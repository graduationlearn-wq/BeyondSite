<%
  // ── SAFE LOCALS (Round E — Portfolio / Freelancer) ────────
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);
  const bn      = esc(L.businessName) || 'Aria Mehta';
  const tagln   = esc(L.tagline)      || 'Brand & editorial designer.';
  const accent  = L.primaryColor      || '#111111';
  const year    = L.year              || new Date().getFullYear();

  // Hero
  const heroEyebrowV      = def(L.heroEyebrow,      `Available for select projects · ${year}`);
  const bnParts           = bn.split(/\s+/);
  const heroNameLeadV     = def(L.heroNameLead, bnParts[0] || bn);
  const heroNameTailV     = def(L.heroNameTail, bnParts.slice(1).join(' ') || '');
  const heroRoleV         = def(L.heroRole, 'Brand & Editorial Designer');
  const heroSubV          = def(L.heroSub,
    'I help small studios and ambitious founders build brands that have a point of view. Most of my work sits at the intersection of editorial typography, considered visual systems, and clear writing.');
  const heroCtaPrimaryV   = def(L.heroCtaPrimary,   'View Work');
  const heroCtaSecondaryV = def(L.heroCtaSecondary, 'Get in Touch');

  // Skills
  const skillsItemsList = (Array.isArray(L.skillsItems) && L.skillsItems.length)
    ? L.skillsItems.map(s => esc(s.text || s)).filter(Boolean)
    : ['Brand Identity','Editorial Design','Typography','Print','Web','Packaging','Art Direction','Strategy'];

  // About
  const aboutLabelV        = def(L.aboutLabel,        'About');
  const aboutHeadlineLeadV = def(L.aboutHeadlineLead, 'Designing things');
  const aboutHeadlineEmphV = def(L.aboutHeadlineEmph, 'that mean something.');
  const aboutBodyV         = def(L.aboutBody || L.about,
    `Hi, I'm ${heroNameLeadV}. I've spent the last decade making things — first at a small studio in Bombay, then briefly in-house at a magazine, and for the past six years on my own.\n\nI work in close partnership with founders and editors who care deeply about how their work looks and reads. Most engagements run six to twelve weeks. I take on roughly eight clients a year, with at least one personal or pro-bono project mixed in.\n\nIf you're building something with a strong point of view and you want a collaborator rather than a vendor, I'd love to hear from you.`);
  const aboutLocationLineV = def(L.aboutLocationLine, 'Mumbai · Available remotely worldwide');

  // Work
  const workLabelV    = def(L.workLabel,    'Selected Work');
  const workHeadlineV = def(L.workHeadline, "A few things I'm proud of.");
  const workItemsList = (Array.isArray(L.workItems) && L.workItems.length)
    ? L.workItems
    : [
        { year:'2024', client:'Helix Coffee',      title:'Brand identity & packaging',    body:'Logo, typography, packaging system, and editorial photography direction for a third-wave roaster expanding to four cities.', tag:'Branding' },
        { year:'2024', client:'Northbeam Magazine',title:'Quarterly editorial redesign',  body:'Full editorial redesign across grid, typography, and section structure for an architecture quarterly.',                  tag:'Editorial' },
        { year:'2023', client:'Studio Halve',      title:'Website & writing system',      body:'Design and copywriting for a 12-page studio site, including a custom CMS structure for project case studies.',          tag:'Web' },
        { year:'2023', client:'Orbit Skincare',    title:'Packaging redesign · 14 SKUs',  body:'A complete packaging refresh across the line, plus the launch campaign visual system.',                                  tag:'Packaging' },
        { year:'2022', client:'Maya Editions',     title:'Custom typeface · "Maya Display"', body:'A serif display family in three weights, drawn for a small literary publisher\'s book covers and interiors.',         tag:'Type' },
        { year:'2022', client:'Helix Coffee',      title:'In-store editorial program',     body:'Quarterly seasonal menus, postcards, and shelf-talkers for thirty-two retail locations.',                              tag:'Editorial' }
      ];

  // Services
  const servicesLabelV    = def(L.servicesLabel,    'Services');
  const servicesHeadlineV = def(L.servicesHeadline, 'What I can take on.');
  const servicesList = (Array.isArray(L.services) && L.services.length && (L.services[0].name || L.services[0].title))
    ? L.services
    : [
        { name:'Brand Identity',    body:'Logo, typography, voice, and a system that scales from a business card to a 200-page lookbook.' },
        { name:'Editorial Design',  body:'Magazines, books, reports, and editorial systems for publishers who care about how the work feels in hand.' },
        { name:'Typography',        body:'Custom typefaces and lettering for brands and publications. From a logo wordmark to a complete display family.' },
        { name:'Web & Digital',     body:'Marketing sites and editorial-led product UI, designed in close collaboration with a small developer network.' },
        { name:'Strategy & Writing','body':'Naming, positioning, and editorial copy for projects where the words matter as much as the visuals.' }
      ];

  // Clients
  const clientListList = (Array.isArray(L.clientList) && L.clientList.length)
    ? L.clientList.map(c => esc(c.name || c)).filter(Boolean)
    : ['Helix Coffee','Northbeam Magazine','Studio Halve','Orbit Skincare','Maya Editions','Atelier Co.','Forge Architects','Marigold Press','Quiet Records','Paper Lantern Books'];

  // Testimonials
  const testimonialsList = (Array.isArray(L.testimonials) && L.testimonials.length)
    ? L.testimonials
    : [
        { quote:`${heroNameLeadV} doesn't decorate, ${heroNameLeadV.toLowerCase()} reasons. Every choice on our brand had a clear answer behind it. I'd hire again in a heartbeat.`, name:'Sarah Lin',    role:'Founder · Helix Coffee' },
        { quote:'The redesign moved the magazine from "competent" to "essential" in our readers\' minds. A genuinely transformative engagement.',                                       name:'Marcus Webb',  role:'Editor-in-Chief · Northbeam' },
        { quote:'A real collaborator. Thoughtful, fast, and the writing was as sharp as the visuals — rare combination.',                                                              name:'Priya Raman',  role:'Founder · Orbit' }
      ];

  // CTA
  const ctaHeadlineLeadV = def(L.ctaHeadlineLead, 'Have something');
  const ctaHeadlineEmphV = def(L.ctaHeadlineEmph, 'worth making?');
  const ctaBodyV         = def(L.ctaBody,         'I take on around eight projects a year. If you have something you care about, I\'d love to hear about it — even if you\'re not sure of the scope yet.');
  const ctaButtonV       = def(L.ctaButton,       'Start a Conversation');

  // Helpers
  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1,2);
    return (a + b).toUpperCase();
  }
  const emailV   = esc(L.email)   || 'hello@ariamehta.in';
  const phoneV   = esc(L.phone)   || '';
  const addressV = esc(L.address) || 'Mumbai, India';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bn %> — <%= heroRoleV %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600;1,9..144,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:        #ffffff;
      --bg-2:      #f5f3ee;
      --ink:       #0a0a0a;
      --ink-soft:  rgba(10,10,10,.7);
      --ink-mute:  rgba(10,10,10,.45);
      --ink-line:  rgba(10,10,10,.1);
      --ink-line-2:rgba(10,10,10,.18);
      --accent:    <%= accent %>;
      --serif:     'Fraunces', 'Cormorant Garamond', Georgia, serif;
      --sans:      'Inter', system-ui, sans-serif;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--bg);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none;background:none}
    em{font-style:italic;font-family:var(--serif);font-weight:500}
    .container{max-width:1240px;margin:0 auto;padding:0 40px}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .7s ease,transform .7s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── NAV */
    .nav{
      position:sticky;top:0;z-index:50;
      background:rgba(255,255,255,.94);backdrop-filter:blur(10px);
      border-bottom:1px solid var(--ink-line)
    }
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:22px 0}
    .brand{font-family:var(--serif);font-size:1.2rem;font-weight:600;letter-spacing:-.005em}
    .brand em{color:var(--ink-soft);font-weight:500}
    .nav-links{display:flex;gap:32px;list-style:none;align-items:center}
    .nav-links a{font-size:.88rem;color:var(--ink-soft);transition:color .2s;font-weight:400}
    .nav-links a:hover{color:var(--ink)}
    .nav-links .nav-cta{
      background:var(--ink);color:var(--bg);padding:8px 18px;border-radius:100px;
      font-weight:500;transition:background .2s
    }
    .nav-links .nav-cta:hover{background:#333;color:var(--bg)}

    /* ── HERO */
    .hero{padding:140px 0 100px}
    .hero-inner{max-width:1100px}
    .hero-eyebrow{
      font-size:.78rem;color:var(--ink-mute);font-weight:500;
      letter-spacing:.01em;margin-bottom:36px;
      display:flex;align-items:center;gap:10px
    }
    .hero-eyebrow::before{content:'';width:24px;height:1px;background:var(--ink-line-2)}
    .hero-name{
      font-family:var(--serif);font-weight:500;
      font-size:clamp(3rem, 9vw, 8.4rem);
      line-height:.95;letter-spacing:-.025em;color:var(--ink);
      margin-bottom:14px
    }
    .hero-name em{font-weight:600;display:inline-block;padding-left:.05em}
    .hero-role{
      font-family:var(--serif);font-style:italic;font-weight:500;
      font-size:clamp(1.4rem,2.6vw,2.2rem);color:var(--ink-soft);
      margin-bottom:48px;letter-spacing:-.005em
    }
    .hero-sub{font-size:1.1rem;color:var(--ink-soft);max-width:620px;line-height:1.75;margin-bottom:48px;font-weight:400}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
    .btn{
      display:inline-flex;align-items:center;gap:8px;
      padding:14px 28px;border-radius:100px;
      font-size:.92rem;font-weight:500;letter-spacing:.005em;
      transition:transform .15s,background .2s,color .2s,border-color .2s
    }
    .btn:hover{transform:translateY(-1px)}
    .btn-primary{background:var(--ink);color:var(--bg)}
    .btn-primary:hover{background:#333;color:var(--bg)}
    .btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--ink-line-2)}
    .btn-ghost:hover{background:var(--ink);color:var(--bg);border-color:var(--ink)}

    /* ── SKILLS MARQUEE */
    .skills-strip{
      background:var(--bg-2);border-top:1px solid var(--ink-line);border-bottom:1px solid var(--ink-line);
      padding:22px 0;overflow:hidden
    }
    .skills-track{
      display:flex;gap:36px;align-items:center;
      animation:skillScroll 30s linear infinite
    }
    .skills-track:hover{animation-play-state:paused}
    .skills-item{
      font-family:var(--serif);font-style:italic;font-size:1.1rem;
      color:var(--ink-soft);white-space:nowrap;font-weight:500
    }
    .skills-item + .skills-item::before{
      content:'·';margin-right:36px;color:var(--ink-mute);font-style:normal
    }
    @keyframes skillScroll{
      from{transform:translateX(0)} to{transform:translateX(-50%)}
    }

    /* ── SECTION HEAD */
    .section-pad{padding:120px 0}
    .section-head{margin-bottom:80px;max-width:760px}
    .section-eyebrow{
      font-size:.74rem;font-weight:500;letter-spacing:.16em;text-transform:uppercase;
      color:var(--ink-mute);margin-bottom:18px;display:flex;align-items:center;gap:12px
    }
    .section-eyebrow::before{content:'—'}
    .section-title{
      font-family:var(--serif);font-size:clamp(2.2rem,4.2vw,4rem);font-weight:500;
      line-height:1.05;letter-spacing:-.018em;color:var(--ink)
    }
    .section-title em{font-weight:600}

    /* ── ABOUT */
    .about{background:var(--bg)}
    .about-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:96px;align-items:start}
    .about-meta{
      font-size:.86rem;color:var(--ink-mute);
      padding-top:32px;border-top:1px solid var(--ink-line);margin-top:32px
    }
    .about-body{font-family:var(--serif);font-size:1.25rem;line-height:1.55;color:var(--ink);font-weight:400;letter-spacing:-.005em}
    .about-body p + p{margin-top:1.4em}
    .about-body p:first-letter{
      font-family:var(--serif);font-size:3.5rem;font-weight:600;
      float:left;line-height:.95;padding:6px 12px 0 0;color:var(--ink)
    }

    /* ── WORK */
    .work{background:var(--bg-2);border-top:1px solid var(--ink-line);border-bottom:1px solid var(--ink-line)}
    .work-list{display:flex;flex-direction:column;border-top:1px solid var(--ink-line-2)}
    .work-item{
      display:grid;grid-template-columns:80px 1fr auto;gap:32px;
      padding:32px 0;border-bottom:1px solid var(--ink-line-2);
      align-items:baseline;transition:background .2s,padding .2s;
      cursor:default
    }
    .work-item:hover{padding-left:18px;padding-right:18px;background:var(--bg)}
    .work-year{
      font-family:var(--serif);font-size:1rem;color:var(--ink-mute);
      font-feature-settings:'tnum';font-weight:500
    }
    .work-content{display:flex;flex-direction:column;gap:6px}
    .work-client{
      font-size:.74rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
      color:var(--ink-mute)
    }
    .work-title{
      font-family:var(--serif);font-size:1.65rem;font-weight:500;color:var(--ink);
      line-height:1.2;letter-spacing:-.012em
    }
    .work-body{font-size:.93rem;color:var(--ink-soft);max-width:560px;line-height:1.6;margin-top:4px}
    .work-tag{
      font-family:var(--serif);font-style:italic;font-size:.92rem;color:var(--ink-mute);
      white-space:nowrap;font-weight:500
    }

    /* ── SERVICES */
    .services{background:var(--bg)}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1px;background:var(--ink-line-2);border:1px solid var(--ink-line-2)}
    .service-card{
      background:var(--bg);padding:40px 32px;
      transition:background .2s
    }
    .service-card:hover{background:var(--bg-2)}
    .service-num{
      font-family:var(--serif);font-size:.92rem;color:var(--ink-mute);
      letter-spacing:.05em;margin-bottom:18px;font-weight:500
    }
    .service-name{
      font-family:var(--serif);font-size:1.4rem;font-weight:500;color:var(--ink);
      margin-bottom:14px;letter-spacing:-.01em
    }
    .service-body{font-size:.93rem;color:var(--ink-soft);line-height:1.7}

    /* ── CLIENTS */
    .clients-strip{background:var(--ink);color:var(--bg);padding:48px 0}
    .clients-eyebrow{
      font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;
      color:rgba(255,255,255,.5);font-weight:500;margin-bottom:18px;text-align:center
    }
    .clients-list{
      display:flex;flex-wrap:wrap;justify-content:center;gap:36px 48px;
      max-width:1100px;margin:0 auto
    }
    .client-name{
      font-family:var(--serif);font-style:italic;font-weight:500;font-size:1.2rem;
      color:rgba(255,255,255,.85)
    }

    /* ── TESTIMONIALS */
    .testi{background:var(--bg-2)}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:32px}
    .testi-card{
      background:var(--bg);border:1px solid var(--ink-line);padding:36px 32px;
      display:flex;flex-direction:column;gap:24px
    }
    .testi-mark{
      font-family:var(--serif);font-size:3rem;line-height:.5;color:var(--ink-line-2);
      font-weight:600;height:18px
    }
    .testi-quote{
      font-family:var(--serif);font-size:1.15rem;line-height:1.55;color:var(--ink);
      font-weight:500;letter-spacing:-.005em;flex:1
    }
    .testi-attr{display:flex;gap:12px;align-items:center;border-top:1px solid var(--ink-line);padding-top:18px}
    .testi-avatar{
      width:38px;height:38px;border-radius:50%;
      background:var(--ink);color:var(--bg);
      display:flex;align-items:center;justify-content:center;
      font-family:var(--serif);font-weight:600;font-size:.88rem
    }
    .testi-name{display:block;font-weight:600;color:var(--ink);font-size:.93rem}
    .testi-role{display:block;font-size:.82rem;color:var(--ink-mute);margin-top:2px}

    /* ── CTA */
    .cta-band{
      background:var(--bg);padding:140px 0;text-align:center;
      border-top:1px solid var(--ink-line)
    }
    .cta-title{
      font-family:var(--serif);font-size:clamp(2.4rem,5vw,4.8rem);font-weight:500;
      line-height:1.05;letter-spacing:-.02em;margin-bottom:24px;color:var(--ink)
    }
    .cta-title em{font-weight:600}
    .cta-body{font-size:1.05rem;color:var(--ink-soft);max-width:540px;margin:0 auto 36px;line-height:1.7}

    /* ── CONTACT */
    .contact{background:var(--bg-2);border-top:1px solid var(--ink-line);padding:96px 0}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px}
    .contact-info{display:flex;flex-direction:column;gap:18px}
    .contact-row{padding:18px 0;border-bottom:1px solid var(--ink-line-2)}
    .contact-row b{display:block;font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-mute);font-weight:600;margin-bottom:6px}
    .contact-row a, .contact-row span{font-family:var(--serif);font-size:1.15rem;color:var(--ink);font-weight:500}

    /* ── FOOTER */
    .footer{background:var(--ink);color:rgba(255,255,255,.55);padding:48px 0;font-size:.86rem}
    .footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:18px}
    .footer-brand{font-family:var(--serif);font-style:italic;font-weight:600;color:var(--bg);font-size:1.05rem}

    /* ── RESPONSIVE */
    @media (max-width:980px){
      .about-grid,.contact-grid{grid-template-columns:1fr;gap:48px}
      .work-item{grid-template-columns:60px 1fr;gap:18px}
      .work-tag{grid-column:2;font-size:.82rem}
    }
    @media (max-width:640px){
      .container{padding:0 24px}
      .nav-links li:not(:last-child){display:none}
      .section-pad{padding:72px 0}
      .hero{padding:80px 0 64px}
      .about-body{font-size:1.05rem}
      .about-body p:first-letter{font-size:2.6rem}
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="#" class="brand"><%= esc(heroNameLeadV) %><% if (heroNameTailV) { %> <em><%= esc(heroNameTailV) %></em><% } %></a>
      <ul class="nav-links">
        <li><a href="#work">Work</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#contact" class="nav-cta"><%= esc(heroCtaSecondaryV) %></a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner reveal">
      <div class="hero-eyebrow"><%= esc(heroEyebrowV) %></div>
      <h1 class="hero-name"><%= esc(heroNameLeadV) %><% if (heroNameTailV) { %> <em><%= esc(heroNameTailV) %></em><% } %></h1>
      <div class="hero-role"><%= esc(heroRoleV) %></div>
      <p class="hero-sub"><%= esc(heroSubV) %></p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary"><%= esc(heroCtaPrimaryV) %> →</a>
        <a href="#contact" class="btn btn-ghost"><%= esc(heroCtaSecondaryV) %></a>
      </div>
    </div>
  </section>

  <!-- SKILLS MARQUEE -->
  <% if (skillsItemsList.length) { %>
  <div class="skills-strip">
    <div class="skills-track">
      <% [...skillsItemsList, ...skillsItemsList].forEach(function(s){ %>
        <span class="skills-item"><%= esc(s) %></span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ABOUT -->
  <section id="about" class="about section-pad">
    <div class="container about-grid">
      <div class="reveal">
        <div class="section-eyebrow"><%= esc(aboutLabelV) %></div>
        <h2 class="section-title"><%= esc(aboutHeadlineLeadV) %><br><em><%= esc(aboutHeadlineEmphV) %></em></h2>
        <% if (aboutLocationLineV) { %>
          <div class="about-meta"><%= esc(aboutLocationLineV) %></div>
        <% } %>
      </div>
      <div class="about-body reveal">
        <% String(aboutBodyV).split(/\n\s*\n/).forEach(function(para){ %>
          <p><%= esc(para) %></p>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="work section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(workLabelV) %> · <%= String(workItemsList.length).padStart(2,'0') %></div>
        <h2 class="section-title"><%= esc(workHeadlineV) %></h2>
      </div>
      <div class="work-list">
        <% workItemsList.forEach(function(w){ %>
        <article class="work-item reveal">
          <span class="work-year"><%= esc(w.year) %></span>
          <div class="work-content">
            <% if (w.client) { %><span class="work-client"><%= esc(w.client) %></span><% } %>
            <h3 class="work-title"><%= esc(w.title) %></h3>
            <% if (w.body) { %><p class="work-body"><%= esc(w.body) %></p><% } %>
          </div>
          <% if (w.tag) { %><span class="work-tag">— <%= esc(w.tag) %></span><% } %>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="services section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(servicesLabelV) %></div>
        <h2 class="section-title"><%= esc(servicesHeadlineV) %></h2>
      </div>
      <div class="services-grid">
        <% servicesList.forEach(function(s, i){ %>
        <article class="service-card reveal">
          <div class="service-num"><%= String(i+1).padStart(2,'0') %> / <%= String(servicesList.length).padStart(2,'0') %></div>
          <h3 class="service-name"><%= esc(s.name) %></h3>
          <p class="service-body"><%= esc(s.body) %></p>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CLIENTS STRIP -->
  <% if (clientListList.length) { %>
  <section class="clients-strip">
    <div class="clients-eyebrow">Trusted by</div>
    <div class="clients-list">
      <% clientListList.forEach(function(c){ %>
        <span class="client-name"><%= esc(c) %></span>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- TESTIMONIALS -->
  <section class="testi section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow">Words from clients</div>
        <h2 class="section-title">A few <em>kind notes.</em></h2>
      </div>
      <div class="testi-grid">
        <% testimonialsList.forEach(function(t){ %>
        <article class="testi-card reveal">
          <div class="testi-mark">"</div>
          <p class="testi-quote"><%= esc(t.quote) %></p>
          <div class="testi-attr">
            <div class="testi-avatar"><%= initialsOf(t.name) %></div>
            <div>
              <span class="testi-name"><%= esc(t.name) %></span>
              <% if (t.role) { %><span class="testi-role"><%= esc(t.role) %></span><% } %>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container reveal">
      <h2 class="cta-title"><%= esc(ctaHeadlineLeadV) %><br><em><%= esc(ctaHeadlineEmphV) %></em></h2>
      <p class="cta-body"><%= esc(ctaBodyV) %></p>
      <a href="#contact" class="btn btn-primary"><%= esc(ctaButtonV) %> →</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact">
    <div class="container contact-grid reveal">
      <div>
        <div class="section-eyebrow">Get in touch</div>
        <h2 class="section-title" style="margin-bottom:24px">Let's <em>talk.</em></h2>
        <p style="font-size:1.02rem;color:var(--ink-soft);line-height:1.7;max-width:480px">The fastest way to reach me is by email — I usually reply within a day. If your project is time-sensitive or you'd rather chat, drop a phone number and I'll set up a call.</p>
      </div>
      <div class="contact-info">
        <% if (emailV)   { %><div class="contact-row"><b>Email</b><a href="mailto:<%= esc(emailV) %>"><%= esc(emailV) %></a></div><% } %>
        <% if (phoneV)   { %><div class="contact-row"><b>Phone</b><span><%= esc(phoneV) %></span></div><% } %>
        <% if (addressV) { %><div class="contact-row"><b>Based in</b><span><%- esc(addressV).replace(/\n/g,' · ') %></span></div><% } %>
        <div class="contact-row"><b>Currently</b><span><%= esc(aboutLocationLineV) %></span></div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-brand"><%= bn %> · <%= year %></span>
      <span>Designed and built with care.</span>
    </div>
  </footer>

  <script>
    var ro = new IntersectionObserver(function(es){
      es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('visible'); ro.unobserve(e.target); } });
    }, { threshold:.06, rootMargin:'0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el){ ro.observe(el); });

    document.querySelectorAll('a[href^="#"]').forEach(function(a){
      a.addEventListener('click', function(e){
        var t = document.querySelector(a.getAttribute('href'));
        if (t){ e.preventDefault(); t.scrollIntoView({ behavior:'smooth', block:'start' }); }
      });
    });
  </script>
</body>
</html>
