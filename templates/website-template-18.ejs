  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --lab:        <%= accent %>;
      --lab-soft:   #38bdf8;
      --lab-deep:   #0369a1;
      --lab-tint:   rgba(14,165,233,.1);
      --lab-glow:   rgba(14,165,233,.28);
      --beaker:     #22c55e;
      --beaker-deep:#15803d;
      --beaker-tint:rgba(34,197,94,.1);
      --amber:      #f97316;
      --amber-tint: rgba(249,115,22,.12);
      --warning:    #facc15;
      --rose:       #f43f5e;
      --rose-tint:  rgba(244,63,94,.1);
      --purple:     #a855f7;
      --purple-tint:rgba(168,85,247,.1);
      --paper:      #ffffff;
      --bg:         #fafbfc;
      --ice:        #f0f9ff;
      --ice2:       #e0f2fe;
      --ink:        #0f172a;
      --ink-soft:   #475569;
      --ink-mute:   rgba(15,23,42,.5);
      --ink-line:   rgba(15,23,42,.07);
      --ink-line-md:rgba(15,23,42,.12);
      --green-flag: #16a34a;
      --amber-flag: #f59e0b;
      --red-flag:   #dc2626;
      --display:    'Space Grotesk', system-ui, sans-serif;
      --sans:       'Inter', system-ui, -apple-system, sans-serif;
      --mono:       'JetBrains Mono', ui-monospace, monospace;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--paper);color:var(--ink);line-height:1.7;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none}
    em{font-style:normal;color:var(--lab-deep);background:linear-gradient(180deg,transparent 60%,var(--lab-tint) 60%);padding:0 .1em}
    .container{max-width:1240px;margin:0 auto;padding:0 32px}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── TOPBAR ─────────────────────────────────────────────── */
    .topbar{background:var(--ink);color:rgba(255,255,255,.78);font-size:.74rem;padding:9px 0}
    .topbar-inner{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;max-width:1240px;margin:0 auto;padding:0 32px}
    .topbar-info{display:flex;gap:18px;flex-wrap:wrap;align-items:center}
    .topbar-info b{font-weight:700;color:#fff}
    .topbar-helpline{display:inline-flex;align-items:center;gap:8px;background:var(--beaker-tint);color:var(--beaker);padding:5px 12px;border-radius:100px;font-weight:700;font-size:.74rem}
    .topbar-helpline::before{content:'☎';font-size:.85rem}

    /* ── NAV ────────────────────────────────────────────────── */
    .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.95);backdrop-filter:blur(14px);border-bottom:1px solid var(--ink-line)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .brand{display:flex;align-items:center;gap:12px;font-family:var(--display);font-size:1.35rem;font-weight:700;color:var(--ink);letter-spacing:-.02em;white-space:nowrap}
    .brand-mark{width:42px;height:42px;border-radius:11px;background:linear-gradient(135deg,var(--lab),var(--lab-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.1rem;box-shadow:0 8px 20px var(--lab-glow);position:relative;overflow:hidden}
    .brand-mark::before{content:'';position:absolute;width:18px;height:24px;background:#fff;border-radius:0 0 50% 50% / 0 0 22% 22%;top:8px;left:50%;transform:translateX(-50%);box-shadow:0 0 0 2px rgba(255,255,255,.25)}
    .brand-mark::after{content:'';position:absolute;width:8px;height:10px;background:var(--amber);border-radius:0 0 50% 50% / 0 0 35% 35%;top:18px;left:50%;transform:translateX(-50%)}
    .nav-links{display:flex;gap:26px;align-items:center;list-style:none}
    .nav-links a{color:var(--ink-soft);font-size:.92rem;font-weight:500;transition:color .2s}
    .nav-links a:hover{color:var(--lab-deep)}
    .nav-cta{background:var(--lab-deep);color:#fff;padding:10px 22px;border-radius:100px;font-weight:600;box-shadow:0 8px 22px var(--lab-glow);white-space:nowrap}
    .nav-cta:hover{background:var(--lab)}

    /* ── BUTTONS ────────────────────────────────────────────── */
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:100px;font-size:.95rem;font-weight:600;transition:transform .15s,box-shadow .25s,background .25s}
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{background:var(--lab-deep);color:#fff;box-shadow:0 12px 28px var(--lab-glow)}
    .btn-primary:hover{background:var(--lab);box-shadow:0 16px 38px var(--lab-glow)}
    .btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--ink-line-md)}
    .btn-ghost:hover{background:var(--ice);border-color:var(--lab-deep);color:var(--lab-deep)}
    .btn-amber{background:var(--amber);color:#fff;box-shadow:0 12px 28px rgba(249,115,22,.36)}
    .btn-amber:hover{background:#ea580c}

    /* ── HERO ───────────────────────────────────────────────── */
    .hero{padding:60px 0 100px;position:relative;overflow:hidden;background:linear-gradient(180deg,#ffffff 0%,#fafbfc 100%)}
    .hero::before{content:'';position:absolute;top:-220px;right:-220px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,var(--lab-tint) 0%,transparent 65%);pointer-events:none}
    .hero::after{content:'';position:absolute;bottom:-160px;left:-160px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,var(--beaker-tint) 0%,transparent 65%);pointer-events:none}
    .hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:60px;align-items:center;position:relative}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:.78rem;font-weight:600;letter-spacing:.04em;color:var(--lab-deep);background:var(--lab-tint);padding:9px 18px;border-radius:100px;margin-bottom:24px}
    .hero-eyebrow::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--beaker);box-shadow:0 0 0 4px rgba(34,197,94,.2)}
    .hero-title{font-family:var(--display);font-weight:700;font-size:clamp(2.6rem,5.5vw,4.6rem);line-height:1.05;letter-spacing:-.025em;color:var(--ink);margin-bottom:22px}
    .hero-sub{font-size:1.06rem;color:var(--ink-soft);max-width:540px;margin-bottom:28px;line-height:1.78}

    /* HERO SEARCH BAR — signature element */
    .hero-search{background:var(--paper);border:1.5px solid var(--ink-line-md);border-radius:100px;padding:6px 6px 6px 22px;display:flex;align-items:center;gap:8px;max-width:580px;margin-bottom:18px;box-shadow:0 18px 40px -22px rgba(15,23,42,.16);transition:border-color .25s,box-shadow .25s}
    .hero-search:focus-within{border-color:var(--lab-deep);box-shadow:0 18px 40px -16px var(--lab-glow)}
    .hero-search svg{flex-shrink:0;color:var(--ink-mute);width:20px;height:20px}
    .hero-search input{flex:1;border:none;background:transparent;font-family:inherit;font-size:.98rem;color:var(--ink);outline:none;padding:10px 0}
    .hero-search input::placeholder{color:var(--ink-mute)}
    .hero-search-btn{background:var(--lab-deep);color:#fff;padding:12px 24px;border-radius:100px;font-weight:600;font-size:.92rem;transition:background .2s;white-space:nowrap}
    .hero-search-btn:hover{background:var(--lab)}
    .hero-popular{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:30px}
    .hero-popular-label{font-size:.84rem;color:var(--ink-mute);font-weight:500}
    .hero-popular-chip{background:var(--ice);border:1px solid var(--ink-line);color:var(--lab-deep);font-size:.82rem;font-weight:600;padding:5px 12px;border-radius:100px;transition:background .2s,border-color .2s}
    .hero-popular-chip:hover{background:var(--ice2);border-color:var(--lab)}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap}

    /* Hero illustration — test-tube cluster */
    .hero-illo{position:relative;display:flex;justify-content:center;align-items:center}
    .hero-illo-disc{position:absolute;width:440px;height:440px;border-radius:50%;background:linear-gradient(160deg,var(--ice),var(--ice2));z-index:0}
    .hero-illo-svg{position:relative;z-index:2;width:440px;height:440px}
    .float-chip{position:absolute;z-index:3;background:var(--paper);border-radius:14px;display:flex;align-items:center;gap:10px;padding:10px 14px;box-shadow:0 14px 32px -16px rgba(15,23,42,.18);border:1px solid var(--ink-line);font-size:.82rem;font-weight:600;color:var(--ink)}
    .float-chip-1{top:4%;left:-2%}
    .float-chip-2{top:42%;right:-6%}
    .float-chip-3{bottom:6%;left:6%}
    .float-chip .dot{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.96rem;flex-shrink:0;font-weight:700}
    .float-chip-1 .dot{background:var(--beaker-tint);color:var(--beaker-deep)}
    .float-chip-2 .dot{background:var(--amber-tint);color:var(--amber)}
    .float-chip-3 .dot{background:var(--lab-tint);color:var(--lab-deep)}

    /* ── TRUST STRIP ────────────────────────────────────────── */
    .trust-strip{background:var(--ink);padding:34px 0;color:#fff;position:relative;overflow:hidden}
    .trust-strip::before{content:'';position:absolute;left:5%;top:50%;transform:translateY(-50%);font-family:var(--mono);font-weight:700;font-size:10rem;color:rgba(255,255,255,.04);line-height:1}
    .trust-strip-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center;position:relative}
    .trust-stat-v{font-family:var(--display);font-size:clamp(1.7rem,2.6vw,2.4rem);font-weight:700;color:#fff;letter-spacing:-.02em;line-height:1}
    .trust-stat-v span{color:var(--beaker)}
    .trust-stat-l{font-size:.84rem;color:rgba(255,255,255,.65);font-weight:500;margin-top:7px}
    .trust-accred{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:28px;padding-top:24px;border-top:1px solid rgba(255,255,255,.1)}
    .accred-pill{font-family:var(--mono);font-size:.78rem;font-weight:600;color:#fff;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);padding:7px 14px;border-radius:6px;display:inline-flex;align-items:center;gap:6px}
    .accred-pill::before{content:'✓';color:var(--beaker);font-weight:700}

    /* ── SECTION ────────────────────────────────────────────── */
    .section-pad{padding:96px 0}
    .section-head{text-align:left;max-width:780px;margin-bottom:54px}
    .section-head.center{margin-left:auto;margin-right:auto;text-align:center}
    .section-eyebrow{display:inline-block;font-family:var(--mono);font-size:.78rem;font-weight:600;color:var(--lab-deep);background:var(--lab-tint);padding:6px 12px;border-radius:4px;margin-bottom:14px;text-transform:uppercase;letter-spacing:.06em}
    .section-title{font-family:var(--display);font-size:clamp(2rem,3.6vw,3.1rem);font-weight:700;line-height:1.13;letter-spacing:-.025em;color:var(--ink);margin-bottom:16px}
    .section-body{font-size:1.02rem;color:var(--ink-soft);line-height:1.78;max-width:680px}

    /* ── PERIODIC-TABLE CATEGORIES ──────────────────────────── */
    .categories{background:var(--bg)}
    .cats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:14px}
    .cat-card{background:var(--paper);border:1.5px solid var(--ink-line);border-radius:14px;padding:18px;aspect-ratio:1/1;display:flex;flex-direction:column;justify-content:space-between;transition:transform .25s,border-color .25s,box-shadow .25s;cursor:pointer;position:relative;overflow:hidden}
    .cat-card:hover{transform:translateY(-4px);box-shadow:0 18px 36px -22px rgba(15,23,42,.18)}
    .cat-card-top{display:flex;justify-content:space-between;align-items:flex-start}
    .cat-symbol{font-family:var(--display);font-size:1.55rem;font-weight:700;letter-spacing:-.02em;line-height:1}
    .cat-count{font-family:var(--mono);font-size:.7rem;font-weight:600;color:var(--ink-mute);background:var(--ink-line);padding:3px 8px;border-radius:4px;letter-spacing:.04em}
    .cat-icon{font-size:1.7rem;align-self:center;margin:2px 0}
    .cat-name{font-family:var(--display);font-size:.94rem;font-weight:600;color:var(--ink);text-align:left;letter-spacing:-.005em}

    /* ── POPULAR TESTS ──────────────────────────────────────── */
    .pop{background:var(--paper)}
    .pop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px}
    .pop-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:16px;padding:24px;display:flex;flex-direction:column;transition:transform .25s,border-color .25s,box-shadow .25s;position:relative;overflow:hidden}
    .pop-card::before{content:'';position:absolute;top:0;right:0;width:80px;height:80px;background:radial-gradient(circle at top right,var(--lab-tint),transparent 70%);pointer-events:none}
    .pop-card:hover{transform:translateY(-3px);border-color:var(--lab);box-shadow:0 16px 32px -22px var(--lab-glow)}
    .pop-card-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px;position:relative}
    .pop-name{font-family:var(--display);font-size:1.08rem;font-weight:600;color:var(--ink);letter-spacing:-.01em;line-height:1.3}
    .pop-code{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--ink-mute);background:var(--ink-line);padding:4px 8px;border-radius:5px;flex-shrink:0}
    .pop-meta{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;padding-bottom:14px;border-bottom:1px dashed var(--ink-line-md)}
    .pop-tag{font-size:.74rem;font-weight:600;padding:4px 10px;border-radius:6px;letter-spacing:.02em}
    .pop-tag-sample{background:var(--rose-tint);color:var(--rose)}
    .pop-tag-tat{background:var(--beaker-tint);color:var(--beaker-deep)}
    .pop-tag-fast{background:var(--amber-tint);color:var(--amber)}
    .pop-foot{display:flex;justify-content:space-between;align-items:flex-end;gap:10px;margin-top:auto}
    .pop-price{font-family:var(--display);font-size:1.6rem;font-weight:700;color:var(--lab-deep);line-height:1;letter-spacing:-.015em}
    .pop-note{font-size:.74rem;color:var(--ink-mute);margin-top:4px;display:block}
    .pop-book{background:var(--lab-deep);color:#fff;padding:9px 16px;border-radius:100px;font-size:.82rem;font-weight:600;transition:background .2s,transform .15s;white-space:nowrap}
    .pop-book:hover{background:var(--lab);transform:translateY(-1px)}

    /* ── HOME COLLECTION FEATURE ────────────────────────────── */
    .home-coll{background:var(--bg)}
    .home-coll-card{background:linear-gradient(160deg,var(--ink) 0%,#1e293b 100%);color:#fff;border-radius:28px;padding:60px;display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center;position:relative;overflow:hidden;box-shadow:0 30px 60px -30px rgba(15,23,42,.4)}
    .home-coll-card::before{content:'';position:absolute;right:-160px;top:-160px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(14,165,233,.2) 0%,transparent 70%);pointer-events:none}
    .home-coll-card::after{content:'';position:absolute;left:-120px;bottom:-160px;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(34,197,94,.15) 0%,transparent 70%);pointer-events:none}
    .home-coll-card .section-eyebrow{background:rgba(14,165,233,.18);color:var(--lab-soft)}
    .home-coll-title{font-family:var(--display);font-size:clamp(1.8rem,3vw,2.4rem);font-weight:700;line-height:1.18;letter-spacing:-.02em;color:#fff;margin-bottom:18px;position:relative}
    .home-coll-body{color:rgba(255,255,255,.78);font-size:1rem;line-height:1.78;margin-bottom:30px;position:relative}
    .home-coll-perks{display:grid;gap:14px;position:relative}
    .home-coll-perk{display:flex;align-items:center;gap:14px;font-size:.95rem;color:rgba(255,255,255,.88)}
    .home-coll-perk-ic{width:38px;height:38px;border-radius:11px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
    .home-coll-slot{background:#fff;color:var(--ink);border-radius:20px;padding:28px;position:relative;box-shadow:0 24px 50px -22px rgba(0,0,0,.4)}
    .home-coll-slot-eyebrow{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--ink-mute);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
    .home-coll-slot-title{font-family:var(--display);font-size:1.32rem;font-weight:700;color:var(--ink);margin-bottom:18px;letter-spacing:-.01em}
    .home-coll-slot-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px}
    .home-coll-slot-pill{background:var(--ice);border:1.5px solid var(--ink-line);border-radius:10px;padding:11px 14px;font-size:.86rem;font-weight:600;color:var(--ink);text-align:center;transition:border-color .2s,background .2s,color .2s;cursor:pointer}
    .home-coll-slot-pill:hover{border-color:var(--lab-deep);background:var(--lab-tint);color:var(--lab-deep)}
    .home-coll-slot-pill.active{background:var(--lab-deep);border-color:var(--lab-deep);color:#fff;box-shadow:0 6px 14px -4px var(--lab-glow)}
    .home-coll-slot-foot{padding-top:18px;border-top:1px dashed var(--ink-line-md);display:flex;justify-content:space-between;align-items:center;font-size:.84rem;color:var(--ink-soft)}
    .home-coll-slot-foot b{color:var(--ink);font-family:var(--display);font-weight:700;font-size:.92rem;letter-spacing:-.005em}

    /* ── PROCESS ────────────────────────────────────────────── */
    .process{background:var(--paper)}
    .process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
    .process-grid::before{content:'';position:absolute;top:48px;left:8%;right:8%;height:2px;background:repeating-linear-gradient(90deg,var(--lab) 0 6px,transparent 6px 14px);opacity:.4;z-index:0}
    .process-step{position:relative;z-index:1;text-align:center;padding:0 8px}
    .process-icon{width:100px;height:100px;border-radius:50%;background:var(--paper);border:2px solid var(--lab);color:var(--lab-deep);font-size:2rem;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;position:relative;box-shadow:0 14px 28px -14px var(--lab-glow)}
    .process-num{position:absolute;top:-8px;right:-8px;width:30px;height:30px;border-radius:50%;background:var(--amber);color:#fff;font-family:var(--display);font-weight:700;font-size:.88rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(249,115,22,.5)}
    .process-title{font-family:var(--display);font-size:1.18rem;font-weight:700;color:var(--ink);margin-bottom:8px;letter-spacing:-.015em}
    .process-body{font-size:.9rem;color:var(--ink-soft);line-height:1.7;max-width:240px;margin:0 auto 12px}
    .process-duration{display:inline-block;font-family:var(--mono);font-size:.78rem;font-weight:600;color:var(--beaker-deep);background:var(--beaker-tint);padding:4px 12px;border-radius:100px;letter-spacing:.04em}

    /* ── PACKAGES ───────────────────────────────────────────── */
    .pkg{background:var(--bg)}
    .pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:22px}
    .pkg-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:22px;padding:34px 30px;display:flex;flex-direction:column;transition:transform .3s,box-shadow .3s;position:relative;overflow:hidden}
    .pkg-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--lab),var(--beaker));border-radius:22px 22px 0 0}
    .pkg-card:nth-child(2){background:linear-gradient(160deg,var(--lab-deep) 0%,#0c4a6e 100%);color:#fff;border:none;transform:translateY(-8px)}
    .pkg-card:nth-child(2)::before{display:none}
    .pkg-card:nth-child(2) .pkg-name,.pkg-card:nth-child(2) .pkg-price,.pkg-card:nth-child(2) .pkg-tests li{color:#fff}
    .pkg-card:nth-child(2) .pkg-price-note,.pkg-card:nth-child(2) .pkg-ideal{color:rgba(255,255,255,.75)}
    .pkg-card:nth-child(2) .pkg-tests li::before{color:var(--beaker)}
    .pkg-card:nth-child(2) .pkg-ideal{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.16)}
    .pkg-card:hover{transform:translateY(-4px);box-shadow:0 24px 48px -22px rgba(15,23,42,.16)}
    .pkg-card:nth-child(2):hover{transform:translateY(-12px)}
    .pkg-name{font-family:var(--display);font-size:1.35rem;font-weight:700;color:var(--ink);margin-bottom:6px;letter-spacing:-.015em}
    .pkg-price{font-family:var(--display);font-size:2.3rem;font-weight:700;color:var(--lab-deep);line-height:1;margin-bottom:6px;letter-spacing:-.02em}
    .pkg-price-note{font-size:.84rem;color:var(--ink-mute);margin-bottom:18px;font-style:italic}
    .pkg-ideal{font-size:.88rem;color:var(--ink-soft);padding:12px 16px;background:var(--ice);border-radius:12px;margin-bottom:22px;border:1px dashed var(--ink-line-md)}
    .pkg-tests{list-style:none;display:flex;flex-direction:column;gap:10px;flex:1}
    .pkg-tests li{font-size:.92rem;color:var(--ink-soft);line-height:1.55;padding-left:24px;position:relative}
    .pkg-tests li::before{content:'✓';position:absolute;left:0;top:0;color:var(--beaker-deep);font-weight:700;font-size:.95rem}

    /* ── REPORTS + SAMPLE REPORT PREVIEW ────────────────────── */
    .reports{background:var(--paper)}
    .reports-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:60px;align-items:center}
    .reports-features{display:grid;grid-template-columns:1fr;gap:14px;margin-top:30px}
    .rep-feat{display:flex;gap:14px;align-items:flex-start;padding:14px;border-radius:12px;background:var(--bg);border:1px solid var(--ink-line)}
    .rep-feat-ic{width:38px;height:38px;border-radius:10px;background:var(--lab-tint);color:var(--lab-deep);display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0}
    .rep-feat-title{font-family:var(--display);font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:2px;letter-spacing:-.005em}
    .rep-feat-body{font-size:.84rem;color:var(--ink-soft);line-height:1.55}

    /* The fake sample-report card */
    .sample-report{background:var(--paper);border:1px solid var(--ink-line-md);border-radius:18px;padding:28px;box-shadow:0 24px 56px -28px rgba(15,23,42,.22);position:relative;overflow:hidden}
    .sample-report::before{content:'SAMPLE';position:absolute;top:18px;right:-32px;font-family:var(--display);font-size:.7rem;font-weight:700;color:var(--amber);background:var(--amber-tint);border:1px solid var(--amber);padding:4px 36px;letter-spacing:.18em;transform:rotate(35deg);transform-origin:center}
    .sample-report-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding-bottom:18px;border-bottom:2px solid var(--ink);margin-bottom:14px}
    .sample-report-brand{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);letter-spacing:-.005em}
    .sample-report-brand small{display:block;font-size:.7rem;color:var(--ink-mute);font-weight:500;margin-top:2px;font-family:var(--sans)}
    .sample-report-id{text-align:right;font-family:var(--mono);font-size:.7rem;color:var(--ink-mute)}
    .sample-report-id b{color:var(--ink);display:block;font-size:.78rem}
    .sample-report-patient{display:grid;grid-template-columns:1fr 1fr;gap:6px 18px;font-size:.78rem;color:var(--ink-soft);margin-bottom:18px;padding:12px;background:var(--ice);border-radius:8px}
    .sample-report-patient b{color:var(--ink);font-weight:600;font-family:var(--mono);font-size:.72rem}
    .sample-report-title{font-family:var(--display);font-size:.92rem;font-weight:700;color:var(--ink);margin-bottom:10px;letter-spacing:-.005em;padding-bottom:6px;border-bottom:1px dashed var(--ink-line-md)}
    .sample-rows{display:flex;flex-direction:column;gap:0;margin-bottom:16px}
    .sample-row{display:grid;grid-template-columns:1.5fr 1fr 1fr auto;gap:10px;padding:10px 0;border-bottom:1px solid var(--ink-line);font-size:.82rem;align-items:center}
    .sample-row:first-child{font-family:var(--mono);font-size:.66rem;color:var(--ink-mute);text-transform:uppercase;letter-spacing:.06em;font-weight:600;padding:8px 0;background:var(--bg);border-radius:4px 4px 0 0;padding:8px 10px}
    .sample-row .sr-name{font-weight:600;color:var(--ink)}
    .sample-row .sr-val{font-family:var(--mono);font-weight:700;color:var(--ink);font-size:.88rem}
    .sample-row .sr-ref{font-family:var(--mono);font-size:.74rem;color:var(--ink-mute)}
    .sample-flag{font-family:var(--mono);font-size:.68rem;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.05em}
    .flag-normal{background:rgba(22,163,74,.12);color:var(--green-flag)}
    .flag-high{background:rgba(220,38,38,.12);color:var(--red-flag)}
    .flag-borderline{background:rgba(245,158,11,.14);color:var(--amber-flag)}
    .sample-report-comment{margin-top:8px;padding:14px 16px;background:var(--lab-tint);border-left:3px solid var(--lab-deep);border-radius:0 8px 8px 0;font-size:.82rem;color:var(--ink-soft);line-height:1.6}
    .sample-report-comment b{display:block;color:var(--lab-deep);font-family:var(--display);font-size:.78rem;font-weight:700;margin-bottom:4px;letter-spacing:.02em;text-transform:uppercase}
    .sample-report-sig{margin-top:16px;text-align:right;font-size:.74rem;color:var(--ink-mute);line-height:1.4}
    .sample-report-sig b{color:var(--ink);font-family:var(--display);display:block;font-size:.85rem;font-weight:700;letter-spacing:-.005em}
    .sample-report-caption{font-size:.78rem;color:var(--ink-mute);text-align:center;margin-top:18px;font-style:italic}

    /* ── SPECIALISTS ────────────────────────────────────────── */
    .specs{background:var(--bg)}
    .specs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:22px}
    .spec-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:22px;overflow:hidden;transition:transform .3s,box-shadow .3s;display:flex;flex-direction:column}
    .spec-card:hover{transform:translateY(-4px);box-shadow:0 22px 44px -22px rgba(15,23,42,.16)}
    .spec-avatar{background:var(--ice);aspect-ratio:1/1;overflow:hidden;position:relative}
    .spec-info{padding:22px 24px 26px}
    .spec-name{font-family:var(--display);font-size:1.16rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .spec-specialty{font-size:.86rem;color:var(--lab-deep);font-weight:600;margin-top:2px;margin-bottom:14px}
    .spec-quals{font-size:.82rem;color:var(--ink-soft);line-height:1.55;margin-bottom:14px;padding-bottom:14px;border-bottom:1px dashed var(--ink-line-md);font-family:var(--mono);font-size:.78rem}
    .spec-meta{display:flex;flex-direction:column;gap:6px;font-size:.78rem;color:var(--ink-soft)}
    .spec-meta-row{display:flex;align-items:flex-start;gap:8px}
    .spec-meta-row::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--beaker);margin-top:6px;flex-shrink:0}
    .spec-meta-row b{font-weight:600;color:var(--ink);font-family:var(--display);font-size:.78rem;letter-spacing:.005em}

    /* ── TESTIMONIALS ──────────────────────────────────────── */
    .testi{background:var(--paper)}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:22px}
    .testi-card{background:var(--bg);border:1px solid var(--ink-line);border-radius:20px;padding:30px;display:flex;flex-direction:column;transition:transform .25s,box-shadow .25s;position:relative}
    .testi-card::before{content:'\201C';position:absolute;top:14px;right:24px;font-family:var(--display);font-size:5rem;font-weight:700;color:var(--lab-tint);line-height:1}
    .testi-card:hover{transform:translateY(-3px);background:var(--paper);box-shadow:0 18px 36px -22px rgba(15,23,42,.14)}
    .testi-product{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--beaker-deep);background:var(--beaker-tint);padding:5px 10px;border-radius:5px;letter-spacing:.04em;display:inline-block;margin-bottom:14px;text-transform:uppercase}
    .testi-quote{font-size:.98rem;color:var(--ink);line-height:1.7;margin-bottom:22px;flex:1;position:relative;z-index:1}
    .testi-author{display:flex;align-items:center;gap:12px;border-top:1px dashed var(--ink-line-md);padding-top:18px}
    .testi-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--lab),var(--lab-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:700;font-size:.92rem;flex-shrink:0}
    .testi-name{display:block;font-weight:700;color:var(--ink);font-size:.94rem}
    .testi-role{display:block;font-size:.82rem;color:var(--ink-mute);margin-top:2px}

    /* ── INSURERS ──────────────────────────────────────────── */
    .insurers{background:var(--bg);border-top:1px solid var(--ink-line)}
    .insurers-row{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:32px}
    .insurer-pill{background:var(--paper);border:1px solid var(--ink-line);border-radius:100px;padding:10px 18px;font-size:.88rem;font-weight:600;color:var(--ink);display:inline-flex;align-items:center;gap:8px;transition:transform .2s,border-color .2s}
    .insurer-pill:hover{transform:translateY(-2px);border-color:var(--lab);color:var(--lab-deep)}
    .insurer-pill::before{content:'✓';color:var(--beaker-deep);font-weight:800}

    /* ── GRIEVANCE ─────────────────────────────────────────── */
    .grievance{background:var(--paper);border-top:1px solid var(--ink-line)}
    .gv-card{background:var(--bg);border:1px solid var(--ink-line-md);border-radius:24px;padding:48px;box-shadow:0 18px 48px -24px rgba(15,23,42,.1)}
    .gv-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:48px;align-items:start}
    .gv-officer{background:linear-gradient(160deg,var(--lab-deep),#0c4a6e);color:#fff;border-radius:18px;padding:32px;position:sticky;top:100px}
    .gv-officer-eyebrow{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--lab-soft);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}
    .gv-officer-name{font-family:var(--display);font-size:1.5rem;font-weight:700;margin-bottom:4px;letter-spacing:-.01em}
    .gv-officer-role{color:rgba(255,255,255,.75);font-size:.92rem;margin-bottom:24px}
    .gv-info{display:grid;gap:14px;padding-top:20px;border-top:1px dashed rgba(255,255,255,.18)}
    .gv-info-row{display:grid;grid-template-columns:78px 1fr;gap:12px;font-size:.86rem}
    .gv-info-key{font-family:var(--mono);color:rgba(255,255,255,.55);font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:.7rem;padding-top:2px}
    .gv-info-val{color:#fff;line-height:1.55;word-break:break-word}
    .gv-escalation{display:flex;flex-direction:column;gap:14px}
    .gv-step{background:var(--paper);border:1px solid var(--ink-line);border-left:4px solid var(--lab);border-radius:14px;padding:20px 22px}
    .gv-step-head{display:flex;align-items:baseline;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}
    .gv-level{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--lab-deep);letter-spacing:-.005em}
    .gv-tat{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--beaker-deep);background:var(--beaker-tint);padding:3px 9px;border-radius:5px;letter-spacing:.04em}
    .gv-step-body{font-size:.91rem;color:var(--ink-soft);line-height:1.7;margin-bottom:8px}
    .gv-step-contact{font-size:.84rem;font-weight:500;font-family:var(--mono);background:var(--lab-tint);padding:6px 10px;border-radius:6px;display:inline-block;color:var(--lab-deep)}

    /* ── CTA BAND ──────────────────────────────────────────── */
    .cta-band{background:linear-gradient(135deg,var(--lab) 0%,var(--lab-deep) 100%);color:#fff;padding:88px 0;position:relative;overflow:hidden}
    .cta-band::before{content:'';position:absolute;right:-220px;top:-200px;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.14) 0%,transparent 70%)}
    .cta-band::after{content:'';position:absolute;left:-180px;bottom:-160px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(34,197,94,.18) 0%,transparent 70%)}
    .cta-inner{display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:center;position:relative}
    .cta-title{font-family:var(--display);font-size:clamp(2rem,3.3vw,2.8rem);font-weight:700;line-height:1.2;margin-bottom:16px;letter-spacing:-.025em;color:#fff}
    .cta-sub{color:rgba(255,255,255,.85);font-size:1.02rem;line-height:1.7}
    .cta-actions{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .cta-actions .btn-primary{background:#fff;color:var(--lab-deep);box-shadow:0 14px 32px rgba(0,0,0,.2)}
    .cta-actions .btn-primary:hover{background:#f0f9ff}
    .cta-note{font-size:.78rem;color:rgba(255,255,255,.65)}
    .cta-disclaim{font-size:.74rem;color:rgba(255,255,255,.58);margin-top:26px;font-style:italic;line-height:1.7;border-top:1px dashed rgba(255,255,255,.18);padding-top:22px}

    /* ── CONTACT ───────────────────────────────────────────── */
    .contact{background:var(--bg);border-top:1px solid var(--ink-line)}
    .contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:start}
    .contact-info{margin-top:28px;padding-top:22px;border-top:1px dashed var(--ink-line-md);display:grid;gap:12px;font-size:.95rem;color:var(--ink-soft)}
    .contact-info b{color:var(--ink);font-weight:700}
    .form-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:20px;padding:36px;box-shadow:0 18px 44px -22px rgba(15,23,42,.1)}
    .fg{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
    .fg label{font-size:.84rem;font-weight:600;color:var(--ink)}
    .fg input,.fg select,.fg textarea{padding:13px 16px;border:1.5px solid var(--ink-line-md);border-radius:12px;background:var(--paper);font-family:inherit;font-size:.95rem;color:var(--ink);outline:none;transition:border-color .2s}
    .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--lab-deep)}
    .fg select option{background:#fff;color:var(--ink)}
    .fg-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .form-submit{width:100%;background:var(--lab-deep);color:#fff;padding:15px;border-radius:12px;font-size:.96rem;font-weight:700;transition:background .2s,transform .15s;box-shadow:0 10px 26px var(--lab-glow)}
    .form-submit:hover{background:var(--lab);transform:translateY(-1px)}
    .form-disclaim{font-size:.78rem;color:var(--ink-mute);margin-top:12px;line-height:1.6}

    /* ── FOOTER ────────────────────────────────────────────── */
    .footer{background:var(--ink);color:rgba(255,255,255,.62);padding:64px 0 0}
    .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:44px;margin-bottom:44px}
    .f-brand{font-family:var(--display);color:#fff;font-size:1.4rem;font-weight:700;margin-bottom:8px;letter-spacing:-.02em}
    .f-tag{font-size:.86rem;color:rgba(255,255,255,.5);max-width:300px;line-height:1.7;margin-bottom:14px}
    .f-reg{font-family:var(--mono);font-size:.76rem;font-weight:600;color:var(--beaker);margin-bottom:6px;letter-spacing:.02em}
    .f-cert-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
    .f-cert{font-family:var(--mono);font-size:.7rem;font-weight:600;color:#fff;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);padding:6px 11px;border-radius:5px}
    .f-col-title{font-family:var(--display);font-size:.92rem;font-weight:700;color:#fff;margin-bottom:16px;letter-spacing:-.005em}
    .f-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .f-links a{color:rgba(255,255,255,.55);font-size:.86rem;transition:color .2s}
    .f-links a:hover{color:#fff}
    .footer-disclaim{padding:24px 0;border-top:1px solid rgba(255,255,255,.08);font-size:.76rem;color:rgba(255,255,255,.5);line-height:1.85;font-style:italic}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding:20px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;font-size:.78rem;color:rgba(255,255,255,.42)}

    /* ── RESPONSIVE ────────────────────────────────────────── */
    @media(max-width:980px){
      .hero-grid,.reports-grid,.gv-grid,.cta-inner,.contact-grid{grid-template-columns:1fr;gap:48px}
      .home-coll-card{grid-template-columns:1fr;padding:40px;gap:36px}
      .gv-officer{position:static}
      .process-grid{grid-template-columns:repeat(2,1fr)}
      .process-grid::before{display:none}
      .trust-strip-grid{grid-template-columns:repeat(2,1fr);gap:24px}
      .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
      .cta-actions{text-align:left;align-items:flex-start}
      .hero-illo-disc,.hero-illo-svg{width:360px;height:360px}
      .pkg-card:nth-child(2){transform:none}
      .pkg-card:nth-child(2):hover{transform:translateY(-4px)}
    }
    @media(max-width:640px){
      .container{padding:0 22px}
      .nav-inner{padding:14px 0}
      .nav-links li:not(:last-child){display:none}
      .brand{font-size:1.05rem;gap:10px}
      .brand-mark{width:34px;height:34px;font-size:.95rem}
      .nav-cta{padding:8px 14px;font-size:.82rem}
      .topbar{font-size:.68rem;padding:7px 0}
      .topbar-inner{flex-direction:column;gap:6px;align-items:flex-start}
      .topbar-info{gap:6px 12px}
      .section-pad{padding:72px 0}
      .process-grid{grid-template-columns:1fr}
      .trust-strip-grid{grid-template-columns:1fr;gap:24px}
      .footer-grid{grid-template-columns:1fr}
      .fg-row{grid-template-columns:1fr}
      .gv-card{padding:30px 22px}
      .home-coll-card{padding:32px 22px}
      .hero-illo-disc,.hero-illo-svg{width:300px;height:300px}
      .float-chip-1,.float-chip-2,.float-chip-3{display:none}
      .cats-grid{grid-template-columns:repeat(2,1fr)}
      .hero-search{padding:6px 6px 6px 18px}
      .hero-search input{font-size:.88rem;padding:9px 0}
      .hero-search-btn{padding:10px 16px;font-size:.82rem}
      .sample-row{grid-template-columns:1.4fr 1fr auto;gap:6px;font-size:.74rem}
      .sample-row .sr-ref{display:none}
      .sample-report{padding:22px}
      .home-coll-slot-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-info">
      <span><%= esc(nablRegV) %></span>
      <span><%= esc(capCertV) %></span>
      <span>ICMR: <b><%= esc(icmrRegV) %></b></span>
    </div>
    <a href="tel:<%= esc(emergencyPhoneV) %>" class="topbar-helpline">24×7 Helpline · <%= esc(emergencyPhoneV) %></a>
  </div>
</div>

<nav class="nav">
  <div class="container nav-inner">
    <a href="#" class="brand">
      <span class="brand-mark"></span>
      <span><%= bn %></span>
    </a>
    <ul class="nav-links">
      <li><a href="#categories">Tests</a></li>
      <li><a href="#packages">Packages</a></li>
      <li><a href="#home-coll">Home Collection</a></li>
      <li><a href="#specialists">Pathologists</a></li>
      <li><a href="#contact" class="nav-cta"><%= esc(heroCtaPrimaryV) %></a></li>
    </ul>
  </div>
</nav>

<section class="hero">
  <div class="container hero-grid">
    <div class="reveal">
      <div class="hero-eyebrow"><%= esc(heroEyebrowV) %></div>
      <h1 class="hero-title"><%= esc(heroHeadlineLeadV) %> <em><%= esc(heroHeadlineEmphV) %></em></h1>
      <p class="hero-sub"><%= esc(heroSubV) %></p>
      <form class="hero-search" onsubmit="event.preventDefault();document.querySelector('#popular-tests').scrollIntoView({behavior:'smooth'})">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="<%= esc(heroSearchPlaceholderV) %>" aria-label="Search tests">
        <button type="submit" class="hero-search-btn"><%= esc(heroSearchCtaV) %></button>
      </form>
      <div class="hero-popular">
        <span class="hero-popular-label">Popular:</span>
        <a href="#popular-tests" class="hero-popular-chip">Vitamin D</a>
        <a href="#popular-tests" class="hero-popular-chip">Thyroid</a>
        <a href="#popular-tests" class="hero-popular-chip">HbA1c</a>
        <a href="#popular-tests" class="hero-popular-chip">Lipid Profile</a>
        <a href="#popular-tests" class="hero-popular-chip">CBC</a>
      </div>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary"><%= esc(heroCtaPrimaryV) %> →</a>
        <a href="#packages" class="btn btn-ghost"><%= esc(heroCtaSecondaryV) %></a>
      </div>
    </div>

    <div class="hero-illo reveal">
      <div class="hero-illo-disc"></div>
      <div class="float-chip float-chip-1">
        <span class="dot">⏱</span>
        <span>Same-day TAT</span>
      </div>
      <div class="float-chip float-chip-2">
        <span class="dot">🚚</span>
        <span>Home collection · Free</span>
      </div>
      <div class="float-chip float-chip-3">
        <span class="dot">✓</span>
        <span>Pathologist-verified</span>
      </div>
      <div class="hero-illo-svg">
        <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
          <defs>
            <linearGradient id="liquidR" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fda4af"/><stop offset="100%" stop-color="#dc2626"/></linearGradient>
            <linearGradient id="liquidA" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fbbf24"/><stop offset="100%" stop-color="#f97316"/></linearGradient>
