        <path d="M 134 246 L 134 256 M 146 246 L 146 256 M 130 256 L 150 256" stroke="#fff" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        <!-- ID badge -->
        <rect x="178" y="215" width="22" height="28" rx="3" fill="#fff" stroke="#cbd5e1" stroke-width="1.5"/>
        <line x1="183" y1="222" x2="195" y2="222" stroke="#0ea5e9" stroke-width="2"/>
        <line x1="183" y1="227" x2="192" y2="227" stroke="#94a3b8" stroke-width="1.5"/>
        <line x1="183" y1="232" x2="194" y2="232" stroke="#94a3b8" stroke-width="1.5"/>
        <rect x="128" y="155" width="24" height="38" rx="8" fill="${v.skin}"/>
        <path d="M 128 168 Q 140 175 152 168 L 152 192 L 128 192 Z" fill="rgba(0,0,0,.06)"/>
        <ellipse cx="140" cy="120" rx="46" ry="52" fill="${v.skin}"/>
        <path d="${v.hairPath}" fill="${v.hair}"/>
