      amber:  { tint: 'rgba(249,115,22,.12)', text: '#c2410c', border: 'rgba(249,115,22,.32)' },
      purple: { tint: 'rgba(168,85,247,.1)',  text: '#6b21a8', border: 'rgba(168,85,247,.3)' },
      rose:   { tint: 'rgba(244,63,94,.1)',   text: '#9f1239', border: 'rgba(244,63,94,.3)' },
      teal:   { tint: 'rgba(20,184,166,.1)',  text: '#0f766e', border: 'rgba(20,184,166,.3)' },
      slate:  { tint: 'rgba(100,116,139,.1)', text: '#334155', border: 'rgba(100,116,139,.3)' }
    };
    return map[c] || map.blue;
