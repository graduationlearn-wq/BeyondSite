  <div class="container cta-inner">
    <div class="reveal">
      <h2 class="cta-title"><%= esc(ctaHeadlineV) %></h2>
      <p class="cta-sub"><%= esc(ctaBodyV) %></p>
      <p class="cta-disclaim"><%= MEDICAL_DISC %></p>
    </div>
    <div class="cta-actions reveal">
      <a href="#contact" class="btn btn-primary"><%= esc(ctaButtonV) %> →</a>
      <%if(ctaNoteV){%><span class="cta-note"><%= esc(ctaNoteV) %></span><%}%>
    </div>
  </div>
</section>

<section id="contact" class="contact section-pad">
  <div class="container contact-grid">
    <div class="reveal">
      <div class="section-eyebrow">Book a test</div>
      <h2 class="section-title">Tell us what you need — <em>we'll do the rest.</em></h2>
      <p class="section-body">Pick a test or package and your preferred home-collection slot. We confirm via SMS within minutes during business hours.</p>
      <div class="contact-info">
        <%if(emailV){%><div><b>Email:</b> <%= esc(emailV) %></div><%}%>
        <%if(phoneV){%><div><b>Reception:</b> <%= esc(phoneV) %></div><%}%>
        <div><b>24×7 Helpline:</b> <%= esc(emergencyPhoneV) %></div>
        <%if(addressV){%><div><b>Address:</b> <%- esc(addressV).replace(/\n/g,'<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;') %></div><%}%>
        <%if(hoursV){%><div><b>Hours:</b> <%= esc(hoursV) %></div><%}%>
      </div>
    </div>
    <div class="form-card reveal">
      <form data-contact>
        <div class="fg-row">
          <div class="fg"><label>Patient name</label><input type="text" placeholder="Your full name" required></div>
          <div class="fg"><label>Mobile</label><input type="tel" placeholder="+91 9XXXXXXXXX" required></div>
        </div>
        <div class="fg"><label>Email (for report delivery)</label><input type="email" placeholder="you@example.com"></div>
        <div class="fg">
          <label>What do you want to book?</label>
          <select required>
            <option value="" disabled selected>Pick a test or package</option>
            <% popularTestsList.slice(0,6).forEach(function(t){ %><option><%= esc(t.name) %></option><% }); %>
            <% healthPackagesList.forEach(function(p){ %><option><%= esc(p.name) %> Package</option><% }); %>
            <option>Custom panel — let's discuss</option>
          </select>
        </div>
        <div class="fg-row">
          <div class="fg"><label>Preferred date</label><input type="date"></div>
          <div class="fg">
            <label>Preferred slot</label>
            <select>
              <option>06:30 – 08:00</option>
              <option selected>08:00 – 09:30</option>
              <option>09:30 – 11:00</option>
              <option>11:00 – 12:30</option>
              <option>16:00 – 18:00</option>
            </select>
          </div>
        </div>
        <div class="fg"><label>Pickup address</label><textarea rows="2" placeholder="Flat / building / area / city / pincode"></textarea></div>
        <button type="submit" class="form-submit">Book Home Collection →</button>
        <p class="form-disclaim">By submitting, you agree to be contacted by <%= bn %>. <%= MEDICAL_DISC %></p>
      </form>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="f-brand"><%= bn %></div>
        <p class="f-tag"><%= tagln %></p>
        <div class="f-reg"><%= esc(nablRegV) %></div>
        <div class="f-reg"><%= esc(capCertV) %></div>
        <div class="f-reg">ICMR: <%= esc(icmrRegV) %></div>
        <div class="f-reg">CEA: <%= esc(clinicalEstabRegV) %></div>
        <div class="f-reg">BMW: <%= esc(bmwRegV) %></div>
        <div class="f-reg">PCPNDT: <%= esc(pcpndtRegV) %></div>
        <%if(hospitalCinV){%><div class="f-reg">CIN: <%= esc(hospitalCinV) %></div><%}%>
        <div class="f-cert-row">
          <span class="f-cert">ISO 15189</span>
          <span class="f-cert">ISO 9001</span>
          <span class="f-cert">CAP</span>
        </div>
      </div>
      <div>
        <p class="f-col-title">Tests</p>
        <ul class="f-links">
          <% testCategoriesList.slice(0,6).forEach(function(c){ %><li><a href="#categories"><%= esc(c.name) %></a></li><% }); %>
        </ul>
      </div>
      <div>
        <p class="f-col-title">Patient</p>
        <ul class="f-links">
          <li><a href="#home-coll">Home collection</a></li>
          <li><a href="#packages">Health packages</a></li>
          <li><a href="#reports">Digital reports</a></li>
          <li><a href="#grievance">Grievance redressal</a></li>
        </ul>
      </div>
      <div>
        <p class="f-col-title">Regulatory</p>
        <ul class="f-links">
          <li><a href="https://www.nabl-india.org" target="_blank" rel="noopener">NABL ↗</a></li>
          <li><a href="https://www.cap.org" target="_blank" rel="noopener">CAP ↗</a></li>
          <li><a href="https://www.icmr.gov.in" target="_blank" rel="noopener">ICMR ↗</a></li>
          <li><a href="#grievance">State Medical Council</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-disclaim">
      <%= MEDICAL_DISC %> <%= REFRANGE_DISC %> <%= NO_CURE_DISC %> <%= PCPNDT_DISC %>
      <br>All sample reports, patient data and results shown on this website are illustrative. Real reports are delivered only to the registered patient and shared per their explicit consent under the Digital Personal Data Protection Act 2023.
    </div>
    <div class="footer-bottom">
      <span>© <%= year %> <%= bn %>. All rights reserved.</span>
      <span>Privacy · Terms · Patient Charter</span>
    </div>
  </div>
</footer>

<script>
  var ro=new IntersectionObserver(function(es){
    es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target);}});
  },{threshold:.06,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(function(el){ro.observe(el);});
  document.querySelectorAll('a[href^="#"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.querySelector(a.getAttribute('href'));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
    });
  });
  // Slot picker visual feedback
  document.querySelectorAll('.home-coll-slot-pill').forEach(function(p){
    p.addEventListener('click',function(){
      document.querySelectorAll('.home-coll-slot-pill').forEach(function(x){x.classList.remove('active');});
      p.classList.add('active');
    });
  });
  var f=document.querySelector('[data-contact]');
  if(f){f.addEventListener('submit',function(e){
    e.preventDefault();
    var b=f.querySelector('.form-submit');
    b.textContent='Booking…';b.disabled=true;
    setTimeout(function(){
      var ok=document.createElement('div');
      ok.style.cssText='background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.34);color:#15803d;padding:15px 18px;border-radius:12px;font-size:.93rem;margin-bottom:14px;font-weight:600;font-family:Inter,sans-serif';
      ok.textContent='✓ Booking confirmed. Our team will SMS you the phlebotomist details within an hour.';
      f.insertAdjacentElement('beforebegin',ok);
      f.reset();b.textContent='Book Home Collection →';b.disabled=false;
      setTimeout(function(){ok.remove();},8000);
    },900);
  });}
</script>
</body>
</html>
