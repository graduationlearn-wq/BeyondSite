  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().replace(/^Dr\.?\s+/i, '').split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1, 2);
    return (a + b).toUpperCase();
  }

