<%
  // ── SAFE LOCALS (Round K — MF Distributor, template-14) ──────────────────
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);

  const bn      = esc(L.businessName) || 'Vrddhi Wealth';
  const tagln   = esc(L.tagline)      || 'Grow wealth. Build futures.';
  const accent  = L.primaryColor      || '#6b1e2c';
  const year    = L.year              || new Date().getFullYear();
  const founded = esc(L.foundedYear)  || '2012';

  // Regulatory
  const arnNumberV      = def(L.arnNumber,     'ARN-123456');
  const euinNumberV     = def(L.euinNumber,    'E-123456');
  const amfiDisclosureV = def(L.amfiDisclosure,'AMFI registered Mutual Fund Distributor · ' + arnNumberV);

  // Mandatory disclaimers — per AMFI/SEBI, must not be removed
  const RISK_DISC      = 'Mutual Fund investments are subject to market risks. Read all scheme-related documents carefully before investing.';
  const PAST_PERF_DISC = 'Past performance does not guarantee future returns.';

  // Hero
  const heroEyebrowV       = def(L.heroEyebrow,      'AMFI Registered ARN holder · Trusted by families since ' + founded);
  const heroHeadlineLeadV  = def(L.heroHeadlineLead, 'Build wealth');
  const heroHeadlineEmphV  = def(L.heroHeadlineEmph, 'systematically.');
  const heroSubV           = def(L.heroSub,           'A SEBI-compliant Mutual Fund Distributor helping Indian families invest in goal-mapped funds — with transparent advice and zero hidden commissions.');
  const heroCtaPrimaryV    = def(L.heroCtaPrimary,   'Start SIP Today');
  const heroCtaSecondaryV  = def(L.heroCtaSecondary, 'Calculate Returns');
  const sipStartingAmountV = def(L.sipStartingAmount,'₹500/month');
  const sipBenefitsList = (Array.isArray(L.sipBenefits) && L.sipBenefits.length)
    ? L.sipBenefits
    : [
        { icon: '📈', text: 'Start with as little as ₹500/month' },
        { icon: '🔄', text: 'Power of compounding over time' },
        { icon: '🛡', text: 'SEBI-regulated, AMFI-compliant' },
        { icon: '✓',  text: 'Goal-based portfolio planning' }
      ];

  // Services
  const servicesLabelV    = def(L.servicesLabel,    'What We Offer');
  const servicesHeadlineV = def(L.servicesHeadline, 'Investment services for every life stage.');
  const servicesBodyV     = def(L.servicesBody,     'From your first SIP to your retirement corpus — personalised advice, transparent commissions, and a relationship that compounds along with your money.');
  const servicesList = (Array.isArray(L.services) && L.services.length && (L.services[0].name || L.services[0].title))
    ? L.services
    : [
        { icon: '🔄', name: 'SIP Investment',      body: 'Systematic Investment Plans starting at ₹500/month. Auto-debit, goal-linked, reviewed annually.' },
        { icon: '💰', name: 'Lumpsum Investment',   body: 'One-time investments for surplus funds, timed with market analysis for better entry points.' },
        { icon: '🎯', name: 'Goal-Based Planning',  body: 'Retirement, education, home purchase — mapped to the right fund category and horizon.' },
        { icon: '🧾', name: 'ELSS Tax Saving',      body: 'Section 80C deduction up to ₹1.5L. Three-year lock-in, equity growth potential.' },
        { icon: '📊', name: 'Portfolio Review',     body: 'Annual review — rebalancing, scheme switches, and performance check against benchmarks.' },
        { icon: '🏦', name: 'Debt & Liquid Funds',  body: 'Capital preservation and short-term parking — Liquid and Ultra Short Duration funds.' }
      ];

  // Schemes
  const schemesLabelV    = def(L.schemesLabel,    'Fund Categories');
  const schemesHeadlineV = def(L.schemesHeadline, 'One goal, the right category.');
  const schemesBodyV     = def(L.schemesBody,     'Every recommendation is mapped to your investment horizon, risk appetite, and financial goal — not to commission rate.');
  const schemesList = (Array.isArray(L.schemes) && L.schemes.length)
    ? L.schemes
    : [
        { icon: '📈', name: 'Equity Funds',  tagline: 'Long-term wealth creation',    body: 'Invests in stocks. Best for goals 5+ years away. Higher risk, higher potential reward.',          riskLevel: 'High',            horizon: '5+ years' },
        { icon: '🛡', name: 'Debt Funds',    tagline: 'Stability and steady income',  body: 'Bonds and corporate paper. Lower volatility — tax-efficient for 1–3 year goals.',               riskLevel: 'Low to Moderate', horizon: '1–3 years' },
        { icon: '⚖',  name: 'Hybrid Funds', tagline: 'Balanced growth and stability', body: 'Pre-set equity-debt mix. Suitable for moderate-risk investors and first-timers.',               riskLevel: 'Moderate',        horizon: '3–5 years' },
        { icon: '🌊', name: 'Liquid Funds',  tagline: 'Park your surplus safely',     body: 'Ultra-short duration. Easy redemption, better than savings account for idle funds.',            riskLevel: 'Low',             horizon: '1 day – 3 months' },
        { icon: '🧾', name: 'ELSS',          tagline: 'Tax saving with equity upside', body: 'Section 80C deduction up to ₹1.5L. Shortest lock-in (3 years) among 80C instruments.',         riskLevel: 'High',            horizon: '3+ years' }
      ];
  const amcPartnersList = (Array.isArray(L.amcPartners) && L.amcPartners.length)
    ? L.amcPartners
    : [{ name: 'Mirae Asset MF' }, { name: 'Axis MF' }, { name: 'Kotak MF' },
       { name: 'HDFC MF' }, { name: 'ICICI Prudential MF' }, { name: 'SBI MF' },
       { name: 'Nippon India MF' }, { name: 'UTI MF' }];

  // Process
  const processLabelV    = def(L.processLabel,    'How It Works');
  const processHeadlineV = def(L.processHeadline, 'From first conversation to first SIP — in days.');
  const processStepsList = (Array.isArray(L.processSteps) && L.processSteps.length)
    ? L.processSteps
    : [
        { icon: '💬', title: 'Goal conversation', body: '30-minute call to understand your income, goals, and risk appetite. No paperwork yet.',      duration: '30 minutes' },
        { icon: '📋', title: 'KYC onboarding',    body: 'PAN + Aadhaar eKYC completed digitally. Already KYC-verified? We skip straight to schemes.', duration: 'Same day' },
        { icon: '🎯', title: 'Scheme selection',  body: 'Portfolio matched to your goals — with full reasoning and disclosed commissions.',              duration: 'Within 24 hours' },
        { icon: '🔄', title: 'Start & review',    body: 'SIP auto-debit activated. Annual review to catch drift before it compounds.',                  duration: 'Ongoing' }
      ];

  // KYC
  const kycLabelV    = def(L.kycLabel,    'KYC Compliance');
  const kycHeadlineV = def(L.kycHeadline, 'KYC-verified investors only. Here\'s why — and how.');
  const kycBodyV     = def(L.kycBody,     'SEBI and AMFI require every mutual fund investor to complete KYC before the first investment. The process is digital, quick, and one-time — once verified, your record is maintained by the CKYC Registry (CERSAI) and shared across all fund houses in India.');
  const kycNoteV     = def(L.kycNote,     'Already KYC-compliant with any SEBI-registered entity? Your CKYC record transfers automatically — no re-verification needed.');
  const kycStepsList = (Array.isArray(L.kycSteps) && L.kycSteps.length)
    ? L.kycSteps
    : [
        { icon: '🪪', title: 'PAN verification',      body: 'Your PAN is the primary identifier linked to your income-tax record.' },
        { icon: '📱', title: 'Aadhaar eKYC',          body: 'OTP-based verification on your phone in 2 minutes. No physical documents needed.' },
        { icon: '📸', title: 'Video KYC (if needed)', body: 'Short 2-minute video call for certain investment amounts.' },
        { icon: '✓',  title: 'CKYC registration',     body: 'KYC lodged on the Central KYC Registry — valid for life across all SEBI-registered entities.' }
      ];

  // About
  const aboutLabelV        = def(L.aboutLabel,        'Our Story');
  const aboutHeadlineLeadV = def(L.aboutHeadlineLead, 'Investing guided by');
  const aboutHeadlineEmphV = def(L.aboutHeadlineEmph, 'honest advice.');
  const aboutBodyV         = def(L.aboutBody || L.about,
    'Founded in ' + founded + ', ' + bn + ' is an AMFI-registered Mutual Fund Distributor holding ' + arnNumberV + '. We operate on a commission-transparent model — every scheme recommendation comes with a clear disclosure of the trail commission we earn. Never pushing a fund because it pays us more.');
  const aboutPillarsList = (Array.isArray(L.aboutPillars) && L.aboutPillars.length)
    ? L.aboutPillars
    : [
        { title: 'Commission Transparency', body: 'We disclose the trail commission on every scheme. You see exactly what we earn — no conflicts, no agenda.' },
        { title: 'Goal-First Advice',       body: 'Every scheme is mapped to a specific goal and horizon. We do not chase AUM targets.' },
        { title: 'Long-Term Partnership',   body: 'Annual reviews, rebalancing calls, and a phone that is answered.' }
      ];
  const ratingsList = (Array.isArray(L.ratings) && L.ratings.length)
    ? L.ratings
    : [
        { label: 'AMFI Registered · ' + arnNumberV },
        { label: 'EUIN: ' + euinNumberV },
        { label: 'SEBI Compliant' },
        { label: 'CKYC Registered' },
        { label: 'CFP Certified' }
      ];

  // Testimonials
  const testimonialsList = (Array.isArray(L.testimonials) && L.testimonials.length)
    ? L.testimonials
    : [
        { quote: 'Started a ₹5,000 SIP in 2016. The annual reviews kept me from stopping during COVID. The corpus exceeded every FD I could have built.', name: 'Ramesh Agarwal', role: 'Jaipur', productUsed: 'Equity SIP · 8-year goal' },
        { quote: 'Vrddhi showed me the trail commission on each fund before recommending anything. That transparency built a trust that made me triple my SIP.',    name: 'Priya Sharma',  role: 'Mumbai', productUsed: 'Multi-fund portfolio' },
        { quote: 'I came asking for an FD alternative. After one call I understood why a debt fund made more sense for my horizon. The decision was mine.',           name: 'Vikram Mehta',  role: 'Pune',   productUsed: 'Debt Fund · 18-month corpus' }
      ];

  // Grievance
  const grievanceLabelV    = def(L.grievanceLabel,    'Investor Care · Grievance Redressal');
  const grievanceHeadlineV = def(L.grievanceHeadline, 'Your complaint gets a real response. Always.');
  const grievanceBodyV     = def(L.grievanceBody,     'As an AMFI-registered distributor, ' + bn + ' maintains a four-tier grievance mechanism. Most concerns are resolved directly. If unresolved, the path escalates to the AMC, then AMFI Investor Services, and finally SEBI SCORES.');
  const groNameV    = def(L.groName,    'Mr. Sanjay Gupta');
  const groRoleV    = def(L.groRole,    'Principal Grievance Officer');
  const groEmailV   = def(L.groEmail,   'grievance@vrddhiwealth.in');
  const groPhoneV   = def(L.groPhone,   '+91 98 XXXX XXXX');
  const groAddressV = def(L.groAddress, bn + '\nJodhpur, Rajasthan 342001');
  const groTimingsV = def(L.groTimings, 'Mon–Sat · 10:00 AM – 6:00 PM IST');
  const escalationLevelsList = (Array.isArray(L.escalationLevels) && L.escalationLevels.length)
    ? L.escalationLevels
    : [
        { level: 'Level 1 · Distributor',            body: 'Contact us directly. Most issues resolved within 3 working days.',                         contact: groPhoneV + ' · ' + groEmailV,              tat: 'Within 3 days' },
        { level: 'Level 2 · AMC Investor Relations',  body: 'If unresolved in 7 days, contact the AMC whose scheme the complaint relates to.',        contact: 'AMC Investor Relations — refer AMC website', tat: 'Within 15 days' },
        { level: 'Level 3 · AMFI Investor Services',  body: 'For distributor complaints not resolved at AMC level, escalate to AMFI.',               contact: 'amfiindia.com/investor-complaint',           tat: 'Within 21 days' },
        { level: 'Level 4 · SEBI SCORES',             body: 'If unresolved after 30 days, register on SEBI\'s official investor grievance portal.',   contact: 'scores.gov.in · 1800-266-7575',              tat: 'As per SEBI norms' }
      ];

  // CTA
  const ctaHeadlineV = def(L.ctaHeadline, 'Start your ₹500 SIP today. Retirement starts now.');
  const ctaBodyV     = def(L.ctaBody,     'A 30-minute conversation, a goal agreed on, and your first SIP running — all within the week. No commitment until you are sure.');
  const ctaButtonV   = def(L.ctaButton,   'Book a Free Call');
  const ctaNoteV     = def(L.ctaNote,     'No charges for consultation · AMFI Registered · ' + arnNumberV);

  // Contact
  const emailV   = esc(L.email)   || 'hello@vrddhiwealth.in';
  const phoneV   = esc(L.phone)   || '+91 98 XXXX XXXX';
  const addressV = esc(L.address) || 'Jodhpur, Rajasthan 342001';
  const hoursV   = esc(L.hours)   || 'Mon–Sat · 10:00 AM – 6:00 PM IST';

  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1, 2);
    return (a + b).toUpperCase();
  }
  function riskColor(level) {
    if (!level) return accent;
    const l = level.toLowerCase();
    if (l.includes('very high') || l.includes('high')) return '#b91c1c';
    if (l.includes('moderately high')) return '#c2700d';
    if (l.includes('moderate')) return '#b8882e';
    if (l.includes('low to')) return '#2d6a4f';
    return '#1c6b3a';
  }
