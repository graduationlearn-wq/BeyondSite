  <script>
    // NAV
    const nav=document.getElementById('nav');
    window.addEventListener('scroll',()=>nav.classList.toggle('elevated',window.scrollY>20),{passive:true});

    // REVEAL
    const ro=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');ro.unobserve(x.target);}});},{threshold:.07,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

    // PRICING TOGGLE
    document.querySelectorAll('.ptog-opt').forEach(opt=>{
      opt.addEventListener('click',()=>{
        document.querySelectorAll('.ptog-opt').forEach(o=>o.classList.remove('active'));
        opt.classList.add('active');
      });
    });

    // LOGO SCROLL
    const lt=document.getElementById('logotrack');
    if(lt){lt.addEventListener('mouseenter',()=>lt.style.animationPlayState='paused');lt.addEventListener('mouseleave',()=>lt.style.animationPlayState='running');}

    // SMOOTH SCROLL
    document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{const t=document.querySelector(a.getAttribute('href'));if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}});});

    // CONTACT FORM
    const f=document.querySelector('[data-contact]');
    if(f){f.addEventListener('submit',e=>{
      e.preventDefault();
      const b=f.querySelector('.form-submit');b.textContent='Creating workspace…';b.disabled=true;
      setTimeout(()=>{
        const n=document.createElement('div');
        n.style.cssText='background:rgba(22,163,74,.07);border:1px solid rgba(22,163,74,.25);color:#16a34a;padding:14px 18px;border-radius:10px;font-size:.87rem;margin-bottom:14px;line-height:1.6;';
        n.innerHTML='✓ <strong>You\'re in!</strong> Check your email — we\'ve sent your workspace link.';
        f.insertAdjacentElement('beforebegin',n);f.reset();
        b.textContent='Start free trial →';b.disabled=false;
        setTimeout(()=>n.remove(),7000);
      },900);
    });}
  </script>
</body>
</html>