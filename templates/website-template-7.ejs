  <!-- CONTACT -->
  <section id="contact" class="contact spad z1">
    <div class="ctn">
      <div class="contact-inner">
        <div class="contact-left reveal">
          <div class="eyebrow">Get In Touch</div>
          <h2 class="sec-title">Let's find the<br>right plan for you.</h2>
          <p class="contact-desc">Whether you're a solo founder or scaling a 500-person org — we have a plan that fits. Talk to us and we'll figure it out together.</p>
          <div class="contact-perks">
            <div class="cperk"><div class="cperk-icon">⚡</div>Reply within 2 hours on business days</div>
            <div class="cperk"><div class="cperk-icon">🎯</div>Free personalised onboarding call</div>
            <div class="cperk"><div class="cperk-icon">🔒</div>Your data stays yours — always</div>
            <div class="cperk"><div class="cperk-icon">🧾</div>Migration help from your current tool</div>
          </div>
        </div>
        <div class="reveal rd1">
          <div class="contact-form">
            <h3 class="form-title">Start your free trial</h3>
            <p class="form-sub">14 days free. No credit card required.</p>
            <form data-contact>
              <div class="fg2">
                <div class="fg"><label>First Name</label><input type="text" placeholder="Kavya" required></div>
                <div class="fg"><label>Last Name</label><input type="text" placeholder="Menon" required></div>
              </div>
              <div class="fg"><label>Work Email</label><input type="email" placeholder="kavya@company.io" required></div>
              <div class="fg"><label>Company Name</label><input type="text" placeholder="Acme Inc."></div>
              <div class="fg">
                <label>Team Size</label>
                <select>
                  <option value="" disabled selected>Select team size</option>
                  <option>Just me</option>
                  <option>2–10</option>
                  <option>11–50</option>
                  <option>51–200</option>
                  <option>200+</option>
                </select>
              </div>
              <div class="fg"><label>What are you trying to solve?</label><textarea placeholder="Tell us about your current challenges and what you're hoping to achieve..."></textarea></div>
              <button type="submit" class="form-submit">Start free trial →</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
