  <!-- CTA BAND -->
  <div class="ctaband z1 reveal">
    <div class="cta-inner">
      <div class="cta-badge">✦ Join 10,000+ teams worldwide</div>
      <h2 class="cta-title">Your team deserves<br>better tools.</h2>
      <p class="cta-sub">Start free. No credit card. No sales calls. Just a faster, cleaner way to work.</p>
      <div class="cta-actions">
        <a href="#contact" class="btn-primary">Start for free →</a>
        <a href="#pricing" class="btn-secondary" style="background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.15);color:rgba(255,255,255,.75)">View pricing</a>
