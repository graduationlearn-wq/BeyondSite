<%
  // ── Read schema values from locals to avoid TDZ / undefined-ref errors ──
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);

  const bn     = esc(L.businessName) || 'Your Local Experts';
  const tag    = esc(L.tagline) || 'Quality work. Honest prices. Right in your neighborhood.';
  const year   = esc(L.foundedYear) || new Date().getFullYear();
  const accent = L.primaryColor || '#c4622d';

  const heroEyebrowV      = def(L.heroEyebrow, `Trusted locally since ${year}`);
  const heroHeadlineV     = def(L.heroHeadline, `Reliable ${bn.toLowerCase()}, done right the first time.`);
  const heroSubV          = def(L.heroSub, `We serve your neighborhood with quality craftsmanship, transparent pricing, and friendly service. Licensed, insured, and ready when you need us.`);
  const heroCtaPrimaryV   = def(L.heroCtaPrimary, 'Get a Free Quote');
  const heroCtaSecondaryV = def(L.heroCtaSecondary, 'Call Now');
  const heroQuoteCardTitleV = def(L.heroQuoteCardTitle, 'Licensed. Insured. Local.');
  const heroQuoteCardBodyV  = def(L.heroQuoteCardBody, 'Every job backed by a written guarantee. No surprise fees. Real people answering the phone.');

  const aboutHeadlineV = def(L.aboutHeadline, `Your neighborhood's trusted team`);
  const aboutBodyV     = def(L.aboutBody, `We're a family-run local business built on repeat customers and word-of-mouth referrals. For years we've served this community with the same promise: show up on time, do the work right, and stand behind it. Our team is fully licensed and insured, and we treat every home like our own.`);
  const emergencyLineV = esc(L.emergencyLine);

  const defaultServices = [
    { icon: '🔧', name: 'Repairs',     body: 'Fast, reliable repair work with parts in stock.', price: '' },
    { icon: '🏠', name: 'Installation',body: 'Clean installations done to code the first time.', price: '' },
    { icon: '🛠', name: 'Maintenance', body: 'Routine maintenance to keep things running.',      price: '' },
    { icon: '⚡', name: 'Emergency',   body: '24/7 emergency response when you need us fast.',   price: '' }
  ];
  const svc = Array.isArray(L.services) && L.services.length ? L.services : defaultServices;

  const trust = Array.isArray(L.trustItems) && L.trustItems.length ? L.trustItems
    : [{ label: 'Licensed & Insured' },{ label: '5-Star Google Reviews' },{ label: 'Free Estimates' },{ label: 'Locally Owned' }];

  const statList = Array.isArray(L.stats) && L.stats.length ? L.stats : [
    { value: '10+',  label: 'Years serving the area' },
    { value: '2500', label: 'Jobs completed' },
    { value: '4.9★', label: 'Average Google rating' },
    { value: '24/7', label: 'Emergency response' }
  ];

  const areas      = Array.isArray(L.areasServed)  ? L.areasServed  : [];
  const hoursBlock = Array.isArray(L.hoursList)    ? L.hoursList    : [];
  const reviews    = Array.isArray(L.testimonials) ? L.testimonials : [];
  const faqItems   = Array.isArray(L.faqs)         ? L.faqs         : [];

  const primaryEmail = esc(L.email) || 'hello@example.com';
  const primaryPhone = esc(L.phone) || '(555) 123-4567';
  const addressBlock = esc(L.address);
  const hoursText    = esc(L.hours) || 'Mon–Fri · 9am–6pm';
  const logoV        = esc(L.logo);
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= bn %> | Local Experts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --cream:#faf7f2;--cream-dark:#f2ece0;
      --navy:#1a2332;--navy-deep:#111b27;
      --terra:<%= accent %>;--terra-lt:#d4774a;
      --amber:#d4a053;
      --border:rgba(26,35,50,.1);
      --text:#1a2332;--muted:rgba(26,35,50,.62);--dim:rgba(26,35,50,.38);
      --white:#fff;
      --serif:'Playfair Display',Georgia,serif;
      --sans:'DM Sans',system-ui,sans-serif;
      --radius:4px;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--cream);color:var(--text);line-height:1.65;overflow-x:hidden;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .wrap{max-width:1180px;margin:0 auto;padding:0 32px}
    .eyebrow{display:inline-block;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--terra)}

    /* ── TOPBAR ─── */
    .topbar{background:var(--navy);padding:10px 32px;display:flex;align-items:center;justify-content:space-between;gap:16px;color:rgba(255,255,255,.75);font-size:.78rem}
    .topbar-left{display:flex;gap:22px;flex-wrap:wrap}
    .topbar-item{display:flex;align-items:center;gap:8px;letter-spacing:.03em}
    .topbar-item .dot{width:6px;height:6px;border-radius:50%;background:var(--amber);animation:pulse 2.2s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.5)}}
    .topbar-cta{color:var(--amber);font-weight:600;letter-spacing:.04em;border-bottom:1px solid rgba(212,160,83,.45)}

    /* ── NAV ─── */
    .nav{position:sticky;top:0;z-index:500;background:var(--white);border-bottom:1px solid var(--border);padding:0 32px;height:72px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 1px 16px rgba(26,35,50,.06)}
    .nav-logo{font-family:var(--serif);font-size:1.45rem;font-weight:700;color:var(--navy)}
    .nav-logo span{color:var(--terra)}
    .nav-logo img{height:34px}
    .nav-book{display:inline-flex;align-items:center;gap:8px;background:var(--terra);color:#fff;padding:11px 22px;font-weight:600;font-size:.85rem;border-radius:var(--radius);letter-spacing:.02em}

    /* ── HERO ─── */
    .hero{padding:90px 0 110px;position:relative;overflow:hidden}
    .hero::before{content:"";position:absolute;inset:0;background:radial-gradient(900px 500px at 90% 10%,rgba(196,98,45,.08),transparent 60%);pointer-events:none}
    .hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:64px;align-items:center;position:relative}
    .hero h1{font-family:var(--serif);font-size:clamp(2.4rem,4.6vw,4rem);line-height:1.05;letter-spacing:-.02em;color:var(--navy);font-weight:700;margin:18px 0 22px}
    .hero h1 em{font-style:italic;color:var(--terra)}
    .hero-sub{font-size:1.1rem;color:var(--muted);max-width:540px;margin-bottom:34px}
    .hero-ctas{display:flex;gap:14px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:var(--radius);font-weight:600;font-size:.94rem;letter-spacing:.01em;cursor:pointer;border:0}
    .btn-primary{background:var(--terra);color:#fff}
    .btn-ghost{background:transparent;color:var(--navy);border:1.5px solid var(--navy)}
    .hero-badges{display:flex;gap:10px;flex-wrap:wrap;margin-top:38px}
    .hero-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(26,35,50,.05);border-radius:20px;font-size:.78rem;color:var(--muted)}
    .hero-badge::before{content:"✓";color:var(--terra);font-weight:700}

    .quote-card{background:#fff;border-radius:10px;padding:36px;box-shadow:0 18px 60px rgba(26,35,50,.08);border:1px solid var(--border);position:relative}
    .quote-card::before{content:"";position:absolute;top:-12px;left:36px;width:24px;height:24px;background:var(--terra);border-radius:2px;transform:rotate(45deg)}
    .quote-card h3{font-family:var(--serif);font-size:1.6rem;color:var(--navy);margin-bottom:12px}
    .quote-card p{color:var(--muted);font-size:.98rem}
    .quote-card-foot{margin-top:24px;padding-top:20px;border-top:1px dashed var(--border);display:flex;gap:14px;align-items:center;font-size:.84rem;color:var(--muted)}
    .quote-card-foot .dot{width:10px;height:10px;border-radius:50%;background:#22c55e;box-shadow:0 0 0 4px rgba(34,197,94,.18)}

    /* ── TRUST STRIP ─── */
    .trust-strip{background:var(--navy);color:#fff;padding:22px 0}
    .trust-strip-grid{display:flex;justify-content:space-around;gap:24px;flex-wrap:wrap;font-size:.86rem;letter-spacing:.03em}
    .trust-strip-item{display:flex;align-items:center;gap:10px;opacity:.85}
    .trust-strip-item::before{content:"◆";color:var(--amber)}

    /* ── SECTIONS ─── */
    section{padding:86px 0}
    .section-head{text-align:center;margin-bottom:56px}
    .section-head h2{font-family:var(--serif);font-size:clamp(2rem,3.2vw,2.8rem);color:var(--navy);line-height:1.15;margin-top:10px}

    /* ── SERVICES ─── */
    .services{background:var(--cream-dark)}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:22px}
    .svc{background:#fff;padding:32px 28px;border-radius:6px;border:1px solid var(--border);transition:transform .25s,border-color .25s;display:flex;flex-direction:column;gap:10px}
    .svc:hover{transform:translateY(-4px);border-color:var(--terra)}
    .svc-icon{font-size:1.9rem;margin-bottom:4px}
    .svc h3{font-family:var(--serif);font-size:1.35rem;color:var(--navy)}
    .svc p{color:var(--muted);font-size:.95rem}
    .svc-price{margin-top:auto;padding-top:14px;font-weight:600;color:var(--terra);font-size:.92rem}

    /* ── NUMBERS ─── */
    .numbers{background:var(--navy);color:#fff;padding:70px 0}
    .numbers-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:30px;text-align:center}
    .num-v{font-family:var(--serif);font-size:clamp(2.4rem,4vw,3.5rem);font-weight:700;color:var(--amber);line-height:1}
    .num-l{margin-top:8px;font-size:.88rem;letter-spacing:.04em;color:rgba(255,255,255,.7);text-transform:uppercase}

    /* ── ABOUT / HOURS ─── */
    .about-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:56px;align-items:start}
    .about h2{font-family:var(--serif);font-size:clamp(1.9rem,3vw,2.6rem);color:var(--navy);line-height:1.15;margin:14px 0 22px}
    .about p{color:var(--muted);margin-bottom:18px}
    .hours-card{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:28px;box-shadow:0 10px 30px rgba(26,35,50,.04)}
    .hours-card h3{font-family:var(--serif);font-size:1.25rem;color:var(--navy);margin-bottom:14px}
    .hours-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px dashed var(--border);font-size:.92rem}
    .hours-row:last-child{border-bottom:0}
    .hours-row .day{color:var(--navy);font-weight:500}
    .hours-row .time{color:var(--muted)}
    .hours-row .closed{color:#c1432d;font-weight:600}
    .emergency{margin-top:20px;padding:16px 18px;background:rgba(196,98,45,.08);border-left:4px solid var(--terra);border-radius:4px;font-size:.9rem;color:var(--navy)}
    .areas{margin-top:26px}
    .area-tag{display:inline-block;background:var(--cream-dark);color:var(--navy);padding:6px 14px;border-radius:20px;font-size:.78rem;margin:4px 5px 0 0}

    /* ── REVIEWS ─── */
    .reviews{background:var(--cream-dark)}
    .reviews-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px}
    .review{background:#fff;border:1px solid var(--border);border-radius:6px;padding:28px;position:relative}
    .review::before{content:"\201C";font-family:var(--serif);font-size:4rem;color:var(--terra);position:absolute;top:-8px;left:18px;line-height:1}
    .review p{color:var(--text);font-size:.98rem;margin:10px 0 20px}
    .review-meta{display:flex;flex-direction:column;gap:2px;font-size:.85rem;color:var(--muted)}
    .review-meta strong{color:var(--navy);font-weight:600;font-size:.95rem}

    /* ── FAQ ─── */
    .faq-list{max-width:820px;margin:0 auto;border-top:1px solid var(--border)}
    details{border-bottom:1px solid var(--border);padding:22px 0}
    details summary{cursor:pointer;list-style:none;font-family:var(--serif);font-size:1.2rem;color:var(--navy);display:flex;justify-content:space-between;align-items:center}
    details summary::-webkit-details-marker{display:none}
    details summary::after{content:"+";font-size:1.6rem;color:var(--terra);transition:transform .25s}
    details[open] summary::after{transform:rotate(45deg)}
    details p{color:var(--muted);margin-top:14px;font-size:.98rem}

    /* ── CONTACT / FOOTER ─── */
    .contact{background:var(--navy);color:#fff}
    .contact h2{color:#fff}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:54px;align-items:start}
    .contact-info p{color:rgba(255,255,255,.7);margin-bottom:12px;display:flex;gap:10px;align-items:center}
    .contact-info strong{color:var(--amber)}
    form.contact-form{background:rgba(255,255,255,.04);padding:28px;border-radius:8px;border:1px solid rgba(255,255,255,.08)}
    form.contact-form label{display:block;font-size:.8rem;color:rgba(255,255,255,.6);margin-bottom:6px;letter-spacing:.04em}
    form.contact-form input,form.contact-form textarea{width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#fff;padding:11px 14px;font-family:inherit;border-radius:4px;margin-bottom:14px;font-size:.94rem}
    form.contact-form button{background:var(--terra);color:#fff;border:0;padding:12px 26px;border-radius:4px;font-weight:600;cursor:pointer}

    footer{background:var(--navy-deep);color:rgba(255,255,255,.55);padding:28px 0;text-align:center;font-size:.82rem;letter-spacing:.03em}

    @media (max-width:900px){
      .hero-grid,.about-grid,.contact-grid{grid-template-columns:1fr;gap:40px}
      .nav{padding:0 18px}.topbar{padding:10px 18px}.wrap{padding:0 18px}
      section{padding:60px 0}
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <span class="topbar-item"><span class="dot"></span><%= hoursText %></span>
    <% if (primaryPhone) { %><span class="topbar-item">📞 <%= primaryPhone %></span><% } %>
  </div>
  <a class="topbar-cta" href="#contact"><%= heroCtaPrimaryV %> →</a>
</div>

<nav class="nav">
  <a href="#" class="nav-logo">
    <% if (logoV) { %><img src="<%= logoV %>" alt="<%= bn %>">
    <% } else { %><%= bn.split(' ')[0] %><% if (bn.split(' ').length > 1) { %><span> <%= bn.split(' ').slice(1).join(' ') %></span><% } %>
    <% } %>
  </a>
  <a class="nav-book" href="#contact"><%= heroCtaPrimaryV %></a>
</nav>

<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow"><%= heroEyebrowV %></span>
      <h1><%- heroHeadlineV %></h1>
      <p class="hero-sub"><%= heroSubV %></p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary"><%= heroCtaPrimaryV %> →</a>
        <% if (primaryPhone) { %><a href="tel:<%= primaryPhone %>" class="btn btn-ghost">📞 <%= heroCtaSecondaryV %></a><% } %>
      </div>
      <% if (trust.length) { %>
      <div class="hero-badges">
        <% trust.slice(0,4).forEach(t => { %><span class="hero-badge"><%= t.label %></span><% }) %>
      </div>
      <% } %>
    </div>
    <aside class="quote-card">
      <h3><%= heroQuoteCardTitleV %></h3>
      <p><%= heroQuoteCardBodyV %></p>
      <div class="quote-card-foot"><span class="dot"></span> Usually responds within 1 hour</div>
    </aside>
  </div>
</section>

<% if (trust.length) { %>
<div class="trust-strip">
  <div class="wrap trust-strip-grid">
    <% trust.forEach(t => { %><span class="trust-strip-item"><%= t.label %></span><% }) %>
  </div>
</div>
<% } %>

<% if (svc.length) { %>
<section class="services" id="services">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">What we do</span>
      <h2>Services we offer</h2>
    </div>
    <div class="services-grid">
      <% svc.forEach(s => { %>
      <article class="svc">
        <% if (s.icon) { %><div class="svc-icon"><%= s.icon %></div><% } %>
        <h3><%= s.name %></h3>
        <p><%= s.body %></p>
        <% if (s.price) { %><div class="svc-price"><%= s.price %></div><% } %>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (statList.length) { %>
<section class="numbers">
  <div class="wrap numbers-grid">
    <% statList.forEach(s => { %>
    <div>
      <div class="num-v"><%= s.value %></div>
      <div class="num-l"><%= s.label %></div>
    </div>
    <% }) %>
  </div>
</section>
<% } %>

<section class="about" id="about">
  <div class="wrap about-grid">
    <div>
      <span class="eyebrow">About us</span>
      <h2><%= aboutHeadlineV %></h2>
      <p><%= aboutBodyV %></p>
      <% if (emergencyLineV) { %><div class="emergency">🚨 <%= emergencyLineV %></div><% } %>
      <% if (areas.length) { %>
        <div class="areas">
          <strong style="font-size:.85rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;">Areas we serve</strong><br>
          <% areas.forEach(a => { %><span class="area-tag"><%= a.name %></span><% }) %>
        </div>
      <% } %>
    </div>
    <div class="hours-card">
      <h3>Business Hours</h3>
      <% if (hoursBlock.length) { %>
        <% hoursBlock.forEach(h => { %>
          <div class="hours-row">
            <span class="day"><%= h.day %></span>
            <% if (h.closed === 'Yes') { %><span class="closed">Closed</span>
            <% } else { %><span class="time"><%= h.open %> – <%= h.close %></span><% } %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="hours-row"><span class="day"><%= hoursText %></span></div>
      <% } %>
    </div>
  </div>
</section>

<% if (reviews.length) { %>
<section class="reviews">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Reviews</span>
      <h2>What our customers say</h2>
    </div>
    <div class="reviews-grid">
      <% reviews.forEach(r => { %>
      <div class="review">
        <p><%= r.quote %></p>
        <div class="review-meta">
          <strong><%= r.name %></strong>
          <% if (r.role) { %><span><%= r.role %></span><% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (faqItems.length) { %>
<section>
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">FAQ</span>
      <h2>Questions, answered</h2>
    </div>
    <div class="faq-list">
      <% faqItems.forEach(f => { %>
        <details>
          <summary><%= f.q %></summary>
          <p><%= f.a %></p>
        </details>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="contact" id="contact">
  <div class="wrap contact-grid">
    <div>
      <span class="eyebrow">Get in touch</span>
      <h2 style="font-family:var(--serif);font-size:clamp(1.9rem,3vw,2.6rem);margin-top:10px;">Let's take care of it, together.</h2>
      <div class="contact-info" style="margin-top:24px">
        <% if (primaryPhone) { %><p><strong>Call:</strong> <%= primaryPhone %></p><% } %>
        <% if (primaryEmail) { %><p><strong>Email:</strong> <%= primaryEmail %></p><% } %>
        <% if (addressBlock) { %><p><strong>Visit:</strong> <%= addressBlock %></p><% } %>
        <% if (hoursText) { %><p><strong>Hours:</strong> <%= hoursText %></p><% } %>
      </div>
    </div>
    <form class="contact-form" onsubmit="event.preventDefault(); this.reset(); alert('Thanks — we\'ll be in touch.');">
      <label>Name</label><input type="text" required>
      <label>Phone</label><input type="tel">
      <label>Email</label><input type="email" required>
      <label>What do you need?</label><textarea rows="3"></textarea>
      <button type="submit"><%= heroCtaPrimaryV %></button>
    </form>
  </div>
</section>

<footer>© <%= year %> <%= bn %> · Licensed & Insured · All rights reserved</footer>

</body>
</html>
