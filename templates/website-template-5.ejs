<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= businessName %> | Local Experts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream:       #faf7f2;
      --cream-dark:  #f2ece0;
      --navy:        #1a2332;
      --navy-deep:   #111b27;
      --navy-mid:    #243044;
      --terra:       #c4622d;
      --terra-lt:    #d4774a;
      --terra-glow:  rgba(196,98,45,.15);
      --amber:       #d4a053;
      --amber-lt:    #e5b56a;
      --border:      rgba(26,35,50,.1);
      --border-md:   rgba(26,35,50,.18);
      --text:        #1a2332;
      --muted:       rgba(26,35,50,.6);
      --dim:         rgba(26,35,50,.38);
      --white:       #ffffff;
      --serif:       'Playfair Display', Georgia, serif;
      --sans:        'DM Sans', system-ui, sans-serif;
      --radius:      4px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--text);
      line-height: 1.65;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── TOPBAR ─── */
    .topbar {
      background: var(--navy);
      padding: 10px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .topbar-left {
      display: flex; align-items: center; gap: 24px;
    }
    .topbar-item {
      display: flex; align-items: center; gap: 7px;
      font-size: .75rem;
      color: rgba(255,255,255,.7);
      letter-spacing: .03em;
    }
    .topbar-item .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--amber);
      animation: pulse 2.2s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.5)} }
    .topbar-cta {
      font-size: .73rem;
      font-weight: 600;
      color: var(--amber);
      text-decoration: none;
      letter-spacing: .04em;
      border-bottom: 1px solid rgba(212,160,83,.4);
      transition: border-color .2s;
    }
    .topbar-cta:hover { border-color: var(--amber); }

    /* ── NAVIGATION ─── */
    .nav {
      position: sticky; top: 0;
      z-index: 500;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 48px;
      height: 72px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 1px 16px rgba(26,35,50,.06);
    }
    .nav-logo {
      font-family: var(--serif);
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--navy);
      text-decoration: none;
      letter-spacing: -.01em;
    }
    .nav-logo span { color: var(--terra); }
    .nav-links {
      display: flex; gap: 32px;
      list-style: none; align-items: center;
    }
    .nav-links a {
      font-size: .85rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-book {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--terra);
      color: var(--white) !important;
      padding: 11px 26px;
      font-weight: 600 !important;
      font-size: .82rem !important;
      border-radius: var(--radius);
      transition: background .2s, box-shadow .2s !important;
    }
    .nav-book:hover { background: var(--terra-lt) !important; box-shadow: 0 4px 20px var(--terra-glow); }

    /* ── HERO ─── */
    .hero {
      background: var(--cream);
      padding: 88px 48px 80px;
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 80px;
      align-items: center;
      max-width: 1240px;
      margin: 0 auto;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--terra);
      margin-bottom: 24px;
    }
    .hero-eyebrow::before {
      content: '';
      width: 36px; height: 2px;
      background: var(--terra);
      border-radius: 2px;
    }
    .hero-headline {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 5.5vw, 5rem);
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -.02em;
      color: var(--navy);
      margin-bottom: 24px;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--terra);
    }
    .hero-sub {
      font-size: 1.05rem;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.8;
      max-width: 500px;
      margin-bottom: 40px;
    }
    .hero-actions {
      display: flex; gap: 14px; align-items: center;
      margin-bottom: 48px;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--terra);
      color: var(--white);
      padding: 16px 36px;
      font-size: .88rem;
      font-weight: 600;
      border-radius: var(--radius);
      text-decoration: none;
      transition: background .2s, box-shadow .2s, transform .15s;
      border: none; cursor: pointer;
    }
    .btn-primary:hover { background: var(--terra-lt); box-shadow: 0 6px 28px var(--terra-glow); transform: translateY(-2px); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      color: var(--navy);
      padding: 15px 28px;
      font-size: .88rem;
      font-weight: 500;
      border-radius: var(--radius);
      border: 1.5px solid var(--border-md);
      text-decoration: none;
      transition: border-color .2s, color .2s;
    }
    .btn-outline:hover { border-color: var(--navy); color: var(--navy); }

    .hero-trust {
      display: flex; gap: 32px; align-items: center;
    }
    .trust-item {
      display: flex; align-items: center; gap: 10px;
      font-size: .8rem;
      color: var(--muted);
      font-weight: 400;
    }
    .trust-icon {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: var(--cream-dark);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    /* Hero visual */
    .hero-visual { position: relative; padding: 20px 28px 48px 24px;}
    .hero-card {
      background: var(--navy);
      border-radius: 12px;
      aspect-ratio: 4/4.5;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .hero-card-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 20%, rgba(196,98,45,.25) 0%, transparent 60%),
        radial-gradient(ellipse 60% 80% at 80% 80%, rgba(212,160,83,.15) 0%, transparent 60%);
    }
    .hero-card-initial {
      font-family: var(--serif);
      font-size: 9rem;
      font-weight: 900;
      color: rgba(255,255,255,.08);
      line-height: 1;
      position: relative; z-index: 1;
      user-select: none;
    }
    .hero-card-badge {
      position: absolute; z-index: 2;
      background: var(--white);
      border-radius: 10px;
      padding: 14px 18px;
      box-shadow: 0 8px 32px rgba(0,0,0,.2);
    }
    .hero-card-badge.top-right { top: 24px; right: -20px; }
    .hero-card-badge.bottom-left { bottom: 40px; left: -20px; }
    .badge-num {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--navy);
      line-height: 1;
    }
    .badge-label {
      font-size: .68rem;
      font-weight: 500;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-top: 2px;
    }
    .hero-card-review {
      position: absolute; z-index: 2;
      background: var(--white);
      border-radius: 10px;
      padding: 12px 16px;
      box-shadow: 0 8px 32px rgba(0,0,0,.2);
      bottom: -20px; right: 24px;
      display: flex; align-items: center; gap: 10px;
    }
    .review-stars { color: var(--amber); font-size: .9rem; }
    .review-text { font-size: .75rem; color: var(--muted); line-height: 1.4; }
    .review-text strong { display: block; color: var(--navy); font-weight: 600; }

    /* ── SECTION GLOBALS ─── */
    section { position: relative; }
    .container { max-width: 1240px; margin: 0 auto; padding: 0 48px; }
    .section-pad { padding: 100px 0; }
    .section-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: .7rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--terra);
      margin-bottom: 16px;
    }
    .section-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: -.02em;
      color: var(--navy);
    }
    .section-title em { font-style: italic; color: var(--terra); }
    .reveal {
      opacity: 0; transform: translateY(32px);
      transition: opacity .75s ease, transform .75s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }

    /* ── TRUST STRIP ─── */
    .trust-strip {
      background: var(--navy);
      padding: 28px 48px;
    }
    .trust-strip-inner {
      max-width: 1240px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
      flex-wrap: wrap;
    }
    .strip-item {
      display: flex; align-items: center; gap: 12px;
      font-size: .82rem;
      color: rgba(255,255,255,.75);
      font-weight: 400;
    }
    .strip-icon {
      font-size: 1.3rem;
      flex-shrink: 0;
    }
    .strip-item strong { display: block; color: var(--white); font-weight: 600; font-size: .85rem; }
    .strip-divider { width: 1px; height: 36px; background: rgba(255,255,255,.12); }

    /* ── SERVICES ─── */
    .services { background: var(--cream-dark); }
    .services-header { text-align: center; margin-bottom: 60px; }
    .services-header .section-title { margin-bottom: 14px; }
    .services-meta { font-size: .95rem; color: var(--muted); font-weight: 300; max-width: 480px; margin: 0 auto; line-height: 1.75; }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
    }
    .service-card {
      background: var(--white);
      border-radius: 10px;
      padding: 40px 32px;
      border: 1px solid var(--border);
      transition: transform .3s, box-shadow .3s, border-color .3s;
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--terra), var(--amber));
      transform: scaleX(0); transform-origin: left;
      transition: transform .35s ease;
    }
    .service-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(26,35,50,.1); border-color: transparent; }
    .service-card:hover::before { transform: scaleX(1); }
    .service-icon {
      width: 52px; height: 52px;
      background: rgba(196,98,45,.1);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 20px;
    }
    .service-name {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 12px;
    }
    .service-desc {
      font-size: .88rem;
      color: var(--muted);
      line-height: 1.75;
      font-weight: 300;
      margin-bottom: 20px;
    }
    .service-link {
      font-size: .82rem;
      font-weight: 600;
      color: var(--terra);
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 6px;
      transition: gap .2s;
    }
    .service-link:hover { gap: 10px; }

    /* ── ABOUT ─── */
    .about { background: var(--cream); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .about-left .section-title { margin-bottom: 20px; }
    .about-body {
      font-size: .95rem;
      color: var(--muted);
      line-height: 1.85;
      font-weight: 300;
      margin-bottom: 28px;
    }
    .checklist { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
    .checklist li {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: .9rem;
      color: var(--text);
      font-weight: 400;
    }
    .check-icon {
      width: 22px; height: 22px;
      border-radius: 50%;
      background: rgba(196,98,45,.12);
      display: flex; align-items: center; justify-content: center;
      color: var(--terra);
      font-size: .7rem;
      flex-shrink: 0;
      margin-top: 2px;
      font-weight: 700;
    }

    .about-right { display: flex; flex-direction: column; gap: 20px; }
    .hours-card {
      background: var(--navy);
      border-radius: 12px;
      padding: 36px 32px;
      color: var(--white);
    }
    .hours-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 24px;
      display: flex; align-items: center; gap: 10px;
    }
    .hours-title .dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; animation: pulse 2s ease-in-out infinite; }
    .hours-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
    .hours-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
      font-size: .88rem;
    }
    .hours-row:last-child { border-bottom: none; }
    .hours-day { color: rgba(255,255,255,.65); font-weight: 300; }
    .hours-time { color: var(--white); font-weight: 500; }
    .hours-time.closed { color: rgba(255,255,255,.35); }

    .emergency-card {
      background: var(--terra);
      border-radius: 12px;
      padding: 28px 32px;
      display: flex; align-items: center; gap: 16px;
    }
    .emergency-icon { font-size: 2rem; flex-shrink: 0; }
    .emergency-title { font-family: var(--serif); font-size: 1.1rem; font-weight: 700; color: var(--white); margin-bottom: 4px; }
    .emergency-sub { font-size: .82rem; color: rgba(255,255,255,.8); font-weight: 300; }

    .area-card {
      background: var(--cream-dark);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 28px 32px;
    }
    .area-title {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 14px;
      display: flex; align-items: center; gap: 8px;
    }
    .area-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .area-tag {
      background: var(--white);
      border: 1px solid var(--border-md);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: .78rem;
      font-weight: 500;
      color: var(--muted);
    }

    /* ── NUMBERS ─── */
    .numbers { background: var(--terra); padding: 80px 0; }
    .numbers-inner {
      max-width: 1240px; margin: 0 auto; padding: 0 48px;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.12);
    }
    .num-item {
      background: var(--terra);
      padding: 56px 40px;
      text-align: center;
    }
    .num-val {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 5vw, 4rem);
      font-weight: 900;
      color: var(--white);
      line-height: 1;
      margin-bottom: 8px;
    }
    .num-label {
      font-size: .8rem;
      font-weight: 500;
      color: rgba(255,255,255,.75);
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    /* ── TESTIMONIALS ─── */
    .testimonials { background: var(--cream-dark); }
    .testi-header { text-align: center; margin-bottom: 60px; }
    .testi-header .section-title { margin-bottom: 14px; }
    .testi-intro { font-size: .95rem; color: var(--muted); font-weight: 300; max-width: 440px; margin: 0 auto; }
    .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
    .testi-card {
      background: var(--white);
      border-radius: 10px;
      padding: 36px 30px;
      border: 1px solid var(--border);
      transition: transform .3s, box-shadow .3s;
    }
    .testi-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(26,35,50,.08); }
    .testi-stars { color: var(--amber); font-size: .9rem; letter-spacing: 2px; margin-bottom: 16px; }
    .testi-quote {
      font-family: var(--serif);
      font-size: 1rem;
      font-style: italic;
      color: var(--text);
      line-height: 1.75;
      margin-bottom: 24px;
    }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--terra), var(--amber));
      display: flex; align-items: center; justify-content: center;
      font-size: .78rem;
      font-weight: 700;
      color: var(--white);
      flex-shrink: 0;
    }
    .testi-name { font-weight: 600; font-size: .88rem; color: var(--navy); display: block; }
    .testi-role { font-size: .78rem; color: var(--muted); display: block; margin-top: 2px; }
    .testi-source { text-align: center; font-size: .8rem; color: var(--muted); }
    .testi-source strong { color: var(--terra); font-weight: 600; }

    /* ── FAQ ─── */
    .faq { background: var(--cream); }
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .faq-left .section-title { margin-bottom: 14px; }
    .faq-left .section-sub { font-size: .95rem; color: var(--muted); font-weight: 300; line-height: 1.8; margin-bottom: 32px; }
    .faq-cta-box {
      background: var(--navy);
      border-radius: 10px;
      padding: 32px 28px;
    }
    .faq-cta-title {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
    }
    .faq-cta-sub { font-size: .85rem; color: rgba(255,255,255,.65); font-weight: 300; margin-bottom: 20px; line-height: 1.7; }
    .faq-list { display: flex; flex-direction: column; gap: 0; }
    .faq-item {
      border-bottom: 1px solid var(--border);
    }
    .faq-question {
      width: 100%;
      background: none; border: none; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
      padding: 22px 0;
      font-family: var(--sans);
      font-size: .95rem;
      font-weight: 600;
      color: var(--navy);
      text-align: left;
      gap: 16px;
    }
    .faq-arrow {
      width: 24px; height: 24px;
      border-radius: 50%;
      border: 1.5px solid var(--border-md);
      display: flex; align-items: center; justify-content: center;
      font-size: .75rem;
      color: var(--terra);
      flex-shrink: 0;
      transition: transform .3s, background .2s;
    }
    .faq-item.open .faq-arrow { transform: rotate(180deg); background: var(--terra); color: var(--white); border-color: var(--terra); }
    .faq-answer {
      max-height: 0; overflow: hidden;
      transition: max-height .4s ease;
    }
    .faq-answer-inner {
      font-size: .9rem;
      color: var(--muted);
      line-height: 1.8;
      font-weight: 300;
      padding-bottom: 20px;
    }

    /* ── CONTACT ─── */
    .contact { background: var(--navy); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1.3fr; gap: 80px; align-items: start; }
    .contact-left .section-title { color: var(--white); margin-bottom: 18px; }
    .contact-left .section-title em { color: var(--amber); }
    .contact-desc { font-size: .95rem; color: rgba(255,255,255,.6); font-weight: 300; line-height: 1.8; margin-bottom: 40px; }
    .contact-details { display: flex; flex-direction: column; gap: 18px; }
    .contact-detail {
      display: flex; align-items: flex-start; gap: 14px;
    }
    .contact-detail-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      background: rgba(255,255,255,.08);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .contact-detail-text strong {
      display: block;
      color: var(--white);
      font-size: .82rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 2px;
    }
    .contact-detail-text span { font-size: .88rem; color: rgba(255,255,255,.55); font-weight: 300; }

    /* Form */
    .contact-form {
      background: var(--white);
      border-radius: 12px;
      padding: 40px 36px;
    }
    .form-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 6px;
    }
    .form-sub { font-size: .85rem; color: var(--muted); margin-bottom: 28px; font-weight: 300; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .form-field label {
      font-size: .75rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--muted);
    }
    .form-field input,
    .form-field textarea,
    .form-field select {
      background: var(--cream);
      border: 1.5px solid var(--border);
      color: var(--text);
      padding: 13px 16px;
      font-family: var(--sans);
      font-size: .9rem;
      font-weight: 300;
      border-radius: var(--radius);
      transition: border-color .2s, box-shadow .2s;
      outline: none;
      -webkit-appearance: none;
    }
    .form-field input::placeholder,
    .form-field textarea::placeholder { color: var(--dim); }
    .form-field input:focus,
    .form-field textarea:focus,
    .form-field select:focus { border-color: var(--terra); box-shadow: 0 0 0 3px var(--terra-glow); }
    .form-field textarea { resize: vertical; min-height: 110px; }
    .form-submit {
      width: 100%;
      background: var(--terra);
      color: var(--white);
      border: none;
      padding: 16px;
      font-family: var(--sans);
      font-size: .88rem;
      font-weight: 600;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background .2s, box-shadow .2s;
      letter-spacing: .02em;
    }
    .form-submit:hover { background: var(--terra-lt); box-shadow: 0 6px 24px var(--terra-glow); }
    .form-privacy { font-size: .72rem; color: var(--dim); text-align: center; margin-top: 10px; line-height: 1.6; }

    /* ── FOOTER ─── */
    .footer { background: var(--navy-deep); border-top: 1px solid rgba(255,255,255,.07); }
    .footer-top {
      max-width: 1240px; margin: 0 auto; padding: 0 48px;
      display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr;
      gap: 56px;
      padding-top: 72px; padding-bottom: 56px;
    }
    .footer-brand {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--white);
      display: block;
      margin-bottom: 14px;
      letter-spacing: -.01em;
    }
    .footer-brand span { color: var(--amber); }
    .footer-tagline { font-size: .88rem; color: rgba(255,255,255,.45); line-height: 1.7; font-weight: 300; max-width: 240px; }
    .footer-col-title { font-size: .68rem; letter-spacing: .16em; text-transform: uppercase; font-weight: 700; color: rgba(255,255,255,.35); margin-bottom: 22px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 11px; }
    .footer-links a { font-size: .88rem; color: rgba(255,255,255,.55); text-decoration: none; transition: color .2s; font-weight: 300; }
    .footer-links a:hover { color: var(--amber); }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.07);
      padding: 24px 48px;
      max-width: 1240px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
      font-size: .78rem;
      color: rgba(255,255,255,.3);
    }
    .footer-bottom a { color: rgba(255,255,255,.3); text-decoration: none; transition: color .2s; }
    .footer-bottom a:hover { color: rgba(255,255,255,.6); }
    .footer-bottom-links { display: flex; gap: 20px; }

    /* ── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      .container { padding: 0 28px; }
      .topbar { padding: 10px 28px; }
      .nav { padding: 0 28px; }
      .hero { padding: 60px 28px; grid-template-columns: 1fr; gap: 48px; max-width: 100%; }
      .hero-visual { display: none; }
      .trust-strip { padding: 24px 28px; }
      .about-grid { grid-template-columns: 1fr; gap: 48px; }
      .numbers-inner { grid-template-columns: repeat(2,1fr); padding: 0 28px; }
      .testi-grid { grid-template-columns: 1fr 1fr; }
      .testi-card:last-child { display: none; }
      .faq-grid { grid-template-columns: 1fr; }
      .contact-inner { grid-template-columns: 1fr; gap: 48px; }
      .footer-top { grid-template-columns: 1fr 1fr; padding: 56px 28px 40px; }
      .footer-bottom { padding: 20px 28px; }
    }
    @media (max-width: 640px) {
      .topbar { flex-direction: column; gap: 8px; }
      .trust-strip-inner { flex-direction: column; gap: 20px; align-items: flex-start; }
      .strip-divider { display: none; }
      .nav-links li:not(:last-child) { display: none; }
      .hero-headline { font-size: 2.6rem; }
      .hero-actions { flex-direction: column; align-items: flex-start; }
      .hero-trust { flex-direction: column; align-items: flex-start; gap: 14px; }
      .numbers-inner { grid-template-columns: 1fr 1fr; padding: 0; }
      .testi-grid { grid-template-columns: 1fr; }
      .testi-card:last-child { display: block; }
      .footer-top { grid-template-columns: 1fr; padding: 40px 28px 28px; gap: 32px; }
      .footer-bottom { flex-direction: column; gap: 12px; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-item">
        <span class="dot"></span>
        Proudly serving our local community
      </div>
      <div class="topbar-item">
        ⭐ 5-Star <%= tone.charAt(0).toUpperCase() + tone.slice(1) %> Service — Trusted Since <%= year %>
      </div>
    </div>
    <a href="#contact" class="topbar-cta">Book a Free Consultation →</a>
  </div>

  <!-- NAVIGATION -->
  <nav class="nav">
    <a href="#home" class="nav-logo"><%= businessName.split(' ')[0] %><span><%= businessName.includes(' ') ? ' ' + businessName.split(' ').slice(1).join(' ') : '' %></span></a>
    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">Our Story</a></li>
      <li><a href="#testimonials">Reviews</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#contact" class="nav-book">Book Appointment</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section id="home">
    <div class="hero">
      <div class="hero-text">
        <div class="hero-eyebrow">Your Local Experts</div>
        <h1 class="hero-headline">
          <em>Quality</em> You Can<br>Count On,<br>Every Time.
        </h1>
        <p class="hero-sub"><%= tagline %> — delivering top-tier solutions with a personal touch that big corporations can't match.</p>
        <div class="hero-actions">
          <a href="#contact" class="btn-primary">Get a Free Quote →</a>
          <a href="#services" class="btn-outline">Our Services</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <div class="trust-icon">✓</div>
            Licensed & Insured
          </div>
          <div class="trust-item">
            <div class="trust-icon">★</div>
            5-Star Rated
          </div>
          <div class="trust-item">
            <div class="trust-icon">⏱</div>
            Same-Day Response
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <div class="hero-card-bg"></div>
          <div class="hero-card-initial"><%= businessName.charAt(0) %></div>
          <div class="hero-card-badge top-right">
            <div class="badge-num">★ 5.0</div>
            <div class="badge-label">Google Rating</div>
          </div>
          <div class="hero-card-badge bottom-left">
            <div class="badge-num">500+</div>
            <div class="badge-label">Happy Clients</div>
          </div>
          <div class="hero-card-review">
            <div>
              <div class="review-stars">★★★★★</div>
              <div class="review-text"><strong>"Absolutely fantastic!"</strong>Best service in town.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <div class="trust-strip">
    <div class="trust-strip-inner">
      <div class="strip-item">
        <span class="strip-icon">🏆</span>
        <div><strong>Award Winning</strong>Best in Category <%= year %></div>
      </div>
      <div class="strip-divider"></div>
      <div class="strip-item">
        <span class="strip-icon">🔒</span>
        <div><strong>Fully Licensed</strong>Insured & Certified</div>
      </div>
      <div class="strip-divider"></div>
      <div class="strip-item">
        <span class="strip-icon">💯</span>
        <div><strong>Satisfaction Guaranteed</strong>Or Your Money Back</div>
      </div>
      <div class="strip-divider"></div>
      <div class="strip-item">
        <span class="strip-icon">📞</span>
        <div><strong>24/7 Emergency Line</strong>Always Here When You Need Us</div>
      </div>
      <div class="strip-divider"></div>
      <div class="strip-item">
        <span class="strip-icon">💰</span>
        <div><strong>Transparent Pricing</strong>No Hidden Fees, Ever</div>
      </div>
    </div>
  </div>

  <!-- SERVICES -->
  <section id="services" class="services section-pad">
    <div class="container">
      <div class="services-header reveal">
        <div class="section-eyebrow">What We Offer</div>
        <h2 class="section-title">Premium Services<br>for <em>Every Need</em></h2>
        <p class="services-meta" style="margin-top:14px">Everything your home or business needs, handled by experts who genuinely care about quality.</p>
      </div>
      <div class="services-grid">
        <% const icons = ['🎯','⚡','🛡️','🔧','✨','📋']; %>
        <% products.forEach(function(p, i){ %>
        <div class="service-card reveal reveal-delay-<%= i % 3 %>">
          <div class="service-icon"><%= icons[i % icons.length] %></div>
          <h3 class="service-name"><%= p %></h3>
          <p class="service-desc">Expert-level <%= p.toLowerCase() %> tailored to your exact needs. We bring decades of experience and a commitment to getting it right — the first time.</p>
          <a href="#contact" class="service-link">Request Service →</a>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- NUMBERS -->
  <div class="numbers reveal">
    <div class="numbers-inner">
      <div class="num-item">
        <div class="num-val" data-target="500" data-suffix="+">0+</div>
        <div class="num-label">Happy Clients</div>
      </div>
      <div class="num-item">
        <div class="num-val" data-target="15" data-suffix="yr">0yr</div>
        <div class="num-label">Experience</div>
      </div>
      <div class="num-item">
        <div class="num-val" data-target="98" data-suffix="%">0%</div>
        <div class="num-label">Satisfaction Rate</div>
      </div>
      <div class="num-item">
        <div class="num-val" data-target="24" data-suffix="/7">0/7</div>
        <div class="num-label">Emergency Service</div>
      </div>
    </div>
  </div>

  <!-- ABOUT -->
  <section id="about" class="about section-pad">
    <div class="container">
      <div class="about-grid">
        <div class="about-left reveal">
          <div class="section-eyebrow">Our Story</div>
          <h2 class="section-title">Committed to<br><em>Our Community</em></h2>
          <p class="about-body" style="margin-top:20px"><%= about %></p>
          <ul class="checklist">
            <li><div class="check-icon">✓</div>Fully licensed, bonded, and insured professionals</li>
            <li><div class="check-icon">✓</div>100% satisfaction guarantee on every single job</li>
            <li><div class="check-icon">✓</div>Transparent, upfront pricing with no hidden costs</li>
            <li><div class="check-icon">✓</div>Background-checked, trained technicians only</li>
            <li><div class="check-icon">✓</div>Eco-friendly products and practices</li>
          </ul>
          <a href="#contact" class="btn-primary">Schedule a Consultation →</a>
        </div>
        <div class="about-right reveal reveal-delay-1">
          <div class="hours-card">
            <h3 class="hours-title"><span class="dot"></span>Business Hours</h3>
            <ul class="hours-list">
              <li class="hours-row"><span class="hours-day">Monday – Friday</span><span class="hours-time">8:00 AM – 6:00 PM</span></li>
              <li class="hours-row"><span class="hours-day">Saturday</span><span class="hours-time">9:00 AM – 4:00 PM</span></li>
              <li class="hours-row"><span class="hours-day">Sunday</span><span class="hours-time closed">Closed</span></li>
            </ul>
          </div>
          <div class="emergency-card">
            <div class="emergency-icon">🚨</div>
            <div>
              <div class="emergency-title">24/7 Emergency Service</div>
              <div class="emergency-sub">We're always available when you need us most. Call our emergency line for immediate assistance, any time.</div>
            </div>
          </div>
          <div class="area-card">
            <div class="area-title">📍 Areas We Serve</div>
            <div class="area-tags">
              <span class="area-tag">Downtown</span>
              <span class="area-tag">North District</span>
              <span class="area-tag">Westside</span>
              <span class="area-tag">East End</span>
              <span class="area-tag">Suburbs</span>
              <span class="area-tag">& Surrounding Areas</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="testimonials section-pad">
    <div class="container">
      <div class="testi-header reveal">
        <div class="section-eyebrow">Real Reviews</div>
        <h2 class="section-title">What Our Neighbours<br><em>Say About Us</em></h2>
        <p class="testi-intro" style="margin-top:14px">Don't take our word for it — here's what real customers in our community have to say.</p>
      </div>
      <div class="testi-grid">
        <div class="testi-card reveal">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-quote">"Absolutely outstanding service from start to finish. They showed up on time, explained everything clearly, and the result was better than I could have hoped. Will 100% use again."</p>
          <div class="testi-author">
            <div class="testi-avatar">MR</div>
            <div><span class="testi-name">Margaret R.</span><span class="testi-role">Local homeowner, 3 years</span></div>
          </div>
        </div>
        <div class="testi-card reveal reveal-delay-1">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-quote">"Finally found a company I can trust! Honest pricing, professional team, and they left the place spotless. <%= businessName %> is the only one I recommend to friends and family."</p>
          <div class="testi-author">
            <div class="testi-avatar">DK</div>
            <div><span class="testi-name">David K.</span><span class="testi-role">Small business owner</span></div>
          </div>
        </div>
        <div class="testi-card reveal reveal-delay-2">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-quote">"Called them on a Saturday morning for an urgent situation — they arrived within two hours. Professional, efficient, and genuinely kind. That's rare. Couldn't recommend more highly."</p>
          <div class="testi-author">
            <div class="testi-avatar">SL</div>
            <div><span class="testi-name">Sandra L.</span><span class="testi-role">Repeat customer, 5 years</span></div>
          </div>
        </div>
      </div>
      <p class="testi-source">Based on <strong>200+ verified reviews</strong> across Google, Yelp & Facebook</p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="faq section-pad">
    <div class="container">
      <div class="faq-grid">
        <div class="faq-left reveal">
          <div class="section-eyebrow">Got Questions?</div>
          <h2 class="section-title">Frequently<br><em>Asked Questions</em></h2>
          <p class="section-sub" style="margin-top:16px">Everything you need to know before getting in touch. Still have a question? We're always happy to chat.</p>
          <div class="faq-cta-box" style="margin-top:32px">
            <div class="faq-cta-title">Still unsure?</div>
            <p class="faq-cta-sub">Our friendly team is happy to answer any questions. No pressure, no obligation — just honest advice.</p>
            <a href="#contact" class="btn-primary" style="font-size:.82rem;padding:13px 24px">Talk to an Expert →</a>
          </div>
        </div>
        <div class="faq-list reveal reveal-delay-1">
          <div class="faq-item">
            <button class="faq-question" data-faq>
              Do you offer free estimates?
              <span class="faq-arrow">▾</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Yes! We offer completely free, no-obligation estimates for all services. One of our experts will assess your needs and provide a transparent, itemized quote before any work begins.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" data-faq>
              Are you licensed and insured?
              <span class="faq-arrow">▾</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Absolutely. <%= businessName %> is fully licensed, bonded, and insured. All our technicians undergo background checks and hold the certifications required for their respective specialties. Your peace of mind is our priority.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" data-faq>
              How quickly can you respond?
              <span class="faq-arrow">▾</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">For standard bookings, we typically respond within 2 hours and can schedule visits as soon as next day. For emergency situations, we operate a 24/7 emergency line and aim to be on-site within 2 hours.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" data-faq>
              What is your satisfaction guarantee?
              <span class="faq-arrow">▾</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">We stand behind every job with a 100% satisfaction guarantee. If you're not completely happy with the results, we'll return to make it right — at no additional charge. Your satisfaction isn't just a promise; it's our policy.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" data-faq>
              Do you offer any payment plans?
              <span class="faq-arrow">▾</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Yes, for larger projects we offer flexible payment plans to make quality services accessible. We accept all major credit cards, bank transfers, and cash. Ask our team about the options available for your specific project.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact section-pad">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-left reveal">
          <div class="section-eyebrow" style="color:var(--amber)">Get In Touch</div>
          <h2 class="section-title">Let's Get<br><em>Started</em></h2>
          <p class="contact-desc">Fill out the form and one of our friendly team members will be in touch within the hour during business hours.</p>
          <div class="contact-details">
            <div class="contact-detail">
              <div class="contact-detail-icon">📞</div>
              <div class="contact-detail-text">
                <strong>Phone</strong>
                <span>Call us for immediate assistance</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">📧</div>
              <div class="contact-detail-text">
                <strong>Email</strong>
                <span>We reply within 1 business hour</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">📍</div>
              <div class="contact-detail-text">
                <strong>Service Area</strong>
                <span>Local and surrounding communities</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">⏰</div>
              <div class="contact-detail-text">
                <strong>Hours</strong>
                <span>Mon–Fri 8AM–6PM · Sat 9AM–4PM</span>
              </div>
            </div>
          </div>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="contact-form">
            <h3 class="form-title">Request a Free Quote</h3>
            <p class="form-sub">No obligation. We'll get back to you within the hour.</p>
            <form data-contact>
              <div class="form-row">
                <div class="form-field">
                  <label>First Name</label>
                  <input type="text" placeholder="Jane" required>
                </div>
                <div class="form-field">
                  <label>Last Name</label>
                  <input type="text" placeholder="Smith" required>
                </div>
              </div>
              <div class="form-field">
                <label>Email Address</label>
                <input type="email" placeholder="jane@email.com" required>
              </div>
              <div class="form-field">
                <label>Phone Number</label>
                <input type="tel" placeholder="+1 (555) 000-0000">
              </div>
              <div class="form-field">
                <label>Service Needed</label>
                <select>
                  <option value="" disabled selected>Select a service</option>
                  <% products.forEach(function(p){ %><option value="<%= p %>"><%= p %></option><% }); %>
                  <option value="emergency">Emergency / Urgent</option>
                  <option value="other">Other / Not Listed</option>
                </select>
              </div>
              <div class="form-field">
                <label>Tell Us About Your Needs</label>
                <textarea placeholder="Describe what you need help with, your location, and any relevant details…" required></textarea>
              </div>
              <button type="submit" class="form-submit">Send My Request →</button>
              <p class="form-privacy">🔒 Your information is kept strictly confidential and never shared with third parties.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-top">
      <div>
        <span class="footer-brand"><%= businessName.split(' ')[0] %><span><%= businessName.includes(' ') ? ' ' + businessName.split(' ').slice(1).join(' ') : '' %></span></span>
        <p class="footer-tagline"><%= tagline %> — your trusted local partner.</p>
      </div>
      <div>
        <p class="footer-col-title">Services</p>
        <ul class="footer-links">
          <% products.forEach(function(p){ %><li><a href="#services"><%= p %></a></li><% }); %>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Company</p>
        <ul class="footer-links">
          <li><a href="#about">Our Story</a></li>
          <li><a href="#testimonials">Reviews</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#contact">Careers</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Contact</p>
        <ul class="footer-links">
          <li><a href="#contact">Book Appointment</a></li>
          <li><a href="#contact">Emergency Line</a></li>
          <li><a href="#contact">Get a Quote</a></li>
          <li><a href="#">Leave a Review</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© <%= year %> <%= businessName %>. All rights reserved.</span>
      <div class="footer-bottom-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Sitemap</a>
      </div>
    </div>
  </footer>

  <script>
    // ── REVEAL ON SCROLL
    const revObs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); }});
    }, { threshold: 0.06, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revObs.observe(el));

    // ── COUNTER ANIMATION
    function animCounter(el, target, suffix) {
      const dur = 1800, start = performance.now();
      (function tick(now) {
        const p = Math.min((now - start) / dur, 1);
        const val = Math.floor((1 - Math.pow(1 - p, 3)) * target);
        el.textContent = val + suffix;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = target + suffix;
      })(start);
    }
    const cntObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          animCounter(e.target, +e.target.dataset.target, e.target.dataset.suffix || '');
          cntObs.unobserve(e.target);
        }
      });
    }, { threshold: .5 });
    document.querySelectorAll('[data-target]').forEach(el => cntObs.observe(el));

    // ── FAQ ACCORDION
    document.querySelectorAll('[data-faq]').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item.querySelector('.faq-answer');
        const isOpen = item.classList.contains('open');
        // close all
        document.querySelectorAll('.faq-item.open').forEach(i => {
          i.classList.remove('open');
          i.querySelector('.faq-answer').style.maxHeight = '0';
        });
        if (!isOpen) {
          item.classList.add('open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });

    // ── SMOOTH SCROLL
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });

    // ── CONTACT FORM
    const form = document.querySelector('[data-contact]');
    if (form) {
      form.addEventListener('submit', e => {
        e.preventDefault();
        const btn = form.querySelector('.form-submit');
        btn.textContent = 'Sending…';
        btn.disabled = true;
        setTimeout(() => {
          const ok = document.createElement('div');
          ok.style.cssText = 'background:#f0fdf4;border:1.5px solid #86efac;color:#166534;padding:16px 20px;border-radius:6px;font-size:.88rem;margin-bottom:16px;line-height:1.6;';
          ok.innerHTML = '✅ <strong>Request received!</strong> We\'ll be in touch within the hour. Thank you for choosing <%= businessName %>!';
          form.insertAdjacentElement('beforebegin', ok);
          form.reset();
          btn.textContent = 'Send My Request →';
          btn.disabled = false;
          setTimeout(() => ok.remove(), 6000);
        }, 800);
      });
    }
  </script>
</body>
</html>
