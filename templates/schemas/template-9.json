{
  "id": "template-9",
  "name": "NBFC / Lender",
  "extends": "_base",
  "complianceReview": {
    "title": "Regulatory content — please have your compliance team review before publishing.",
    "body": "This template includes RBI registration, NBFC category, Fair Practice Code, and Grievance Redressal disclosures. AI-suggested copy in these sections is a starting draft only — the final wording must match your actual RBI registration, your Principal Nodal Officer's real contact details, and the latest RBI guidelines applicable to your NBFC category. Publishing inaccurate regulatory copy can be a compliance violation."
  },
  "sections": [
    {
      "id": "compliance",
      "title": "Compliance Bar",
      "hint": {
        "label": "The thin RBI / CIN bar at the top",
        "description": "Mandatory regulatory strip for NBFCs — your RBI registration number, CIN, and NBFC category sit here above the navigation. Visitors (and regulators) look here first to confirm you're a real registered NBFC.",
        "mockupTarget": "header"
      },
      "fields": [
        { "id": "rbiRegNumber",       "label": "RBI Registration Number (Cert. of Registration No.)", "type": "text", "max": 40, "placeholder": "B-13.02345" },
        { "id": "cin",                "label": "CIN (Corporate Identity Number)",                     "type": "text", "max": 30, "placeholder": "U65923MH2012PTC230456" },
        { "id": "nbfcCategory",       "label": "NBFC Category",                                       "type": "select",
          "options": ["NBFC-ICC (Investment & Credit Co.)","NBFC-MFI (Microfinance)","NBFC-Factor","NBFC-IFC (Infrastructure)","HFC (Housing Finance)","Asset Finance NBFC","Loan NBFC","Other NBFC"] },
        { "id": "mitcLinkLabel",      "label": "Most Important T&Cs link label", "type": "text", "max": 40, "placeholder": "Most Important T&Cs" },
        { "id": "fairPracticeLinkLabel","label": "Fair Practice Code link label","type": "text", "max": 40, "placeholder": "Fair Practice Code" },
        { "id": "grievanceLinkLabel", "label": "Grievance Redressal link label","type": "text", "max": 40, "placeholder": "Grievance Redressal" },
        { "id": "sachetLinkLabel",    "label": "RBI Sachet portal link label",   "type": "text", "max": 40, "placeholder": "Report unauthorised entity (Sachet)" }
      ]
    },
    {
      "id": "hero",
      "title": "Hero",
      "aiable": true,
      "hint": {
        "label": "The big promise + headline rate panel",
        "description": "Headline + sub-line on the left, a 'starting at X% p.a.' rate panel on the right with three or four quick-promise bullets. The rate panel is what visitors screenshot — keep the rate honest and the bullets sharp."
      },
      "fields": [
        { "id": "heroEyebrow",         "label": "Eyebrow (e.g. RBI Registered NBFC since 2012)", "type": "text", "max": 80, "aiable": true },
        { "id": "heroHeadlineLead",    "label": "Headline · line 1", "type": "text", "max": 40, "placeholder": "Loans built" },
        { "id": "heroHeadlineBody",    "label": "Headline · line 2", "type": "text", "max": 40, "placeholder": "around" },
        { "id": "heroHeadlineEmph",    "label": "Headline · emphasised line (italic)", "type": "text", "max": 40, "placeholder": "your life.", "aiable": true },
        { "id": "heroSub",             "label": "Sub-headline", "type": "textarea", "rows": 3, "max": 280, "aiable": true },
        { "id": "heroCtaPrimary",      "label": "Primary CTA text",   "type": "text", "max": 30, "placeholder": "Apply Now" },
        { "id": "heroCtaSecondary",    "label": "Secondary CTA text", "type": "text", "max": 30, "placeholder": "Calculate EMI" },
        { "id": "heroRatePanelTitle",  "label": "Rate panel title",   "type": "text", "max": 40, "placeholder": "Starting at" },
        { "id": "heroRatePanelProduct","label": "Rate panel product line (e.g. Personal Loan)", "type": "text", "max": 40, "placeholder": "Personal Loan" },
        { "id": "heroRateValue",       "label": "Rate value (e.g. 10.99)", "type": "text", "max": 12, "placeholder": "10.99%" },
        { "id": "heroRateUnit",        "label": "Rate unit suffix (e.g. p.a.* onwards)", "type": "text", "max": 30, "placeholder": "p.a.* onwards" },
        {
          "id": "heroRateBenefits", "label": "Quick benefits in the rate panel (3–4 bullets)", "type": "repeater", "min": 0, "max": 4, "itemLabel": "Benefit",
          "item": [
            { "id": "icon", "label": "Icon (single emoji)", "type": "text", "max": 4, "placeholder": "✓" },
            { "id": "text", "label": "Benefit (e.g. No collateral required)", "type": "text", "max": 60 }
          ]
        }
      ]
    },
    {
      "id": "trustStrip",
      "title": "Trust Strip",
      "hint": {
        "label": "Quick credibility badges",
        "description": "A thin band beneath the hero with quick credibility cues — 'RBI Regulated', 'CRISIL AA', 'ISO 27001', '15 years lending'. Builds trust in two seconds before they scroll."
      },
      "fields": [
        {
          "id": "trustBadges", "type": "repeater", "min": 2, "max": 6, "itemLabel": "Badge",
          "item": [
            { "id": "icon", "label": "Icon (single emoji)", "type": "text", "max": 4, "placeholder": "🏛" },
            { "id": "label", "label": "Label", "type": "text", "max": 40, "placeholder": "RBI Regulated" }
          ]
        }
      ]
    },
    {
      "id": "products",
      "title": "Loan Products",
      "aiable": true,
      "hint": {
        "label": "What you actually lend",
        "description": "The most-clicked section. Each product card shows icon, name, a one-line pitch, the loan amount range, the 'from' interest rate, and the tenure window. Be transparent — under-promising and over-delivering on rates is how NBFCs build long-term trust."
      },
      "fields": [
        { "id": "productsLabel",    "label": "Section eyebrow",  "type": "text", "max": 40, "placeholder": "What We Offer" },
        { "id": "productsHeadline", "label": "Section headline", "type": "text", "max": 80, "placeholder": "Lending solutions for every life stage.", "aiable": true },
        { "id": "productsBody",     "label": "Section sub-copy", "type": "textarea", "rows": 2, "max": 240, "aiable": true },
        {
          "id": "products", "type": "repeater", "min": 3, "max": 9, "itemLabel": "Product",
          "item": [
            { "id": "icon",        "label": "Icon (single emoji)",            "type": "text", "max": 4, "placeholder": "💼" },
            { "id": "name",        "label": "Product name",                   "type": "text", "required": true, "max": 60, "placeholder": "Personal Loan" },
            { "id": "body",        "label": "Short pitch (1 line)",            "type": "textarea", "rows": 2, "max": 220, "aiable": true },
            { "id": "amountRange", "label": "Loan amount (e.g. ₹1L – ₹40L)", "type": "text", "max": 40, "placeholder": "₹1L – ₹40L" },
            { "id": "rateFrom",    "label": "Rate (from, e.g. 10.99%)",       "type": "text", "max": 16, "placeholder": "10.99%" },
            { "id": "tenure",      "label": "Tenure (e.g. 12–60 months)",      "type": "text", "max": 30, "placeholder": "12–60 months" }
          ]
        }
      ]
    },
    {
      "id": "eligibility",
      "title": "Eligibility & Documents",
      "aiable": true,
      "hint": {
        "label": "Who can apply + what to bring",
        "description": "Two-column section. Left side lists the eligibility criteria — age, income, credit score, employment. Right side lists the documents required, grouped by category (Salaried / Self-employed). Reduces drop-off by setting expectations upfront."
      },
      "fields": [
        { "id": "eligibilityLabel",    "label": "Section eyebrow",       "type": "text", "max": 40, "placeholder": "Eligibility & Documents" },
        { "id": "eligibilityHeadline", "label": "Section headline",      "type": "text", "max": 80, "placeholder": "Simple eligibility. Honest documentation list.", "aiable": true },
        {
          "id": "eligibilityCriteria", "label": "Eligibility criteria", "type": "repeater", "min": 0, "max": 6, "itemLabel": "Criterion",
          "item": [
            { "id": "icon",  "label": "Icon (single emoji)", "type": "text", "max": 4, "placeholder": "🎂" },
            { "id": "title", "label": "Title",                "type": "text", "max": 40, "placeholder": "Age 21 – 65 years" },
            { "id": "body",  "label": "Body",                 "type": "textarea", "rows": 2, "max": 200, "aiable": true }
          ]
        },
        {
          "id": "documentsList", "label": "Documents required (group by category)", "type": "repeater", "min": 0, "max": 4, "itemLabel": "Doc category",
          "item": [
            { "id": "category", "label": "Category (e.g. Salaried / Self-employed)", "type": "text", "max": 40, "placeholder": "Salaried" },
            { "id": "items",    "label": "Comma-separated documents",                   "type": "textarea", "rows": 2, "max": 320, "placeholder": "PAN, Aadhaar, Latest 3 salary slips, 6-month bank statement, Latest Form 16" }
          ]
        }
      ]
    },
    {
      "id": "process",
      "title": "Application Process (4 steps)",
      "aiable": true,
      "hint": {
        "label": "How a loan moves from apply to disbursal",
        "description": "Four steps showing how a customer's loan moves from the first click to money in the bank. Each step has a duration ('5 minutes', 'within 24 hours') — the durations matter more than the verbs."
      },
      "fields": [
        { "id": "processLabel",    "label": "Section eyebrow",  "type": "text", "max": 40, "placeholder": "How To Apply" },
        { "id": "processHeadline", "label": "Section headline", "type": "text", "max": 80, "placeholder": "From apply to disbursal in days.", "aiable": true },
        {
          "id": "processSteps", "type": "repeater", "min": 4, "max": 4, "itemLabel": "Step",
          "item": [
            { "id": "icon",     "label": "Icon (single emoji)",   "type": "text", "max": 4,  "placeholder": "📝" },
            { "id": "title",    "label": "Step title",             "type": "text", "required": true, "max": 40, "placeholder": "Apply Online" },
            { "id": "body",     "label": "Step body",              "type": "textarea", "rows": 2, "max": 200, "aiable": true },
            { "id": "duration", "label": "Duration (e.g. 5 mins)", "type": "text", "max": 30, "placeholder": "5 minutes" }
          ]
        }
      ]
    },
    {
      "id": "charges",
      "title": "Rates & Charges",
      "hint": {
        "label": "The transparent rate-and-fee disclosure",
        "description": "RBI requires NBFCs to publish their interest rates and processing fees clearly. This is a table — product, interest rate, processing fee, foreclosure / prepayment charge. Honest disclosure here reduces complaints and builds long-term trust."
      },
      "fields": [
        { "id": "chargesLabel",     "label": "Section eyebrow",  "type": "text", "max": 40, "placeholder": "Rates & Charges" },
        { "id": "chargesHeadline",  "label": "Section headline", "type": "text", "max": 80, "placeholder": "What it actually costs. No fine print." },
        { "id": "chargesBody",      "label": "Sub-copy",         "type": "textarea", "rows": 2, "max": 240 },
        {
          "id": "rateRows", "label": "Product rate rows", "type": "repeater", "min": 0, "max": 8, "itemLabel": "Row",
          "item": [
            { "id": "product",         "label": "Product",                              "type": "text", "max": 50, "placeholder": "Personal Loan" },
            { "id": "rate",            "label": "Interest rate (e.g. 10.99% – 24% p.a.)", "type": "text", "max": 40, "placeholder": "10.99% – 24% p.a." },
            { "id": "processingFee",   "label": "Processing fee (e.g. Up to 2% + GST)", "type": "text", "max": 40, "placeholder": "Up to 2% + GST" },
            { "id": "prepaymentCharge","label": "Prepayment / foreclosure charge",       "type": "text", "max": 40, "placeholder": "Nil after 6 EMIs" }
          ]
        },
        { "id": "chargesNote", "label": "Disclaimer below the table", "type": "textarea", "rows": 2, "max": 320, "placeholder": "* Final rate is determined by credit assessment. Other charges (stamp duty, GST, late fees) apply as per sanction letter. T&C apply." }
      ]
    },
    {
      "id": "numbers",
      "title": "Numbers Band",
      "hint": {
        "label": "Disbursal + customer + branches",
        "description": "Four big numbers — total disbursed, customers served, branches, years in operation. Specific figures beat vague claims; '₹12,400 Cr disbursed' is far more convincing than 'leading NBFC'."
      },
      "fields": [
        {
          "id": "numberStats", "type": "repeater", "min": 2, "max": 4, "itemLabel": "Stat",
          "item": [
            { "id": "value",  "label": "Number (e.g. 12,400)", "type": "text", "max": 12 },
            { "id": "suffix", "label": "Suffix (e.g. Cr+, L+, Yr, %)", "type": "text", "max": 8 },
            { "id": "label",  "label": "Label",                 "type": "text", "max": 60, "placeholder": "Disbursed since 2012" }
          ]
        }
      ]
    },
    {
      "id": "about",
      "title": "About / Heritage",
      "aiable": true,
      "hint": {
        "label": "Your story + ratings + certifications",
        "description": "Story on the left (origin, lending philosophy, who you serve), three pillars under it. Right side has a heritage card and a row of certifications — CRISIL / ICRA rating, ISO, AMFI, etc."
      },
      "fields": [
        { "id": "aboutLabel",        "label": "Section eyebrow",  "type": "text", "max": 40, "placeholder": "Our Story" },
        { "id": "aboutHeadlineLead", "label": "Headline · line 1","type": "text", "max": 40, "placeholder": "Lending built on" },
        { "id": "aboutHeadlineEmph", "label": "Headline · line 2 (italic)", "type": "text", "max": 40, "placeholder": "trust.", "aiable": true },
        { "id": "aboutBody",         "label": "About body",        "type": "textarea", "rows": 5, "max": 700, "aiable": true },
        {
          "id": "aboutPillars", "label": "Pillars (3 recommended)", "type": "repeater", "min": 0, "max": 4, "itemLabel": "Pillar",
          "item": [
            { "id": "title", "label": "Pillar title", "type": "text", "max": 40, "placeholder": "Transparent Pricing" },
            { "id": "body",  "label": "Pillar body",  "type": "textarea", "rows": 2, "max": 220, "aiable": true }
          ]
        },
        {
          "id": "ratings", "label": "Ratings & certifications", "type": "repeater", "min": 0, "max": 8, "itemLabel": "Rating",
          "item": [
            { "id": "label", "label": "Cert (e.g. CRISIL AA / Stable)", "type": "text", "max": 40 }
          ]
        }
      ]
    },
    {
      "id": "testimonials",
      "title": "Testimonials",
      "hint": {
        "label": "Loan customer stories",
        "description": "Real quotes from real loan customers, with the product they took ('Personal Loan · 2024', 'Business Loan · ₹40L'). Lending is about trust — borrower stories build it faster than any marketing copy."
      },
      "fields": [
        {
          "id": "testimonials", "type": "repeater", "min": 0, "max": 6, "itemLabel": "Testimonial",
          "item": [
            { "id": "quote",       "label": "Quote",                 "type": "textarea", "rows": 3, "max": 320 },
            { "id": "name",        "label": "Customer name",         "type": "text", "max": 60 },
            { "id": "role",        "label": "Role / location (optional)", "type": "text", "max": 80 },
            { "id": "productUsed", "label": "Product / context (e.g. Home Loan · 2024)", "type": "text", "max": 80 }
          ]
        }
      ]
    },
    {
      "id": "grievance",
      "title": "Grievance Redressal",
      "hint": {
        "label": "Mandatory regulatory disclosure",
        "description": "RBI requires every NBFC to publish a Grievance Redressal Officer's name, contact, and a clear 3-tier escalation matrix (Branch → GRO → RBI Ombudsman). This section satisfies that disclosure on your homepage. Don't skip it — non-compliance is a real audit risk."
      },
      "fields": [
        { "id": "grievanceLabel",     "label": "Section eyebrow",   "type": "text", "max": 40, "placeholder": "Customer Care · Grievance Redressal" },
        { "id": "grievanceHeadline",  "label": "Section headline",  "type": "text", "max": 80, "placeholder": "We hear you. And we resolve fast." },
        { "id": "grievanceBody",      "label": "Section body",      "type": "textarea", "rows": 3, "max": 400 },
        { "id": "groName",            "label": "Grievance Redressal Officer · Name",   "type": "text", "max": 80 },
        { "id": "groRole",            "label": "GRO · Designation",                     "type": "text", "max": 80, "placeholder": "Principal Nodal Officer" },
        { "id": "groEmail",           "label": "GRO · Email",                            "type": "text", "max": 120, "placeholder": "grievance@yournbfc.in" },
        { "id": "groPhone",           "label": "GRO · Phone",                            "type": "text", "max": 40 },
        { "id": "groAddress",         "label": "GRO · Postal address",                   "type": "textarea", "rows": 2, "max": 240 },
        { "id": "groTimings",         "label": "GRO · Working hours",                    "type": "text", "max": 80, "placeholder": "Mon–Fri · 10:00 AM – 6:00 PM IST" },
        {
          "id": "escalationLevels", "label": "Escalation matrix (3 levels recommended)", "type": "repeater", "min": 0, "max": 4, "itemLabel": "Level",
          "item": [
            { "id": "level",    "label": "Level (e.g. Level 1 · Branch / Customer Care)", "type": "text", "max": 60 },
            { "id": "body",     "label": "When to escalate / what to expect",              "type": "textarea", "rows": 2, "max": 240 },
            { "id": "contact",  "label": "Contact line (email / phone / link)",            "type": "text", "max": 120 },
            { "id": "tat",      "label": "Turnaround commitment (e.g. Within 7 days)",     "type": "text", "max": 40 }
          ]
        }
      ]
    },
    {
      "id": "cta",
      "title": "CTA Band",
      "aiable": true,
      "hint": {
        "label": "The 'apply now' nudge",
        "description": "A wide call-to-action band before the contact form — bold headline, one supporting line about pre-approval / instant decision, one button. Use action verbs in the button copy."
      },
      "fields": [
        { "id": "ctaHeadline", "label": "CTA headline",        "type": "text", "max": 80,  "aiable": true, "placeholder": "Get a pre-approved offer in 60 seconds." },
        { "id": "ctaBody",     "label": "CTA supporting line", "type": "text", "max": 220, "aiable": true },
        { "id": "ctaButton",   "label": "CTA button text",     "type": "text", "max": 30,  "placeholder": "Check Eligibility" },
        { "id": "ctaNote",     "label": "Fine print under button (optional)", "type": "text", "max": 120, "placeholder": "Soft credit check · Will not affect your CIBIL score" }
      ]
    },
    {
      "id": "contactPerks",
      "title": "Contact Perks",
      "hint": {
        "label": "Reassurance bullets next to the form",
        "description": "Four short bullets next to the contact form telling visitors what happens after they fill it. 'Soft check · won't affect CIBIL', 'Decision in 30 mins', 'Dedicated RM', 'Documents collected at your home'."
      },
      "fields": [
        {
          "id": "contactPerks", "type": "repeater", "min": 0, "max": 6, "itemLabel": "Perk",
          "item": [
            { "id": "icon", "label": "Icon (single emoji)", "type": "text", "max": 4, "placeholder": "✓" },
            { "id": "text", "label": "Perk text",            "type": "text", "max": 120 }
          ]
        }
      ]
    }
  ]
}
