<%
  const color = primaryColor || '#c0392b';
  const svcs = (services && services.length) ? services : [{name:'Service One',body:''},{name:'Service Two',body:''},{name:'Service Three',body:''}];
  const steps = (processSteps && processSteps.length === 4) ? processSteps : [
    {title:'Discovery & Scoping', body:'We begin by listening and understanding your goals and constraints.'},
    {title:'Strategy & Planning', body:'Every engagement is backed by a bespoke plan with clear milestones.'},
    {title:'Execution & Delivery', body:'Our team executes with discipline and transparent communication.'},
    {title:'Review & Growth', body:"We don't disappear at delivery — post-project reviews ensure compounding results."}
  ];
  const vals = (values && values.length) ? values : [
    {text:'Uncompromising quality in every engagement'},
    {text:'Transparent, honest relationships built on trust'},
    {text:'Results measured in outcomes and impact'}
  ];
  const tests = testimonials || [];
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= businessName %><%= tagline ? ' — ' + tagline : '' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root { --accent: <%= color %>; --ink:#0d0d0d; --ink-soft:#3a3a3a; --ink-muted:#888; --paper:#f5f0e8; --paper-mid:#ede8db; --paper-dark:#d9d2c3; --rule:#c8bfae; --white:#fff; --serif:'Playfair Display',Georgia,serif; --sans:'DM Sans',system-ui,sans-serif; }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    body{font-family:var(--sans);background:var(--paper);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}
    .mast{border-bottom:3px double var(--rule);background:var(--paper);position:sticky;top:0;z-index:100}
    .mast-dateline{border-bottom:1px solid var(--rule);padding:6px 48px;display:flex;justify-content:space-between;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-muted)}
    .mast-main{display:flex;align-items:center;justify-content:space-between;padding:14px 48px}
    .mast-brand{display:flex;align-items:center;gap:12px;font-family:var(--serif);font-size:2rem;font-weight:900;color:var(--ink);text-decoration:none}
    .mast-brand img{height:40px;width:auto}
    .mast-nav{display:flex;gap:32px;list-style:none;align-items:center}
    .mast-nav a{font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);text-decoration:none;font-weight:500}
    .mast-nav a:hover{color:var(--accent)}
    .mast-nav .nav-cta{background:var(--ink);color:var(--paper)!important;padding:8px 20px;font-size:.72rem}
    .mast-nav .nav-cta:hover{background:var(--accent)!important}
    .hero{display:grid;grid-template-columns:1fr 1px 1fr;min-height:82vh;border-bottom:2px solid var(--rule);padding:0 48px}
    .hero-left{padding:60px 48px 60px 0;display:flex;flex-direction:column;justify-content:space-between}
    .hero-issue{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:28px}
    .hero-headline{font-family:var(--serif);font-size:clamp(3.2rem,5.5vw,5.5rem);line-height:1.04;font-weight:900;letter-spacing:-.03em;margin-bottom:28px}
    .hero-headline em{font-style:italic;color:var(--accent)}
    .hero-deck{font-size:1.15rem;color:var(--ink-soft);line-height:1.7;font-weight:300;max-width:480px;border-left:3px solid var(--accent);padding-left:20px;margin-bottom:40px}
    .hero-divider{background:var(--rule);width:1px}
    .hero-right{padding:60px 0 60px 48px;display:flex;flex-direction:column;justify-content:center;gap:32px}
    .hero-drop-cap{font-family:var(--serif);font-size:clamp(7rem,14vw,13rem);line-height:.85;font-weight:900;color:var(--paper-dark);letter-spacing:-.05em;margin-bottom:-24px}
    .hero-stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule)}
    .hero-stat{background:var(--paper);padding:24px 20px;text-align:center}
    .hero-stat-num{font-family:var(--serif);font-size:2.2rem;font-weight:900;display:block}
    .hero-stat-label{font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-muted);margin-top:4px;display:block}
    .hero-pull-quote{border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);padding:24px 0;font-family:var(--serif);font-style:italic;font-size:1.3rem;color:var(--ink-soft);line-height:1.5}
    .section-rule{padding:64px 48px 0}
    .section-rule-line{display:flex;align-items:center;gap:20px;margin-bottom:40px}
    .section-rule-line h2{font-family:var(--serif);font-size:1.1rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
    .section-rule-line::before,.section-rule-line::after{content:'';height:1px;background:var(--ink)}
    .section-rule-line::before{width:40px;flex-shrink:0}
    .section-rule-line::after{flex:1}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule);margin:0 48px}
    .service-card{background:var(--paper);padding:36px 32px}
    .service-num{font-family:var(--serif);font-size:3rem;font-weight:900;color:var(--paper-dark);display:block;margin-bottom:16px}
    .service-title{font-family:var(--serif);font-size:1.3rem;font-weight:700;margin-bottom:10px}
    .service-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;font-weight:300}
    .process{padding:0 48px 64px}
    .process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule)}
    .process-step{background:var(--paper);padding:40px 28px}
    .process-step-num{font-family:var(--serif);font-size:.85rem;font-weight:700;color:var(--accent);letter-spacing:.1em;margin-bottom:20px;display:block}
    .process-step-title{font-family:var(--serif);font-size:1.25rem;font-weight:700;margin-bottom:12px}
    .process-step-body{font-size:.85rem;color:var(--ink-soft);font-weight:300}
    .about{margin:0 48px 64px;background:var(--ink);color:var(--paper);display:grid;grid-template-columns:1fr 1fr}
    .about-left{padding:64px 56px;border-right:1px solid rgba(255,255,255,.1)}
    .about-eyebrow{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:24px}
    .about-headline{font-family:var(--serif);font-size:clamp(2rem,3.5vw,3.2rem);font-weight:700;margin-bottom:28px}
    .about-body{font-size:.95rem;color:rgba(245,240,232,.7);font-weight:300;margin-bottom:32px}
    .about-right{padding:64px 56px}
    .about-values{list-style:none}
    .about-values li{padding:18px 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:.9rem;color:rgba(245,240,232,.8);display:flex;gap:16px}
    .about-values li::before{content:'✦';color:var(--accent);font-size:.7rem}
    .testimonials{padding:0 48px 64px}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1px;background:var(--rule);border:1px solid var(--rule)}
    .testi-card{background:var(--paper);padding:40px 32px;display:flex;flex-direction:column;gap:20px}
    .testi-quote{font-family:var(--serif);font-style:italic;font-size:1.05rem;color:var(--ink-soft);line-height:1.6;flex:1}
    .testi-author{display:flex;align-items:center;gap:12px;padding-top:16px;border-top:1px solid var(--rule)}
    .testi-avatar{width:36px;height:36px;background:var(--ink);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--paper);font-family:var(--serif);font-weight:700}
    .testi-name{font-size:.82rem;display:block}
    .testi-role{font-size:.75rem;color:var(--ink-muted);display:block}
    .cta-band{margin:0 48px 64px;background:var(--accent);padding:56px 64px;display:flex;align-items:center;justify-content:space-between;gap:40px}
    .cta-band h2{font-family:var(--serif);font-size:clamp(1.6rem,2.8vw,2.4rem);font-weight:900;color:#fff;margin-bottom:8px}
    .cta-band p{font-size:.9rem;color:rgba(255,255,255,.8)}
    .btn-white{background:#fff;color:var(--accent);padding:16px 36px;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700;text-decoration:none}
    .contact{padding:64px 48px;border-top:3px double var(--rule)}
    .contact-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px}
    .contact-headline{font-family:var(--serif);font-size:clamp(2rem,3vw,3rem);font-weight:900;margin-bottom:20px}
    .contact-info-items{display:flex;flex-direction:column;gap:12px;margin-top:20px}
    .contact-info-item{display:flex;align-items:center;gap:12px;font-size:.85rem;color:var(--ink-soft)}
    .contact-info-item::before{content:'';width:20px;height:1px;background:var(--accent)}
    .site-footer{background:var(--ink);color:var(--paper);border-top:3px solid var(--accent)}
    .footer-top{display:grid;grid-template-columns:2fr 1fr 1fr;padding:56px 48px;gap:48px;border-bottom:1px solid rgba(255,255,255,.08)}
    .footer-brand{font-family:var(--serif);font-size:2rem;font-weight:900;display:block;margin-bottom:16px}
    .footer-col-title{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(245,240,232,.4);margin-bottom:20px}
    .footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .footer-links a{font-size:.85rem;color:rgba(245,240,232,.6);text-decoration:none}
    .footer-bottom{display:flex;align-items:center;justify-content:space-between;padding:20px 48px}
    .footer-copy{font-size:.75rem;color:rgba(245,240,232,.3)}
    @media (max-width:900px){.hero{grid-template-columns:1fr;padding:0 24px}.hero-divider{display:none}.process-grid{grid-template-columns:1fr}.about{grid-template-columns:1fr;margin:0 24px 48px}.cta-band{flex-direction:column;align-items:flex-start;padding:40px 32px;margin:0 24px 48px}.contact-inner{grid-template-columns:1fr;gap:40px}.footer-top{grid-template-columns:1fr;padding:40px 24px}}
  </style>
</head>
<body>
  <header class="mast" id="home">
    <div class="mast-dateline">
      <span><%= (tone||'Professional').charAt(0).toUpperCase() + (tone||'professional').slice(1) %> · Est. <%= foundedYear %></span>
      <span>Excellence in Every Detail</span>
    </div>
    <nav class="mast-main">
      <a href="#home" class="mast-brand">
        <% if (logo) { %><img src="<%= logo %>" alt="<%= businessName %>"><% } %>
        <span><%= businessName %></span>
      </a>
      <ul class="mast-nav">
        <li><a href="#services">Services</a></li>
        <li><a href="#process">Process</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact" class="nav-cta">Contact Us</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-left">
      <div>
        <p class="hero-issue"><%= heroEyebrow || ((tone||'Professional').charAt(0).toUpperCase() + (tone||'professional').slice(1) + ' Solutions') %></p>
        <h1 class="hero-headline">
          <%= businessName.split(' ').slice(0,-1).join(' ') || businessName %>
          <% if (businessName.split(' ').length > 1) { %><em><%= businessName.split(' ').slice(-1)[0] %></em><% } %>
        </h1>
        <p class="hero-deck"><%= heroDeck || tagline %></p>
      </div>
      <div><a href="#services" style="background:var(--ink);color:var(--paper);padding:14px 32px;text-decoration:none;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase">Explore Services</a></div>
    </div>
    <div class="hero-divider"></div>
    <div class="hero-right">
      <div class="hero-drop-cap"><%= businessName.charAt(0) %></div>
      <div class="hero-stat-row">
        <div class="hero-stat"><span class="hero-stat-num"><%= svcs.length %></span><span class="hero-stat-label">Services</span></div>
        <div class="hero-stat"><span class="hero-stat-num">100%</span><span class="hero-stat-label">Committed</span></div>
        <div class="hero-stat"><span class="hero-stat-num">24/7</span><span class="hero-stat-label">Support</span></div>
      </div>
      <% if (heroPullQuote) { %><blockquote class="hero-pull-quote">"<%= heroPullQuote %>"</blockquote><% } %>
    </div>
  </section>

  <section id="services">
    <div class="section-rule"><div class="section-rule-line"><h2>What We Offer</h2></div></div>
    <div class="services-grid">
      <% svcs.forEach(function(s,i){ %>
        <div class="service-card">
          <span class="service-num">0<%= i+1 %></span>
          <h3 class="service-title"><%= s.name %></h3>
          <p class="service-body"><%= s.body || ('Delivering premium ' + (s.name||'').toLowerCase() + ' solutions.') %></p>
        </div>
      <% }) %>
    </div>
  </section>

  <section id="process">
    <div class="section-rule"><div class="section-rule-line"><h2>How We Work</h2></div></div>
    <div class="process"><div class="process-grid">
      <% steps.forEach(function(st,i){ %>
        <div class="process-step">
          <span class="process-step-num">Step 0<%= i+1 %></span>
          <h3 class="process-step-title"><%= st.title %></h3>
          <p class="process-step-body"><%= st.body %></p>
        </div>
      <% }) %>
    </div></div>
  </section>

  <section id="about">
    <div class="section-rule"><div class="section-rule-line"><h2>Our Story</h2></div></div>
    <div class="about">
      <div class="about-left">
        <p class="about-eyebrow">Who We Are</p>
        <h2 class="about-headline"><%= aboutHeadline || 'Built on principle. Driven by purpose.' %></h2>
        <p class="about-body"><%= aboutBody || tagline %></p>
      </div>
      <div class="about-right">
        <ul class="about-values"><% vals.forEach(function(v){ %><li><%= v.text %></li><% }) %></ul>
      </div>
    </div>
  </section>

  <% if (tests.length) { %>
  <section id="testimonials">
    <div class="section-rule"><div class="section-rule-line"><h2>Client Voices</h2></div></div>
    <div class="testimonials"><div class="testi-grid">
      <% tests.forEach(function(t){ %>
        <div class="testi-card">
          <p class="testi-quote">"<%= t.quote %>"</p>
          <div class="testi-author">
            <div class="testi-avatar"><%= (t.name||'?').split(' ').map(function(w){return w.charAt(0)}).slice(0,2).join('') %></div>
            <div><span class="testi-name"><%= t.name %></span><span class="testi-role"><%= t.role %></span></div>
          </div>
        </div>
      <% }) %>
    </div></div>
  </section>
  <% } %>

  <% if (ctaHeadline) { %>
  <div class="cta-band">
    <div>
      <h2><%= ctaHeadline %></h2>
      <% if (ctaBody) { %><p><%= ctaBody %></p><% } %>
    </div>
    <a href="#contact" class="btn-white"><%= ctaButton || 'Get in Touch' %></a>
  </div>
  <% } %>

  <section id="contact" class="contact">
    <div class="contact-inner">
      <div>
        <h2 class="contact-headline">Let's build something remarkable.</h2>
        <div class="contact-info-items">
          <% if (hours)   { %><div class="contact-info-item"><%= hours %></div><% } %>
          <% if (email)   { %><div class="contact-info-item"><%= email %></div><% } %>
          <% if (phone)   { %><div class="contact-info-item"><%= phone %></div><% } %>
          <% if (address) { %><div class="contact-info-item"><%= address %></div><% } %>
        </div>
      </div>
      <div>
        <form onsubmit="event.preventDefault();alert('Demo form — wire to your backend.')">
          <input type="text" placeholder="Your name" style="width:100%;padding:12px;margin-bottom:8px;border:1px solid var(--rule);background:var(--paper)">
          <input type="email" placeholder="Email" style="width:100%;padding:12px;margin-bottom:8px;border:1px solid var(--rule);background:var(--paper)">
          <textarea rows="4" placeholder="Your message" style="width:100%;padding:12px;margin-bottom:8px;border:1px solid var(--rule);background:var(--paper)"></textarea>
          <button type="submit" style="background:var(--ink);color:var(--paper);padding:14px 28px;border:none;width:100%;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="footer-top">
      <div>
        <span class="footer-brand"><%= businessName %></span>
        <p style="color:rgba(245,240,232,.5);font-weight:300"><%= tagline %></p>
      </div>
      <div>
        <p class="footer-col-title">Navigation</p>
        <ul class="footer-links"><li><a href="#home">Home</a></li><li><a href="#services">Services</a></li><li><a href="#about">About</a></li><li><a href="#contact">Contact</a></li></ul>
      </div>
      <div>
        <p class="footer-col-title">Services</p>
        <ul class="footer-links"><% svcs.forEach(function(s){ %><li><a href="#services"><%= s.name %></a></li><% }) %></ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© <%= year %> <%= businessName %>. All rights reserved.</span>
    </div>
  </footer>
</body>
</html>