      .b2b-grid{grid-template-columns:1fr}
      .ft-top{grid-template-columns:1fr;gap:28px;padding:36px 20px}
      .ft-bot{flex-direction:column;gap:10px;text-align:center;padding:16px 20px}
      .fg2{grid-template-columns:1fr}
    }
  </style>
