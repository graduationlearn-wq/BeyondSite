  <script>
    const nav=document.getElementById('nav');
    window.addEventListener('scroll',()=>nav.classList.toggle('elevated',window.scrollY>20),{passive:true});

    const ro=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');ro.unobserve(x.target);}});},{threshold:.07,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

    function cnt(el,target,suffix){const dur=1800,s=performance.now();(function tick(now){const p=Math.min((now-s)/dur,1),v=Math.floor((1-Math.pow(1-p,3))*target);el.textContent=v+suffix;if(p<1)requestAnimationFrame(tick);else el.textContent=target+suffix;})(s);}
    const co=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){cnt(x.target,+x.target.dataset.target,x.target.dataset.suffix||'');co.unobserve(x.target);}});},{threshold:.5});
    document.querySelectorAll('[data-target]').forEach(el=>co.observe(el));

    document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{const t=document.querySelector(a.getAttribute('href'));if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}});});

    const f=document.querySelector('[data-contact]');
    if(f){f.addEventListener('submit',e=>{e.preventDefault();const b=f.querySelector('.form-submit');b.textContent='Getting quotes…';b.disabled=true;setTimeout(()=>{const n=document.createElement('div');n.style.cssText='background:rgba(0,133,111,.07);border:1px solid rgba(0,133,111,.25);color:#00856f;padding:14px 18px;border-radius:10px;font-size:.87rem;margin-bottom:14px;line-height:1.6;';n.innerHTML='✓ <strong>Request received!</strong> Our advisor will call you within 2 hours with the best quotes.';f.insertAdjacentElement('beforebegin',n);f.reset();b.textContent='Get Free Quotes →';b.disabled=false;setTimeout(()=>n.remove(),7000);},900);});}
  </script>
