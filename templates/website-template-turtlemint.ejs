<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= businessName %> — <%= tagline %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:      #f7f9fc;
      --bg2:     #eef1f7;
      --white:   #ffffff;
      --ink:     #0d1117;
      --ink2:    #1e2530;
      --ink3:    #3a4050;
      --muted:   rgba(13,17,23,.5);
      --dim:     rgba(13,17,23,.28);
      --teal:    #00856f;
      --teal-lt: #00a688;
      --teal-glo:rgba(0,133,111,.14);
      --teal-dim:rgba(0,133,111,.08);
      --teal-bdr:rgba(0,133,111,.22);
      --amber:   #f59e0b;
      --grn:     #16a34a;
      --grn-dim: rgba(22,163,74,.1);
      --red:     #dc2626;
      --border:  rgba(13,17,23,.09);
      --bdrmd:   rgba(13,17,23,.14);
      --radius:  12px;
      --display: 'Plus Jakarta Sans', system-ui, sans-serif;
      --body:    'DM Sans', system-ui, sans-serif;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--body);background:var(--bg);color:var(--ink);overflow-x:hidden;-webkit-font-smoothing:antialiased;line-height:1.65}

    /* ── NAV ── */
    .nav{position:sticky;top:0;z-index:500;height:68px;padding:0 48px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);transition:box-shadow .3s}
    .nav.elevated{box-shadow:0 2px 20px rgba(13,17,23,.08)}
    .nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .logo-mark{width:32px;height:32px;border-radius:10px;background:var(--teal);display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px var(--teal-glo)}
    .logo-mark svg{display:block}
    .logo-text{font-family:var(--display);font-size:1.1rem;font-weight:800;letter-spacing:-.03em;color:var(--ink)}
    .logo-text span{color:var(--teal)}
    .nav-links{display:flex;gap:0;list-style:none;align-items:center}
    .nav-links a{font-size:.84rem;font-weight:500;color:var(--muted);text-decoration:none;padding:8px 14px;border-radius:8px;transition:color .2s,background .2s}
    .nav-links a:hover{color:var(--ink);background:var(--bg2)}
    .nav-right{display:flex;gap:8px;align-items:center}
    .btn-outline-nav{font-size:.84rem;font-weight:600;color:var(--teal);border:1.5px solid var(--teal-bdr);padding:8px 18px;border-radius:8px;text-decoration:none;transition:background .2s}
    .btn-outline-nav:hover{background:var(--teal-dim)}
    .btn-solid-nav{font-size:.84rem;font-weight:700;color:#fff;background:var(--teal);padding:9px 20px;border-radius:8px;text-decoration:none;box-shadow:0 2px 12px var(--teal-glo);transition:background .2s,box-shadow .2s}
    .btn-solid-nav:hover{background:var(--teal-lt);box-shadow:0 4px 20px var(--teal-glo)}

    /* ── HERO ── */
    .hero{position:relative;z-index:1;background:var(--white);border-bottom:1px solid var(--border);overflow:hidden}
    .hero::before{content:'';position:absolute;top:-60px;right:-80px;width:600px;height:600px;background:radial-gradient(circle,rgba(0,133,111,.06) 0%,transparent 65%);border-radius:50%;pointer-events:none}
    .hero-inner{max-width:1200px;margin:0 auto;padding:80px 48px 0;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:end}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:var(--teal-dim);border:1px solid var(--teal-bdr);color:var(--teal);padding:5px 12px;border-radius:100px;font-size:.72rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:24px}
    .hero-title{font-family:var(--display);font-size:clamp(2.8rem,5vw,4.6rem);font-weight:800;line-height:1.06;letter-spacing:-.04em;color:var(--ink);margin-bottom:20px}
    .hero-title .teal{color:var(--teal)}
    .hero-sub{font-size:1rem;color:var(--muted);line-height:1.78;max-width:480px;margin-bottom:36px}
    .hero-ctas{display:flex;gap:12px;align-items:center;margin-bottom:40px}
    .btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--teal);color:#fff;padding:14px 28px;border-radius:10px;font-family:var(--display);font-size:.9rem;font-weight:700;text-decoration:none;border:none;cursor:pointer;box-shadow:0 4px 18px var(--teal-glo);transition:background .2s,box-shadow .2s,transform .15s}
    .btn-primary:hover{background:var(--teal-lt);box-shadow:0 6px 28px var(--teal-glo);transform:translateY(-2px)}
    .btn-secondary{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--ink2);padding:13px 24px;border-radius:10px;border:1.5px solid var(--bdrmd);font-size:.9rem;font-weight:600;text-decoration:none;transition:border-color .2s,color .2s}
    .btn-secondary:hover{border-color:var(--teal);color:var(--teal)}
    .hero-trust-pills{display:flex;gap:10px;flex-wrap:wrap}
    .trust-pill{display:inline-flex;align-items:center;gap:6px;background:var(--bg);border:1px solid var(--border);padding:6px 12px;border-radius:100px;font-size:.74rem;font-weight:500;color:var(--muted)}
    .trust-pill-icon{font-size:.85rem}

    /* HERO RIGHT — stats cards */
    .hero-right{display:flex;flex-direction:column;gap:12px;padding-bottom:0}
    .hero-stat-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .hsc{background:var(--white);border:1.5px solid var(--border);border-radius:14px;padding:20px 20px 16px;box-shadow:0 2px 12px rgba(13,17,23,.05);transition:box-shadow .25s,transform .25s}
    .hsc:hover{box-shadow:0 6px 24px rgba(0,133,111,.1);transform:translateY(-3px)}
    .hsc-val{font-family:var(--display);font-size:2rem;font-weight:800;color:var(--teal);line-height:1;letter-spacing:-.04em;margin-bottom:4px}
    .hsc-label{font-size:.78rem;color:var(--muted);font-weight:400}
    .hsc-icon{font-size:1.4rem;margin-bottom:10px}
    .hero-app-banner{background:var(--teal);border-radius:14px;padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px}
    .hab-text{color:#fff}
    .hab-title{font-family:var(--display);font-size:.95rem;font-weight:700;margin-bottom:3px}
    .hab-sub{font-size:.78rem;opacity:.8}
    .hab-badge{background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);color:#fff;padding:8px 16px;border-radius:8px;font-size:.78rem;font-weight:600;white-space:nowrap;cursor:pointer;transition:background .2s}
    .hab-badge:hover{background:rgba(255,255,255,.28)}

    /* ── TRUST STRIP ── */
    .trust-strip{background:var(--ink2);padding:20px 48px;display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap}
    .ts-item{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.75);font-size:.82rem}
    .ts-icon{font-size:1.1rem;flex-shrink:0}
    .ts-item strong{display:block;color:#fff;font-weight:600;font-size:.85rem}
    .ts-divider{width:1px;height:32px;background:rgba(255,255,255,.12);flex-shrink:0}

    /* ── SECTIONS ── */
    .z1{position:relative;z-index:1}
    .ctn{max-width:1200px;margin:0 auto;padding:0 48px}
    .spad{padding:96px 0}
    .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:var(--teal);margin-bottom:14px}
    .eyebrow::before{content:'';width:16px;height:2px;background:var(--teal);border-radius:2px}
    .sec-title{font-family:var(--display);font-size:clamp(2rem,3.8vw,3.2rem);font-weight:800;letter-spacing:-.04em;line-height:1.1;color:var(--ink)}
    .sec-title .teal{color:var(--teal)}
    .sec-sub{font-size:.95rem;color:var(--muted);font-weight:400;line-height:1.75;max-width:500px}
    .reveal{opacity:0;transform:translateY(30px);transition:opacity .75s ease,transform .75s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}
    .rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}

    /* ── PRODUCTS GRID ── */
    .products{background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .products-intro{text-align:center;max-width:560px;margin:0 auto 56px}
    .products-intro .sec-sub{margin:14px auto 0}
    .prod-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px}
    .prod-card{background:var(--bg);border:1.5px solid var(--border);border-radius:14px;padding:24px 16px;text-align:center;transition:border-color .25s,box-shadow .25s,transform .25s;cursor:pointer}
    .prod-card:hover{border-color:var(--teal-bdr);box-shadow:0 4px 20px var(--teal-glo);transform:translateY(-4px)}
    .prod-icon{font-size:2rem;margin-bottom:12px;display:block}
    .prod-name{font-family:var(--display);font-size:.88rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .prod-sub{font-size:.72rem;color:var(--muted);margin-top:3px}
    .prod-cta{display:inline-flex;align-items:center;gap:4px;font-size:.72rem;font-weight:600;color:var(--teal);margin-top:8px;text-decoration:none}

    /* ── THREE AUDIENCE SECTIONS ── */
    .audience{background:var(--bg)}
    .aud-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    .aud-card{background:var(--white);border:1.5px solid var(--border);border-radius:16px;overflow:hidden;transition:box-shadow .3s,transform .3s}
    .aud-card:hover{box-shadow:0 8px 40px rgba(0,133,111,.1);transform:translateY(-6px)}
    .aud-header{padding:32px 28px 24px;border-bottom:1px solid var(--border)}
    .aud-badge{display:inline-flex;align-items:center;gap:6px;background:var(--teal-dim);color:var(--teal);padding:4px 12px;border-radius:100px;font-size:.68rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px}
    .aud-title{font-family:var(--display);font-size:1.3rem;font-weight:800;color:var(--ink);letter-spacing:-.03em;margin-bottom:8px}
    .aud-sub{font-size:.86rem;color:var(--muted);line-height:1.7}
    .aud-body{padding:24px 28px}
    .aud-feats{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
    .aud-feat{display:flex;align-items:flex-start;gap:10px;font-size:.85rem;color:var(--ink3)}
    .aud-check{width:18px;height:18px;border-radius:50%;background:var(--grn-dim);color:var(--grn);display:flex;align-items:center;justify-content:center;font-size:.56rem;font-weight:700;flex-shrink:0;margin-top:2px}
    .aud-cta{display:block;text-align:center;padding:12px;border-radius:10px;font-family:var(--display);font-size:.86rem;font-weight:700;text-decoration:none;transition:all .2s}
    .aud-cta-primary{background:var(--teal);color:#fff;box-shadow:0 2px 10px var(--teal-glo)}
    .aud-cta-primary:hover{background:var(--teal-lt)}
    .aud-cta-outline{border:1.5px solid var(--teal-bdr);color:var(--teal)}
    .aud-cta-outline:hover{background:var(--teal-dim)}

    /* ── NUMBERS ── */
    .numband{background:var(--teal);padding:72px 0}
    .num-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.15)}
    .num-item{background:transparent;padding:48px 36px;text-align:center}
    .num-val{font-family:var(--display);font-size:clamp(2.2rem,4vw,3.4rem);font-weight:800;color:#fff;line-height:1;margin-bottom:8px;letter-spacing:-.04em}
    .num-label{font-size:.72rem;color:rgba(255,255,255,.7);letter-spacing:.1em;text-transform:uppercase;font-weight:500}

    /* ── INSURER STRIP ── */
    .ins-strip{background:var(--white);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:32px 0}
    .ins-label{text-align:center;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);font-weight:500;margin-bottom:24px}
    .ins-track-wrap{overflow:hidden;position:relative}
    .ins-track-wrap::before,.ins-track-wrap::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none}
    .ins-track-wrap::before{left:0;background:linear-gradient(90deg,var(--white),transparent)}
    .ins-track-wrap::after{right:0;background:linear-gradient(-90deg,var(--white),transparent)}
    .ins-track2{display:inline-flex;gap:0;animation:tck 22s linear infinite}
    .ins-name{display:inline-flex;align-items:center;padding:0 28px;font-family:var(--display);font-size:.82rem;font-weight:700;color:rgba(13,17,23,.2);letter-spacing:-.01em;white-space:nowrap;border-right:1px solid var(--border)}
    @keyframes tck{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    /* ── TESTIMONIALS ── */
    .tst{background:var(--bg)}
    .tst-head{margin-bottom:52px}
    .tst-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .tst-card{background:var(--white);border:1.5px solid var(--border);border-radius:14px;padding:28px 24px;transition:box-shadow .25s,transform .25s}
    .tst-card:hover{box-shadow:0 6px 28px rgba(0,133,111,.09);transform:translateY(-3px)}
    .tst-stars{color:var(--amber);font-size:.85rem;letter-spacing:2px;margin-bottom:14px}
    .tst-quote{font-size:.88rem;color:var(--muted);line-height:1.78;font-style:italic;margin-bottom:20px}
    .tst-author{display:flex;align-items:center;gap:10px}
    .tst-av{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--teal),#00a8ff);display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;color:#fff;flex-shrink:0}
    .tst-name{font-weight:700;font-size:.84rem;color:var(--ink);display:block}
    .tst-role{font-size:.73rem;color:var(--muted);display:block;margin-top:1px}

    /* ── B2B SECTION ── */
    .b2b{background:var(--white);border-top:1px solid var(--border)}
    .b2b-inner{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
    .b2b-left .sec-title{margin-bottom:16px}
    .b2b-desc{font-size:.95rem;color:var(--muted);line-height:1.78;margin-bottom:32px}
    .b2b-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .b2b-card{background:var(--bg);border:1.5px solid var(--border);border-radius:12px;padding:20px}
    .b2b-card:hover{border-color:var(--teal-bdr);background:var(--teal-dim)}
    .b2b-card-title{font-family:var(--display);font-size:.88rem;font-weight:700;color:var(--ink);margin-bottom:5px}
    .b2b-card-sub{font-size:.78rem;color:var(--muted);line-height:1.6}
    .b2b-right{background:var(--bg2);border-radius:20px;padding:36px;display:flex;flex-direction:column;gap:14px}
    .b2b-stat{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between}
    .b2b-stat-label{font-size:.84rem;color:var(--muted)}
    .b2b-stat-val{font-family:var(--display);font-size:1.3rem;font-weight:800;color:var(--teal)}

    /* ── CTA BAND ── */
    .ctaband{background:var(--ink2);padding:88px 48px;display:flex;align-items:center;justify-content:space-between;gap:48px;position:relative;overflow:hidden}
    .ctaband::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 120% at 80% 50%,rgba(0,133,111,.15) 0%,transparent 70%)}
    .cta-text{position:relative;z-index:1}
    .cta-title{font-family:var(--display);font-size:clamp(1.8rem,3.5vw,3rem);font-weight:800;letter-spacing:-.04em;color:#fff;margin-bottom:10px}
    .cta-sub{font-size:.95rem;color:rgba(255,255,255,.55);max-width:460px}
    .cta-actions{position:relative;z-index:1;display:flex;gap:12px;flex-shrink:0}

    /* ── CONTACT ── */
    .contact{background:var(--bg);border-top:1px solid var(--border)}
    .contact-inner{display:grid;grid-template-columns:1fr 1.3fr;gap:72px;align-items:start;padding-top:96px;padding-bottom:96px}
    .contact-left .sec-title{margin-bottom:14px}
    .contact-desc{font-size:.92rem;color:var(--muted);line-height:1.78;margin-bottom:32px}
    .contact-channels{display:flex;flex-direction:column;gap:0}
    .cc-item{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--border);font-size:.86rem;color:var(--muted)}
    .cc-item:last-child{border-bottom:none}
    .cc-icon{width:34px;height:34px;border-radius:8px;background:var(--teal-dim);border:1px solid var(--teal-bdr);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
    .cc-info strong{display:block;color:var(--ink);font-size:.84rem;font-weight:600;margin-bottom:2px}
    .contact-form{background:var(--white);border:1.5px solid var(--border);border-radius:16px;padding:36px 32px;box-shadow:0 4px 24px rgba(13,17,23,.05)}
    .form-title{font-family:var(--display);font-size:1.2rem;font-weight:800;color:var(--ink);margin-bottom:4px;letter-spacing:-.02em}
    .form-sub{font-size:.82rem;color:var(--muted);margin-bottom:24px}
    .fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .fg{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
    .fg label{font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;font-weight:600;color:var(--dim)}
    .fg input,.fg textarea,.fg select{background:var(--bg);border:1.5px solid var(--border);color:var(--ink);padding:11px 14px;border-radius:8px;font-family:var(--body);font-size:.88rem;font-weight:400;outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
    .fg input::placeholder,.fg textarea::placeholder{color:var(--dim)}
    .fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--teal);box-shadow:0 0 0 3px var(--teal-dim)}
    .fg textarea{resize:vertical;min-height:100px}
    .form-submit{width:100%;background:var(--teal);color:#fff;border:none;padding:14px;border-radius:10px;font-family:var(--display);font-size:.9rem;font-weight:700;cursor:pointer;box-shadow:0 2px 14px var(--teal-glo);transition:background .2s,box-shadow .2s}
    .form-submit:hover{background:var(--teal-lt);box-shadow:0 4px 24px var(--teal-glo)}

    /* ── FOOTER ── */
    footer{background:var(--white);border-top:1px solid var(--border)}
    .ft-top{max-width:1200px;margin:0 auto;padding:64px 48px 48px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px}
    .ft-logo{display:flex;align-items:center;gap:9px;margin-bottom:12px}
    .ft-lm{width:28px;height:28px;border-radius:8px;background:var(--teal);display:flex;align-items:center;justify-content:center}
    .ft-lt{font-family:var(--display);font-size:1rem;font-weight:800;letter-spacing:-.03em;color:var(--ink)}
    .ft-lt span{color:var(--teal)}
    .ft-tagline{font-size:.84rem;color:var(--muted);line-height:1.7;max-width:220px;margin-bottom:14px}
    .ft-discl{font-size:.7rem;color:var(--dim);line-height:1.65;border-top:1px solid var(--border);padding-top:12px}
    .ft-col-title{font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:var(--dim);margin-bottom:16px}
    .ft-links{list-style:none;display:flex;flex-direction:column;gap:9px}
    .ft-links a{font-size:.85rem;color:var(--muted);text-decoration:none;font-weight:400;transition:color .2s}
    .ft-links a:hover{color:var(--teal)}
    .ft-bot{border-top:1px solid var(--border);max-width:1200px;margin:0 auto;padding:20px 48px;display:flex;justify-content:space-between;align-items:center;font-size:.74rem;color:var(--dim)}
    .ft-bot-links{display:flex;gap:16px}
    .ft-bot-links a{color:var(--dim);text-decoration:none;transition:color .2s}
    .ft-bot-links a:hover{color:var(--muted)}

    /* ── RESPONSIVE ── */
    @media(max-width:1024px){
      .ctn{padding:0 28px}.nav{padding:0 28px}
      .hero-inner{grid-template-columns:1fr;padding:64px 28px 0}.hero-right{display:grid;grid-template-columns:1fr 1fr;gap:12px}
      .hero-stat-cards{grid-template-columns:1fr 1fr}
      .aud-grid{grid-template-columns:1fr 1fr}.aud-card:last-child{grid-column:span 2}
      .num-grid{grid-template-columns:repeat(2,1fr)}
      .tst-grid{grid-template-columns:1fr 1fr}.tst-card:last-child{display:none}
      .b2b-inner{grid-template-columns:1fr;gap:40px}
      .contact-inner{grid-template-columns:1fr;gap:40px}
      .ft-top{grid-template-columns:1fr 1fr;padding:48px 28px 36px}.ft-bot{padding:16px 28px}
      .ctaband{padding:72px 28px;flex-direction:column;align-items:flex-start}
      .trust-strip{padding:20px 28px}
    }
    @media(max-width:640px){
      .nav-links{display:none}.nav{padding:0 20px}
      .hero-inner{padding:60px 20px 0}.hero-right{grid-template-columns:1fr}
      .hero-stat-cards{grid-template-columns:1fr 1fr}
      .hero-ctas{flex-direction:column;align-items:flex-start}
      .ctn{padding:0 20px}
      .prod-grid{grid-template-columns:repeat(3,1fr)}
      .aud-grid{grid-template-columns:1fr}.aud-card:last-child{grid-column:auto}
