<%
  // ── SAFE LOCALS (Round D — NBFC) ──────────────────────────────
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);
  const bn      = esc(L.businessName) || 'Meridian Capital';
  const tagln   = esc(L.tagline)      || 'Honest lending. Transparent rates. Fast decisions.';
  const accent  = L.primaryColor      || '#e85d2c';
  const year    = L.year              || new Date().getFullYear();
  const founded = esc(L.foundedYear)  || '2012';

  // Compliance bar
  const rbiRegNumberV          = def(L.rbiRegNumber, 'B-13.02345');
  const cinV                   = def(L.cin, 'U65923MH2012PTC230456');
  const nbfcCategoryV          = def(L.nbfcCategory, 'NBFC-ICC (Investment & Credit Co.)');
  const mitcLinkLabelV         = def(L.mitcLinkLabel, 'Most Important T&Cs');
  const fairPracticeLinkLabelV = def(L.fairPracticeLinkLabel, 'Fair Practice Code');
  const grievanceLinkLabelV    = def(L.grievanceLinkLabel, 'Grievance Redressal');
  const sachetLinkLabelV       = def(L.sachetLinkLabel, 'Report unauthorised entity (Sachet)');

  // Hero
  const heroEyebrowV         = def(L.heroEyebrow,        `RBI Registered NBFC since ${founded}`);
  const heroHeadlineLeadV    = def(L.heroHeadlineLead,   'Loans built');
  const heroHeadlineBodyV    = def(L.heroHeadlineBody,   'around');
  const heroHeadlineEmphV    = def(L.heroHeadlineEmph,   'your life.');
  const heroSubV             = def(L.heroSub,
    'Personal, business, gold and home loans designed for real Indian customers — sanctioned in hours, disbursed in days, priced transparently.');
  const heroCtaPrimaryV      = def(L.heroCtaPrimary,     'Apply Now');
  const heroCtaSecondaryV    = def(L.heroCtaSecondary,   'Calculate EMI');
  const heroRatePanelTitleV  = def(L.heroRatePanelTitle, 'Starting at');
  const heroRatePanelProductV= def(L.heroRatePanelProduct,'Personal Loan');
  const heroRateValueV       = def(L.heroRateValue,      '10.99%');
  const heroRateUnitV        = def(L.heroRateUnit,       'p.a.* onwards');
  const heroRateBenefitsList = (Array.isArray(L.heroRateBenefits) && L.heroRateBenefits.length)
    ? L.heroRateBenefits
    : [
        { icon:'✓', text:'No collateral required' },
        { icon:'✓', text:'Decision in 30 minutes' },
        { icon:'✓', text:'Loans up to ₹40 Lakhs' },
        { icon:'✓', text:'Tenure up to 60 months' }
      ];

  // Trust strip
  const trustBadgesList = (Array.isArray(L.trustBadges) && L.trustBadges.length)
    ? L.trustBadges
    : [
        { icon:'🏛', label:'RBI Regulated' },
        { icon:'★',  label:'CRISIL AA / Stable' },
        { icon:'🔒', label:'ISO 27001 Certified' },
        { icon:'⏱',  label:'Decision in 30 mins' },
        { icon:'📍', label:'200+ branches' },
        { icon:'⚖',  label:'Fair Practice Code' }
      ];

  // Products
  const productsLabelV    = def(L.productsLabel,    'What We Offer');
  const productsHeadlineV = def(L.productsHeadline, 'Lending solutions for every life stage.');
  const productsBodyV     = def(L.productsBody,
    'Salary advance, business expansion, gold pledge, home purchase — whatever the need, our products are priced honestly and approved on merit.');
  const productsList = (Array.isArray(L.products) && L.products.length && (L.products[0].name || L.products[0].title))
    ? L.products
    : [
        { icon:'💼', name:'Personal Loan',   body:'Unsecured loans for life events, medical, or travel.',                       amountRange:'₹50K – ₹40L',  rateFrom:'10.99%', tenure:'12–60 months' },
        { icon:'🏢', name:'Business Loan',   body:'Working capital and term loans for SMEs and proprietors.',                  amountRange:'₹2L – ₹2 Cr',   rateFrom:'14.50%', tenure:'12–84 months' },
        { icon:'🪙', name:'Gold Loan',       body:'Same-day disbursal against gold ornaments — lowest market rates.',          amountRange:'₹25K – ₹50L',  rateFrom:'9.25%',  tenure:'3–36 months' },
        { icon:'🏠', name:'Home Loan',       body:'Floating-rate home loans with 30-year tenure and no foreclosure penalty.', amountRange:'₹5L – ₹5 Cr',   rateFrom:'8.45%',  tenure:'5–30 years' },
        { icon:'🚗', name:'Vehicle Loan',    body:'New and pre-owned cars and two-wheelers, sanctioned at the dealership.',     amountRange:'₹50K – ₹50L',  rateFrom:'9.99%',  tenure:'12–84 months' },
        { icon:'🧾', name:'Loan Against Property', body:'Mortgage your residential or commercial property for business or personal needs.', amountRange:'₹10L – ₹5 Cr', rateFrom:'10.50%', tenure:'5–15 years' }
      ];

  // Eligibility & docs
  const eligibilityLabelV    = def(L.eligibilityLabel,    'Eligibility & Documents');
  const eligibilityHeadlineV = def(L.eligibilityHeadline, 'Simple eligibility. Honest documentation list.');
  const eligibilityCriteriaList = (Array.isArray(L.eligibilityCriteria) && L.eligibilityCriteria.length)
    ? L.eligibilityCriteria
    : [
        { icon:'🎂', title:'Age 21 – 65 years',          body:'You must be a resident Indian aged between 21 and 65 at loan maturity.' },
        { icon:'💰', title:'Minimum income ₹25,000/mo',  body:'Salaried applicants need a minimum monthly take-home of ₹25,000.' },
        { icon:'📈', title:'Credit score 700+',          body:'A CIBIL score of 700 or above improves both approval odds and your interest rate.' },
        { icon:'🏢', title:'2+ years employment',        body:'Total work experience of 2 years, with at least 6 months at the current employer.' }
      ];
  const documentsListList = (Array.isArray(L.documentsList) && L.documentsList.length)
    ? L.documentsList
    : [
        { category:'Salaried',      items:'PAN card, Aadhaar, latest 3 salary slips, 6-month bank statement, latest Form 16' },
        { category:'Self-employed', items:'PAN, Aadhaar, business proof (GST/Udyam/Shop Act), 2-year ITR with computation, 12-month bank statement' }
      ];

  // Process
  const processLabelV    = def(L.processLabel,    'How To Apply');
  const processHeadlineV = def(L.processHeadline, 'From apply to disbursal in days.');
  const processStepsList = (Array.isArray(L.processSteps) && L.processSteps.length)
    ? L.processSteps
    : [
        { icon:'📝', title:'Apply Online',         body:'Fill basic details and upload documents from your phone or laptop.',                duration:'5 minutes' },
        { icon:'🔍', title:'Soft Credit Check',     body:'A non-affecting CIBIL pull and quick eligibility verification.',                    duration:'Within 30 mins' },
        { icon:'📋', title:'Sanction & Agreement',  body:'You receive the sanction letter, key fact statement, and digital agreement.',       duration:'Within 24 hours' },
        { icon:'💸', title:'Disbursal',             body:'Funds credited to your bank account once the agreement is e-signed and KYC is done.', duration:'Within 48 hours' }
      ];

  // Charges
  const chargesLabelV    = def(L.chargesLabel,    'Rates & Charges');
  const chargesHeadlineV = def(L.chargesHeadline, 'What it actually costs. No fine print.');
  const chargesBodyV     = def(L.chargesBody,
    'RBI requires NBFCs to publish their interest rate ranges and fees clearly. Here are ours — applicable charges depend on credit assessment, product, and tenure.');
  const rateRowsList = (Array.isArray(L.rateRows) && L.rateRows.length)
    ? L.rateRows
    : [
        { product:'Personal Loan',          rate:'10.99% – 24% p.a.', processingFee:'Up to 2% + GST',      prepaymentCharge:'Nil after 6 EMIs' },
        { product:'Business Loan',          rate:'14.50% – 22% p.a.', processingFee:'Up to 2.5% + GST',    prepaymentCharge:'4% in 1st year, then nil' },
        { product:'Home Loan (Floating)',   rate:'8.45% – 12% p.a.',  processingFee:'Up to 1% + GST',       prepaymentCharge:'Nil for floating-rate' },
        { product:'Loan Against Property',  rate:'10.50% – 14% p.a.', processingFee:'Up to 1.5% + GST',    prepaymentCharge:'Nil after 12 EMIs' },
        { product:'Gold Loan',              rate:'9.25% – 18% p.a.',  processingFee:'₹500 flat',            prepaymentCharge:'Nil' },
        { product:'Vehicle Loan',           rate:'9.99% – 16% p.a.',  processingFee:'Up to 1% + GST',       prepaymentCharge:'2% on outstanding' }
      ];
  const chargesNoteV = def(L.chargesNote,
    '* Final rate is determined by credit assessment, loan amount, tenure, and product type. Other charges (stamp duty, GST, late payment fees) apply as per the sanction letter and Most Important T&Cs. T&C apply.');

  // Numbers
  const numberStatsList = (Array.isArray(L.numberStats) && L.numberStats.length)
    ? L.numberStats
    : [
        { value:'12,400', suffix:'Cr+', label:`Disbursed since ${founded}` },
        { value:'5',       suffix:'L+',  label:'Customers served' },
        { value:'200',     suffix:'+',   label:'Branches & service points' },
        { value:'15',      suffix:'Yr',  label:'In operation' }
      ];

  // About
  const aboutLabelV        = def(L.aboutLabel,        'Our Story');
  const aboutHeadlineLeadV = def(L.aboutHeadlineLead, 'Lending built on');
  const aboutHeadlineEmphV = def(L.aboutHeadlineEmph, 'trust.');
  const aboutBodyV         = def(L.aboutBody || L.about,
    'Founded in ' + founded + ', ' + bn + ' is a registered NBFC serving Indian families and small businesses across 200+ branches. We are RBI-regulated, CRISIL AA / Stable rated, and have disbursed over ₹12,400 Cr without a single regulatory adverse action. Our lending philosophy is simple: honest pricing, fast decisions, and a relationship manager you can actually reach by phone.');
  const aboutPillarsList = (Array.isArray(L.aboutPillars) && L.aboutPillars.length)
    ? L.aboutPillars
    : [
        { title:'Transparent Pricing', body:'Every fee is published on our site and explained in the sanction letter. No hidden charges, ever.' },
        { title:'Fair Practice Code',   body:'Our staff are trained on RBI Fair Practice guidelines. Recovery is professional and dignified.' },
        { title:'Customer First',       body:'Dedicated relationship manager from sanction to closure — no call-tree, no off-shore support.' }
      ];
  const ratingsList = (Array.isArray(L.ratings) && L.ratings.length)
    ? L.ratings
    : [
        { label:'RBI Registered NBFC' }, { label:'CRISIL AA / Stable' }, { label:'ICRA AA-' },
        { label:'ISO 27001 Certified' }, { label:'CKYC Compliant' }, { label:'AMFI Registered' }
      ];

  // Testimonials
  const testimonialsList = (Array.isArray(L.testimonials) && L.testimonials.length)
    ? L.testimonials
    : [
        { quote:'I got my home loan disbursed in 9 days flat. The RM kept me posted at every stage — no chasing, no surprises, no hidden fees at the end.', name:'Rohit Kapoor',     role:'Mumbai',    productUsed:'Home Loan · 2024' },
        { quote:'Working capital line that actually scales with our seasonal business. Our previous bank could never figure it out — Meridian got it from week one.', name:'Anil Gupta',  role:'Surat',     productUsed:'Business Loan · ₹40L' },
        { quote:'Three FD-backed gold loan renewals over four years. Same RM each time, same rate transparency. That kind of consistency is rare.',          name:'Mrs. Lakshmi Iyer', role:'Chennai',  productUsed:'Gold Loan customer' }
      ];

  // Grievance
  const grievanceLabelV    = def(L.grievanceLabel,    'Customer Care · Grievance Redressal');
  const grievanceHeadlineV = def(L.grievanceHeadline, 'We hear you. And we resolve fast.');
  const grievanceBodyV     = def(L.grievanceBody,
    `As an RBI-regulated NBFC, ${bn} maintains a clear three-tier grievance redressal mechanism. Most issues are resolved at the branch level within 7 working days. If unresolved, the matter escalates to our Principal Nodal Officer and then, if still unresolved, to the RBI Ombudsman.`);
  const groNameV     = def(L.groName,     'Ms. Anjali Mehra');
  const groRoleV     = def(L.groRole,     'Principal Nodal Officer');
  const groEmailV    = def(L.groEmail,    'grievance@meridiancapital.in');
  const groPhoneV    = def(L.groPhone,    '+91 22 6789 4500');
  const groAddressV  = def(L.groAddress,  bn + ', 4th Floor, Meridian Tower, Bandra Kurla Complex, Mumbai 400051');
  const groTimingsV  = def(L.groTimings,  'Mon–Fri · 10:00 AM – 6:00 PM IST');
  const escalationLevelsList = (Array.isArray(L.escalationLevels) && L.escalationLevels.length)
    ? L.escalationLevels
    : [
        { level:'Level 1 · Branch / Customer Care',     body:'Walk in to your branch or call our customer care for any service or product issue.', contact:'1800 200 5000 · care@meridiancapital.in', tat:'Within 7 days' },
        { level:'Level 2 · Principal Nodal Officer',    body:'If unresolved within 7 days, escalate in writing to our Principal Nodal Officer (GRO).', contact:'grievance@meridiancapital.in',           tat:'Within 14 days' },
        { level:'Level 3 · RBI Ombudsman / Sachet',     body:'If unresolved within 30 days, file a complaint with the RBI Ombudsman or report on the Sachet portal.', contact:'cms.rbi.org.in · sachet.rbi.org.in',     tat:'As per RBI scheme' }
      ];

  // CTA
  const ctaHeadlineV = def(L.ctaHeadline, 'Get a pre-approved offer in 60 seconds.');
  const ctaBodyV     = def(L.ctaBody,     'Soft credit check that does not affect your CIBIL score. No commitment to proceed. No spam, ever.');
  const ctaButtonV   = def(L.ctaButton,   'Check Eligibility');
  const ctaNoteV     = def(L.ctaNote,     'Soft credit check · Will not affect your CIBIL score');

  // Contact perks
  const contactPerksList = (Array.isArray(L.contactPerks) && L.contactPerks.length)
    ? L.contactPerks
    : [
        { icon:'⏱', text:'Decision in 30 minutes, disbursal in 48 hours' },
        { icon:'✓', text:'Soft credit check — will not affect your CIBIL' },
        { icon:'☎', text:'Dedicated relationship manager from sanction to closure' },
        { icon:'🛡', text:'No commission-driven pushing — you only pay for what you need' }
      ];

  // Helpers
  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1,2);
    return (a + b).toUpperCase();
  }
  function splitItems(s) {
    return String(s || '').split(/[,،]/).map(x => x.trim()).filter(Boolean);
  }
  const emailV   = esc(L.email)   || 'hello@meridiancapital.in';
  const phoneV   = esc(L.phone)   || '+91 22 6789 4500';
  const addressV = esc(L.address) || 'Meridian Tower, Bandra Kurla Complex\nMumbai, Maharashtra 400051';
  const hoursV   = esc(L.hours)   || 'Mon–Sat · 9:30am–6:30pm IST';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bn %> — <%= tagln %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:           #fbf7f0;
      --bg-card:      #ffffff;
      --ink:          #0e1c2a;
      --ink-soft:     rgba(14,28,42,.7);
      --ink-mute:     rgba(14,28,42,.5);
      --ink-line:     rgba(14,28,42,.08);
      --ink-line-md:  rgba(14,28,42,.14);
      --teal:         #0c4a4a;
      --teal-soft:    #0f5e5e;
      --teal-tint:    rgba(12,74,74,.08);
      --gold:         #c4942a;
      --orange:       <%= accent %>;
      --orange-tint:  rgba(232,93,44,.1);
      --green:        #1b7a48;
      --serif:        'Fraunces', Georgia, serif;
      --sans:         'Inter', system-ui, -apple-system, sans-serif;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--bg);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none}
    em{font-style:italic;font-family:var(--serif);font-weight:500}

    .container{max-width:1240px;margin:0 auto;padding:0 32px}
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── COMPLIANCE TOPBAR */
    .topbar{
      background:var(--teal);color:#e9efef;
      font-size:.74rem;letter-spacing:.01em;
      padding:9px 0;
    }
    .topbar-inner{
      display:flex;align-items:center;justify-content:space-between;gap:22px;flex-wrap:wrap;
      max-width:1240px;margin:0 auto;padding:0 32px;
    }
    .topbar-info{display:flex;gap:18px;flex-wrap:wrap;align-items:center}
    .topbar-info span{display:inline-flex;align-items:center;gap:6px}
    .topbar-info b{font-weight:600;color:#fff}
    .topbar-links{display:flex;gap:18px;flex-wrap:wrap}
    .topbar-links a{color:rgba(233,239,239,.85);transition:color .2s}
    .topbar-links a:hover{color:#fff;text-decoration:underline}

    /* ── NAV */
    .nav{
      position:sticky;top:0;z-index:50;
      background:rgba(251,247,240,.92);
      backdrop-filter:blur(14px);
      border-bottom:1px solid var(--ink-line);
    }
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 0}
    .brand{display:flex;align-items:center;gap:12px;font-family:var(--serif);font-size:1.4rem;font-weight:600;letter-spacing:-.01em;color:var(--teal)}
    .brand-mark{
      width:38px;height:38px;border-radius:8px;
      background:linear-gradient(135deg,var(--teal),var(--teal-soft));
      color:#fff;display:flex;align-items:center;justify-content:center;
      font-family:var(--serif);font-weight:700;font-size:1.1rem;
    }
    .nav-links{display:flex;gap:30px;align-items:center;list-style:none}
    .nav-links a{color:var(--ink-soft);font-size:.93rem;font-weight:500;transition:color .2s}
    .nav-links a:hover{color:var(--teal)}
    .nav-links .nav-cta{
      background:var(--orange);color:#fff;padding:10px 20px;border-radius:6px;
      transition:background .2s,transform .15s
    }
    .nav-links .nav-cta:hover{background:#d44e1f;color:#fff}

    /* ── HERO */
    .hero{padding:80px 0 96px;position:relative;overflow:hidden}
    .hero::before{
      content:'';position:absolute;top:-180px;right:-220px;
      width:520px;height:520px;border-radius:50%;
      background:radial-gradient(circle,var(--orange-tint) 0%,transparent 70%);
      pointer-events:none;
    }
    .hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:64px;align-items:center;position:relative}
    .hero-eyebrow{
      display:inline-flex;align-items:center;gap:8px;
      font-size:.78rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;
      color:var(--teal);background:var(--teal-tint);
      padding:8px 14px;border-radius:100px;margin-bottom:28px
    }
    .hero-eyebrow::before{content:'●';color:var(--green);font-size:.7rem}
    .hero-title{
      font-family:var(--serif);font-weight:600;
      font-size:clamp(2.4rem,5vw,4.6rem);line-height:1.05;letter-spacing:-.02em;
      color:var(--ink);margin-bottom:20px;
    }
    .hero-title em{color:var(--orange);font-weight:600}
    .hero-sub{font-size:1.05rem;color:var(--ink-soft);max-width:540px;margin-bottom:36px;line-height:1.7}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:8px;font-size:.93rem;font-weight:600;letter-spacing:.01em;transition:transform .15s,box-shadow .2s,background .2s,color .2s}
    .btn:hover{transform:translateY(-1px)}
    .btn-primary{background:var(--orange);color:#fff;box-shadow:0 8px 22px rgba(232,93,44,.28)}
    .btn-primary:hover{background:#d44e1f;color:#fff;box-shadow:0 12px 28px rgba(232,93,44,.36)}
    .btn-ghost{background:transparent;color:var(--teal);border:1.5px solid var(--ink-line-md)}
    .btn-ghost:hover{background:var(--teal);color:#fff;border-color:var(--teal)}
    .btn-dark{background:var(--ink);color:#fff}
    .btn-dark:hover{background:#1f3144;color:#fff}

    /* Rate panel */
    .rate-panel{
      background:var(--bg-card);
      border:1px solid var(--ink-line);
      border-radius:18px;padding:32px;
      box-shadow:0 18px 50px -20px rgba(14,28,42,.18);
      position:relative;
    }
    .rate-panel::before{
      content:'';position:absolute;top:-1px;left:24px;right:24px;height:3px;
      background:linear-gradient(90deg,var(--teal),var(--orange));
      border-radius:0 0 4px 4px;
    }
    .rate-title{font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:8px}
    .rate-product{font-family:var(--serif);font-size:1.1rem;font-weight:600;color:var(--ink);margin-bottom:14px}
    .rate-value{font-family:var(--serif);font-size:4rem;font-weight:600;line-height:1;color:var(--teal);letter-spacing:-.02em}
    .rate-value sup{font-size:1rem;color:var(--orange);font-weight:600;vertical-align:super}
    .rate-unit{font-size:.92rem;color:var(--ink-soft);margin-top:6px;margin-bottom:24px}
    .rate-benefits{display:flex;flex-direction:column;gap:10px;border-top:1px solid var(--ink-line);padding-top:20px}
    .rate-benefit{display:flex;align-items:center;gap:10px;font-size:.92rem;color:var(--ink)}
    .rate-benefit-ico{width:22px;height:22px;border-radius:50%;background:var(--teal-tint);color:var(--teal);display:flex;align-items:center;justify-content:center;font-size:.78rem;font-weight:700;flex-shrink:0}

    /* ── TRUST STRIP */
    .trust-strip{background:var(--ink);color:#fff;padding:22px 0}
    .trust-grid{display:flex;justify-content:space-around;gap:24px;flex-wrap:wrap}
    .trust-badge{display:flex;align-items:center;gap:10px;font-size:.88rem;font-weight:500;color:rgba(255,255,255,.85)}
    .trust-badge .ti{font-size:1.1rem}

    /* ── SECTION HEAD */
    .section-pad{padding:96px 0}
    .section-head{text-align:left;max-width:760px;margin-bottom:56px}
    .section-head.center{margin-left:auto;margin-right:auto;text-align:center}
    .section-eyebrow{font-size:.78rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:14px}
    .section-title{font-family:var(--serif);font-size:clamp(1.9rem,3.6vw,3rem);font-weight:600;line-height:1.15;letter-spacing:-.015em;color:var(--ink);margin-bottom:14px}
    .section-title em{color:var(--orange)}
    .section-body{font-size:1rem;color:var(--ink-soft);line-height:1.75;max-width:680px}

    /* ── PRODUCTS */
    .products{background:var(--bg)}
    .products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:22px}
    .product-card{
      background:var(--bg-card);border:1px solid var(--ink-line);border-radius:14px;
      padding:30px 28px;transition:transform .25s,border-color .25s,box-shadow .25s;
      display:flex;flex-direction:column
    }
    .product-card:hover{transform:translateY(-4px);border-color:var(--teal);box-shadow:0 22px 48px -22px rgba(12,74,74,.28)}
    .product-icon{width:46px;height:46px;border-radius:10px;background:var(--teal-tint);color:var(--teal);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:18px}
    .product-name{font-family:var(--serif);font-size:1.3rem;font-weight:600;color:var(--ink);margin-bottom:8px}
    .product-body{font-size:.9rem;color:var(--ink-soft);line-height:1.65;margin-bottom:22px;flex:1}
    .product-meta{border-top:1px dashed var(--ink-line-md);padding-top:18px;display:grid;gap:10px}
    .product-meta-row{display:flex;justify-content:space-between;align-items:baseline;gap:12px;font-size:.85rem}
    .pm-label{color:var(--ink-mute);font-weight:500}
    .pm-value{color:var(--ink);font-weight:600;font-family:var(--serif)}
    .pm-value.rate{color:var(--orange)}

    /* ── ELIGIBILITY / DOCS */
    .elig-wrap{background:var(--bg-card);border-top:1px solid var(--ink-line);border-bottom:1px solid var(--ink-line)}
    .elig-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px}
    .elig-list{display:flex;flex-direction:column;gap:16px}
    .elig-item{display:flex;gap:16px;padding:18px;border:1px solid var(--ink-line);border-radius:12px;background:var(--bg)}
    .elig-icon{width:42px;height:42px;border-radius:8px;background:var(--orange-tint);color:var(--orange);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
    .elig-title{font-family:var(--serif);font-size:1.05rem;font-weight:600;color:var(--ink);margin-bottom:4px}
    .elig-body{font-size:.88rem;color:var(--ink-soft);line-height:1.6}
    .doc-block{background:var(--bg);border:1px solid var(--ink-line);border-radius:12px;padding:20px;margin-bottom:14px}
    .doc-cat{font-family:var(--serif);font-weight:600;color:var(--teal);font-size:1rem;margin-bottom:10px;display:flex;align-items:center;gap:8px}
    .doc-cat::before{content:'📁';font-size:1rem}
    .doc-items{display:flex;flex-wrap:wrap;gap:8px}
    .doc-pill{
      background:var(--teal-tint);color:var(--teal);
      font-size:.8rem;font-weight:500;padding:5px 11px;border-radius:100px;
    }

    /* ── PROCESS */
    .process{background:var(--bg)}
    .process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;position:relative}
    .process-grid::before{
      content:'';position:absolute;top:46px;left:8%;right:8%;height:2px;
      background:repeating-linear-gradient(90deg,var(--ink-line-md) 0 6px,transparent 6px 12px);
      z-index:0
    }
    .process-step{position:relative;z-index:1;text-align:center;padding:0 8px}
    .process-icon{
      width:96px;height:96px;border-radius:50%;
      background:var(--bg-card);border:2px solid var(--teal);
      color:var(--teal);font-size:2rem;
      display:flex;align-items:center;justify-content:center;
      margin:0 auto 22px;position:relative
    }
    .process-num{
      position:absolute;top:-6px;right:-6px;
      width:28px;height:28px;border-radius:50%;
      background:var(--orange);color:#fff;
      font-family:var(--serif);font-weight:600;font-size:.85rem;
      display:flex;align-items:center;justify-content:center
    }
    .process-title{font-family:var(--serif);font-size:1.15rem;font-weight:600;color:var(--ink);margin-bottom:8px}
    .process-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;max-width:240px;margin:0 auto 14px}
    .process-duration{
      display:inline-block;font-size:.74rem;font-weight:600;letter-spacing:.05em;
      color:var(--green);background:rgba(27,122,72,.1);
      padding:5px 12px;border-radius:100px;text-transform:uppercase
    }

    /* ── CHARGES */
    .charges{background:var(--bg-card);border-top:1px solid var(--ink-line)}
    .charges-table-wrap{border:1px solid var(--ink-line);border-radius:14px;overflow:hidden;background:var(--bg);overflow-x:auto}
    .charges-table{width:100%;border-collapse:collapse;min-width:720px}
    .charges-table thead{background:var(--teal);color:#fff}
    .charges-table th{padding:18px 22px;text-align:left;font-size:.78rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase}
    .charges-table tbody tr{border-top:1px solid var(--ink-line)}
    .charges-table tbody tr:nth-child(even){background:var(--bg)}
    .charges-table td{padding:18px 22px;font-size:.92rem;color:var(--ink);vertical-align:top}
    .charges-table .ct-product{font-family:var(--serif);font-weight:600;color:var(--ink)}
    .charges-table .ct-rate{color:var(--orange);font-weight:600;font-family:var(--serif)}
    .charges-note{font-size:.82rem;color:var(--ink-mute);margin-top:18px;line-height:1.7;font-style:italic}

    /* ── NUMBERS */
    .numbers{background:var(--teal);color:#fff;padding:80px 0;position:relative;overflow:hidden}
    .numbers::before{
      content:'';position:absolute;bottom:-200px;left:-200px;width:520px;height:520px;border-radius:50%;
      background:radial-gradient(circle,rgba(255,255,255,.05) 0%,transparent 70%)
    }
    .numbers-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;position:relative}
    .num-item{text-align:center;padding:0 14px}
    .num-val{font-family:var(--serif);font-size:clamp(2.4rem,4.5vw,3.6rem);font-weight:600;color:#fff;letter-spacing:-.02em;line-height:1;margin-bottom:10px}
    .num-suf{color:var(--gold);font-weight:600}
    .num-label{font-size:.86rem;color:rgba(255,255,255,.78);font-weight:400;letter-spacing:.02em}

    /* ── ABOUT */
    .about{background:var(--bg)}
    .about-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:64px;align-items:start}
    .about-body{font-size:1rem;color:var(--ink-soft);line-height:1.85;margin-bottom:32px}
    .about-pillars{display:grid;gap:18px}
    .pillar{
      display:flex;gap:16px;padding:18px;border-radius:12px;
      background:var(--bg-card);border:1px solid var(--ink-line)
    }
    .pillar-num{
      width:32px;height:32px;border-radius:6px;flex-shrink:0;
      background:var(--orange);color:#fff;
      display:flex;align-items:center;justify-content:center;
      font-family:var(--serif);font-weight:700;font-size:.92rem
    }
    .pillar-title{font-family:var(--serif);font-weight:600;font-size:1.05rem;margin-bottom:5px;color:var(--ink)}
    .pillar-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65}
    .ratings-card{
      background:var(--bg-card);border:1px solid var(--ink-line);border-radius:14px;padding:30px;
      box-shadow:0 12px 30px -16px rgba(14,28,42,.12)
    }
    .ratings-title{font-family:var(--serif);font-size:1.4rem;font-weight:600;color:var(--ink);margin-bottom:6px}
    .ratings-sub{font-size:.86rem;color:var(--ink-mute);margin-bottom:22px}
    .ratings-list{display:flex;flex-wrap:wrap;gap:10px}
    .rating-pill{
      background:var(--teal-tint);color:var(--teal);
      font-size:.82rem;font-weight:600;padding:8px 14px;border-radius:8px;
      display:inline-flex;align-items:center;gap:6px
    }
    .rating-pill::before{content:'★';color:var(--gold)}

    /* ── TESTIMONIALS */
    .testi{background:var(--bg-card);border-top:1px solid var(--ink-line)}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:22px}
    .testi-card{background:var(--bg);border:1px solid var(--ink-line);border-radius:14px;padding:28px;display:flex;flex-direction:column}
    .testi-product{font-size:.74rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--orange);margin-bottom:16px}
    .testi-quote{font-family:var(--serif);font-size:1.02rem;color:var(--ink);line-height:1.65;margin-bottom:22px;flex:1}
    .testi-author{display:flex;align-items:center;gap:12px;border-top:1px solid var(--ink-line);padding-top:18px}
    .testi-avatar{
      width:44px;height:44px;border-radius:50%;
      background:linear-gradient(135deg,var(--teal),var(--teal-soft));color:#fff;
      display:flex;align-items:center;justify-content:center;
      font-family:var(--serif);font-weight:600;font-size:.95rem;flex-shrink:0
    }
    .testi-name{display:block;font-weight:600;color:var(--ink);font-size:.95rem}
    .testi-role{display:block;font-size:.82rem;color:var(--ink-mute);margin-top:2px}

    /* ── GRIEVANCE */
    .grievance{background:var(--bg);border-top:1px solid var(--ink-line)}
    .gv-card{background:var(--bg-card);border:1px solid var(--ink-line-md);border-radius:18px;padding:48px;box-shadow:0 18px 48px -22px rgba(14,28,42,.16)}
    .gv-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
    .gv-officer{background:var(--teal);color:#fff;border-radius:14px;padding:30px;position:sticky;top:100px}
    .gv-officer-eyebrow{font-size:.74rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
    .gv-officer-name{font-family:var(--serif);font-size:1.5rem;font-weight:600;margin-bottom:4px}
    .gv-officer-role{color:rgba(255,255,255,.78);font-size:.93rem;margin-bottom:24px}
    .gv-info{display:grid;gap:14px;padding-top:22px;border-top:1px solid rgba(255,255,255,.14)}
    .gv-info-row{display:grid;grid-template-columns:80px 1fr;gap:14px;font-size:.88rem}
    .gv-info-key{color:rgba(255,255,255,.6);font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:.74rem;padding-top:2px}
    .gv-info-val{color:#fff;line-height:1.55;word-break:break-word}
    .gv-escalation{display:flex;flex-direction:column;gap:14px}
    .gv-step{
      background:var(--bg);border:1px solid var(--ink-line);border-left:4px solid var(--orange);
      border-radius:10px;padding:20px 22px
    }
    .gv-step-head{display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:8px}
    .gv-level{font-family:var(--serif);font-size:1rem;font-weight:600;color:var(--teal)}
    .gv-tat{font-size:.74rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--green);background:rgba(27,122,72,.1);padding:4px 10px;border-radius:100px}
    .gv-step-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;margin-bottom:10px}
    .gv-step-contact{font-size:.85rem;color:var(--ink);font-weight:500;font-family:'JetBrains Mono',ui-monospace,monospace;background:var(--teal-tint);padding:8px 12px;border-radius:6px;display:inline-block;color:var(--teal)}

    /* ── CTA BAND */
    .cta-band{background:var(--ink);color:#fff;padding:80px 0;position:relative;overflow:hidden}
    .cta-band::before{
      content:'';position:absolute;right:-180px;top:-180px;width:520px;height:520px;border-radius:50%;
      background:radial-gradient(circle,rgba(232,93,44,.18) 0%,transparent 70%)
    }
    .cta-inner{display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:center;position:relative}
    .cta-title{font-family:var(--serif);font-size:clamp(1.7rem,3vw,2.6rem);font-weight:600;line-height:1.2;color:#fff;margin-bottom:14px;letter-spacing:-.015em}
    .cta-sub{color:rgba(255,255,255,.78);font-size:1rem;line-height:1.65;max-width:540px}
    .cta-actions{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .cta-note{font-size:.78rem;color:rgba(255,255,255,.5)}

    /* ── CONTACT */
    .contact{background:var(--bg);border-top:1px solid var(--ink-line)}
    .contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:64px;align-items:start}
    .contact-perks{display:flex;flex-direction:column;gap:14px;margin-top:30px}
    .cperk{display:flex;gap:12px;font-size:.93rem;color:var(--ink);line-height:1.55}
    .cperk-ico{width:24px;height:24px;border-radius:50%;background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;flex-shrink:0;margin-top:2px}
    .contact-info{margin-top:32px;padding-top:24px;border-top:1px dashed var(--ink-line-md);display:grid;gap:10px;font-size:.9rem;color:var(--ink-soft)}
    .contact-info b{color:var(--ink);font-weight:600}

    .form-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:14px;padding:36px;box-shadow:0 16px 40px -22px rgba(14,28,42,.12)}
    .fg{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
    .fg label{font-size:.82rem;font-weight:600;color:var(--ink)}
    .fg input,.fg select,.fg textarea{
      padding:12px 14px;border:1.5px solid var(--ink-line-md);border-radius:8px;background:var(--bg);
      font-family:inherit;font-size:.95rem;color:var(--ink);outline:none;
      transition:border-color .2s,background .2s
    }
    .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--orange);background:var(--bg-card)}
    .fg-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .form-submit{width:100%;background:var(--orange);color:#fff;padding:14px;border-radius:8px;font-size:.95rem;font-weight:600;letter-spacing:.01em;transition:background .2s,transform .15s}
    .form-submit:hover{background:#d44e1f;transform:translateY(-1px)}
    .form-disclaim{font-size:.74rem;color:var(--ink-mute);margin-top:12px;line-height:1.55}

    /* ── FOOTER */
    .footer{background:var(--ink);color:rgba(255,255,255,.7);padding:64px 0 0}
    .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
    .f-brand{font-family:var(--serif);color:#fff;font-size:1.3rem;font-weight:600;margin-bottom:8px}
    .f-tag{font-size:.86rem;color:rgba(255,255,255,.55);max-width:280px;line-height:1.6;margin-bottom:18px}
    .f-cert-row{display:flex;flex-wrap:wrap;gap:8px}
    .f-cert{font-size:.72rem;font-weight:600;letter-spacing:.04em;color:#fff;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);padding:5px 10px;border-radius:5px}
    .f-col-title{font-size:.74rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#fff;margin-bottom:18px}
    .f-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .f-links a{color:rgba(255,255,255,.6);font-size:.88rem;transition:color .2s}
    .f-links a:hover{color:#fff}
    .footer-bottom{
      border-top:1px solid rgba(255,255,255,.1);padding:22px 0;
      display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
      font-size:.78rem;color:rgba(255,255,255,.5)
    }
    .footer-disclaim{padding:18px 0;border-top:1px solid rgba(255,255,255,.08);font-size:.74rem;color:rgba(255,255,255,.4);line-height:1.7}

    /* ── RESPONSIVE */
    @media (max-width:980px){
      .hero-grid,.elig-grid,.about-grid,.gv-grid,.cta-inner,.contact-grid{grid-template-columns:1fr;gap:40px}
      .gv-officer{position:static}
      .process-grid{grid-template-columns:repeat(2,1fr)}
      .process-grid::before{display:none}
      .numbers-grid{grid-template-columns:repeat(2,1fr)}
      .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
      .cta-actions{text-align:left;align-items:flex-start}
    }
    @media (max-width:640px){
      .container{padding:0 20px}
      .topbar-info{font-size:.7rem}
      .nav-links li:not(:last-child){display:none}
      .section-pad{padding:64px 0}
      .process-grid,.numbers-grid{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr}
      .fg-row{grid-template-columns:1fr}
      .gv-card{padding:28px 20px}
      .charges-table th,.charges-table td{padding:14px 16px;font-size:.82rem}
    }
  </style>
</head>
<body>

  <!-- COMPLIANCE TOPBAR -->
  <div class="topbar">
    <div class="topbar-inner">
      <div class="topbar-info">
        <span>RBI Reg. No.: <b><%= esc(rbiRegNumberV) %></b></span>
        <span>CIN: <b><%= esc(cinV) %></b></span>
        <span><%= esc(nbfcCategoryV) %></span>
      </div>
      <div class="topbar-links">
        <a href="#charges"><%= esc(mitcLinkLabelV) %></a>
        <a href="#about"><%= esc(fairPracticeLinkLabelV) %></a>
        <a href="#grievance"><%= esc(grievanceLinkLabelV) %></a>
        <a href="https://sachet.rbi.org.in" target="_blank" rel="noopener"><%= esc(sachetLinkLabelV) %> ↗</a>
      </div>
    </div>
  </div>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="#" class="brand">
        <span class="brand-mark"><%= bn.charAt(0).toUpperCase() %></span>
        <span><%= bn %></span>
      </a>
      <ul class="nav-links">
        <li><a href="#products">Products</a></li>
        <li><a href="#process">How To Apply</a></li>
        <li><a href="#charges">Rates</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#grievance">Customer Care</a></li>
        <li><a href="#contact" class="nav-cta"><%= esc(heroCtaPrimaryV) %></a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="reveal">
        <div class="hero-eyebrow"><%= esc(heroEyebrowV) %></div>
        <h1 class="hero-title">
          <%= esc(heroHeadlineLeadV) %><br>
          <%= esc(heroHeadlineBodyV) %> <em><%= esc(heroHeadlineEmphV) %></em>
        </h1>
        <p class="hero-sub"><%= esc(heroSubV) %></p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary"><%= esc(heroCtaPrimaryV) %> →</a>
          <a href="#charges" class="btn btn-ghost"><%= esc(heroCtaSecondaryV) %></a>
        </div>
      </div>
      <div class="rate-panel reveal">
        <div class="rate-title"><%= esc(heroRatePanelTitleV) %></div>
        <div class="rate-product"><%= esc(heroRatePanelProductV) %></div>
        <div class="rate-value"><%= esc(heroRateValueV) %><sup>*</sup></div>
        <div class="rate-unit"><%= esc(heroRateUnitV) %></div>
        <div class="rate-benefits">
          <% heroRateBenefitsList.forEach(function(b){ %>
            <div class="rate-benefit"><span class="rate-benefit-ico"><%= esc(b.icon || '✓') %></span><%= esc(b.text) %></div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="trust-strip">
    <div class="container trust-grid">
      <% trustBadgesList.forEach(function(t){ %>
        <div class="trust-badge"><span class="ti"><%= esc(t.icon || '✓') %></span><%= esc(t.label) %></div>
      <% }); %>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="products section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(productsLabelV) %></div>
        <h2 class="section-title"><%= esc(productsHeadlineV) %></h2>
        <p class="section-body"><%= esc(productsBodyV) %></p>
      </div>
      <div class="products-grid">
        <% productsList.forEach(function(p){ %>
        <article class="product-card reveal">
          <div class="product-icon"><%= esc(p.icon || '💼') %></div>
          <h3 class="product-name"><%= esc(p.name) %></h3>
          <p class="product-body"><%= esc(p.body) %></p>
          <div class="product-meta">
            <% if (p.amountRange) { %><div class="product-meta-row"><span class="pm-label">Loan amount</span><span class="pm-value"><%= esc(p.amountRange) %></span></div><% } %>
            <% if (p.rateFrom)    { %><div class="product-meta-row"><span class="pm-label">Interest from</span><span class="pm-value rate"><%= esc(p.rateFrom) %></span></div><% } %>
            <% if (p.tenure)      { %><div class="product-meta-row"><span class="pm-label">Tenure</span><span class="pm-value"><%= esc(p.tenure) %></span></div><% } %>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ELIGIBILITY & DOCS -->
  <section id="eligibility" class="elig-wrap section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(eligibilityLabelV) %></div>
        <h2 class="section-title"><%= esc(eligibilityHeadlineV) %></h2>
      </div>
      <div class="elig-grid">
        <div class="reveal">
          <div class="elig-list">
            <% eligibilityCriteriaList.forEach(function(c){ %>
            <div class="elig-item">
              <div class="elig-icon"><%= esc(c.icon || '✓') %></div>
              <div>
                <div class="elig-title"><%= esc(c.title) %></div>
                <div class="elig-body"><%= esc(c.body) %></div>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
        <div class="reveal">
          <% documentsListList.forEach(function(d){ %>
          <div class="doc-block">
            <div class="doc-cat"><%= esc(d.category) %></div>
            <div class="doc-items">
              <% splitItems(d.items).forEach(function(it){ %>
                <span class="doc-pill"><%= esc(it) %></span>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process" class="process section-pad">
    <div class="container">
      <div class="section-head center reveal">
        <div class="section-eyebrow"><%= esc(processLabelV) %></div>
        <h2 class="section-title"><%= esc(processHeadlineV) %></h2>
      </div>
      <div class="process-grid">
        <% processStepsList.forEach(function(s, i){ var n = String(i+1).padStart(2,'0'); %>
        <div class="process-step reveal">
          <div class="process-icon">
            <%= esc(s.icon || '●') %>
            <span class="process-num"><%= n %></span>
          </div>
          <h3 class="process-title"><%= esc(s.title) %></h3>
          <p class="process-body"><%= esc(s.body) %></p>
          <% if (s.duration) { %><span class="process-duration">⏱ <%= esc(s.duration) %></span><% } %>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CHARGES -->
  <section id="charges" class="charges section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(chargesLabelV) %></div>
        <h2 class="section-title"><%= esc(chargesHeadlineV) %></h2>
        <p class="section-body"><%= esc(chargesBodyV) %></p>
      </div>
      <div class="charges-table-wrap reveal">
        <table class="charges-table">
          <thead>
            <tr><th>Product</th><th>Interest Rate</th><th>Processing Fee</th><th>Prepayment / Foreclosure</th></tr>
          </thead>
          <tbody>
            <% rateRowsList.forEach(function(r){ %>
            <tr>
              <td class="ct-product"><%= esc(r.product) %></td>
              <td class="ct-rate"><%= esc(r.rate) %></td>
              <td><%= esc(r.processingFee) %></td>
              <td><%= esc(r.prepaymentCharge) %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <p class="charges-note"><%= esc(chargesNoteV) %></p>
    </div>
  </section>

  <!-- NUMBERS -->
  <section class="numbers">
    <div class="container numbers-grid">
      <% numberStatsList.forEach(function(n){ %>
      <div class="num-item reveal">
        <div class="num-val"><%= esc(n.value) %><span class="num-suf"><%= esc(n.suffix || '') %></span></div>
        <div class="num-label"><%= esc(n.label) %></div>
      </div>
      <% }); %>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about section-pad">
    <div class="container about-grid">
      <div class="reveal">
        <div class="section-eyebrow"><%= esc(aboutLabelV) %></div>
        <h2 class="section-title"><%= esc(aboutHeadlineLeadV) %> <em><%= esc(aboutHeadlineEmphV) %></em></h2>
        <p class="about-body"><%= esc(aboutBodyV) %></p>
        <div class="about-pillars">
          <% aboutPillarsList.forEach(function(p, i){ %>
          <div class="pillar">
            <div class="pillar-num"><%= String(i+1).padStart(2,'0') %></div>
            <div>
              <div class="pillar-title"><%= esc(p.title) %></div>
              <div class="pillar-body"><%= esc(p.body) %></div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <div class="ratings-card reveal">
        <div class="ratings-title">Regulated. Rated. Audited.</div>
        <div class="ratings-sub">Transparent compliance — every certification publicly verifiable.</div>
        <div class="ratings-list">
          <% ratingsList.forEach(function(r){ %>
            <span class="rating-pill"><%= esc(r.label) %></span>
          <% }); %>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testi section-pad">
    <div class="container">
      <div class="section-head center reveal">
        <div class="section-eyebrow">What customers say</div>
        <h2 class="section-title">Stories from real <em>borrowers.</em></h2>
      </div>
      <div class="testi-grid">
        <% testimonialsList.forEach(function(t){ %>
        <article class="testi-card reveal">
          <% if (t.productUsed) { %><div class="testi-product"><%= esc(t.productUsed) %></div><% } %>
          <p class="testi-quote">"<%= esc(t.quote) %>"</p>
          <div class="testi-author">
            <div class="testi-avatar"><%= initialsOf(t.name) %></div>
            <div>
              <span class="testi-name"><%= esc(t.name) %></span>
              <% if (t.role) { %><span class="testi-role"><%= esc(t.role) %></span><% } %>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- GRIEVANCE -->
  <section id="grievance" class="grievance section-pad">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-eyebrow"><%= esc(grievanceLabelV) %></div>
        <h2 class="section-title"><%= esc(grievanceHeadlineV) %></h2>
        <p class="section-body"><%= esc(grievanceBodyV) %></p>
      </div>
      <div class="gv-card reveal">
        <div class="gv-grid">
          <aside class="gv-officer">
            <div class="gv-officer-eyebrow">Principal Nodal Officer</div>
            <div class="gv-officer-name"><%= esc(groNameV) %></div>
            <div class="gv-officer-role"><%= esc(groRoleV) %></div>
            <div class="gv-info">
              <div class="gv-info-row"><span class="gv-info-key">Email</span><span class="gv-info-val"><%= esc(groEmailV) %></span></div>
              <div class="gv-info-row"><span class="gv-info-key">Phone</span><span class="gv-info-val"><%= esc(groPhoneV) %></span></div>
              <div class="gv-info-row"><span class="gv-info-key">Address</span><span class="gv-info-val"><%= esc(groAddressV).replace(/\n/g, '<br>') %></span></div>
              <div class="gv-info-row"><span class="gv-info-key">Hours</span><span class="gv-info-val"><%= esc(groTimingsV) %></span></div>
            </div>
          </aside>
          <div class="gv-escalation">
            <% escalationLevelsList.forEach(function(e){ %>
            <div class="gv-step">
              <div class="gv-step-head">
                <span class="gv-level"><%= esc(e.level) %></span>
                <% if (e.tat) { %><span class="gv-tat">⏱ <%= esc(e.tat) %></span><% } %>
              </div>
              <p class="gv-step-body"><%= esc(e.body) %></p>
              <% if (e.contact) { %><span class="gv-step-contact"><%= esc(e.contact) %></span><% } %>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta-band">
    <div class="container cta-inner">
      <div class="reveal">
        <h2 class="cta-title"><%= esc(ctaHeadlineV) %></h2>
        <p class="cta-sub"><%= esc(ctaBodyV) %></p>
      </div>
      <div class="cta-actions reveal">
        <a href="#contact" class="btn btn-primary"><%= esc(ctaButtonV) %> →</a>
        <% if (ctaNoteV) { %><span class="cta-note"><%= esc(ctaNoteV) %></span><% } %>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact section-pad">
    <div class="container contact-grid">
      <div class="reveal">
        <div class="section-eyebrow">Talk to us</div>
        <h2 class="section-title">Start your <em>application.</em></h2>
        <p class="section-body">Fill in your details and a relationship manager will reach out within one business hour to walk you through the right product.</p>
        <div class="contact-perks">
          <% contactPerksList.forEach(function(p){ %>
          <div class="cperk"><span class="cperk-ico"><%= esc(p.icon || '✓') %></span><%= esc(p.text) %></div>
          <% }); %>
        </div>
        <div class="contact-info">
          <% if (emailV)   { %><div><b>Email:</b> <%= esc(emailV) %></div><% } %>
          <% if (phoneV)   { %><div><b>Phone:</b> <%= esc(phoneV) %></div><% } %>
          <% if (addressV) { %><div><b>Office:</b> <%- esc(addressV).replace(/\n/g,'<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;') %></div><% } %>
          <% if (hoursV)   { %><div><b>Hours:</b> <%= esc(hoursV) %></div><% } %>
        </div>
      </div>
      <div class="form-card reveal">
        <form data-contact>
          <div class="fg-row">
            <div class="fg"><label>Full name</label><input type="text" placeholder="Rohit Kapoor" required></div>
            <div class="fg"><label>Mobile</label><input type="tel" placeholder="+91 98XXXXXXXX" required></div>
          </div>
          <div class="fg"><label>Email</label><input type="email" placeholder="rohit@example.com" required></div>
          <div class="fg-row">
            <div class="fg">
              <label>Loan product</label>
              <select required>
                <option value="" disabled selected>Select a product</option>
                <% productsList.forEach(function(p){ %><option value="<%= esc(p.name) %>"><%= esc(p.name) %></option><% }); %>
                <option value="other">Other / Not sure</option>
              </select>
            </div>
            <div class="fg"><label>Loan amount (₹)</label><input type="text" placeholder="e.g. 10,00,000"></div>
          </div>
          <div class="fg"><label>Tell us about your need</label><textarea rows="3" placeholder="Income source, purpose of loan, preferred tenure…"></textarea></div>
          <button type="submit" class="form-submit">Check Eligibility →</button>
          <p class="form-disclaim">By submitting, you authorise <%= bn %> to do a soft credit check (no impact on CIBIL) and contact you on the number provided. We never share your data with third parties.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="f-brand"><%= bn %></div>
          <p class="f-tag"><%= tagln %> · RBI-registered NBFC since <%= founded %>.</p>
          <div class="f-cert-row">
            <% ratingsList.slice(0,4).forEach(function(r){ %><span class="f-cert"><%= esc(r.label) %></span><% }); %>
          </div>
        </div>
        <div>
          <p class="f-col-title">Products</p>
          <ul class="f-links">
            <% productsList.forEach(function(p){ %><li><a href="#products"><%= esc(p.name) %></a></li><% }); %>
          </ul>
        </div>
        <div>
          <p class="f-col-title">Customer</p>
          <ul class="f-links">
            <li><a href="#process">How To Apply</a></li>
            <li><a href="#charges">Rates &amp; Charges</a></li>
            <li><a href="#about"><%= esc(fairPracticeLinkLabelV) %></a></li>
            <li><a href="#charges"><%= esc(mitcLinkLabelV) %></a></li>
            <li><a href="#grievance"><%= esc(grievanceLinkLabelV) %></a></li>
          </ul>
        </div>
        <div>
          <p class="f-col-title">Regulatory</p>
          <ul class="f-links">
            <li>RBI Reg.: <%= esc(rbiRegNumberV) %></li>
            <li>CIN: <%= esc(cinV) %></li>
            <li><%= esc(nbfcCategoryV) %></li>
            <li><a href="https://sachet.rbi.org.in" target="_blank" rel="noopener">RBI Sachet ↗</a></li>
            <li><a href="https://cms.rbi.org.in" target="_blank" rel="noopener">RBI Ombudsman (CMS) ↗</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-disclaim">
        <%= bn %> is a Non-Banking Financial Company registered with the Reserve Bank of India under Certificate of Registration No. <%= esc(rbiRegNumberV) %>.
        Loans are sanctioned at the sole discretion of <%= bn %> based on credit assessment.
        Final interest rate, processing fee, and other charges are determined as per the sanction letter and Most Important Terms &amp; Conditions.
        Customer service complaints unresolved within 30 days may be escalated to the RBI Ombudsman via cms.rbi.org.in.
        Reporting unauthorised lending entities: sachet.rbi.org.in.
      </div>
      <div class="footer-bottom">
        <span>© <%= year %> <%= bn %>. All rights reserved.</span>
        <span>Privacy Policy · Terms of Use · Cookie Policy</span>
      </div>
    </div>
  </footer>

  <script>
    // Scroll reveal
    var ro = new IntersectionObserver(function(es){
      es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('visible'); ro.unobserve(e.target); } });
    }, { threshold:.06, rootMargin:'0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(function(el){ ro.observe(el); });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(function(a){
      a.addEventListener('click', function(e){
        var t = document.querySelector(a.getAttribute('href'));
        if (t){ e.preventDefault(); t.scrollIntoView({ behavior:'smooth', block:'start' }); }
      });
    });

    // Contact form
    var f = document.querySelector('[data-contact]');
    if (f){
      f.addEventListener('submit', function(e){
        e.preventDefault();
        var b = f.querySelector('.form-submit');
        b.textContent = 'Submitting…'; b.disabled = true;
        setTimeout(function(){
          var ok = document.createElement('div');
          ok.style.cssText = 'background:rgba(27,122,72,.08);border:1px solid rgba(27,122,72,.25);color:#1b7a48;padding:14px 16px;border-radius:8px;font-size:.92rem;margin-bottom:14px;font-weight:500';
          ok.textContent = '✓ Application received — a relationship manager will call within one business hour.';
          f.insertAdjacentElement('beforebegin', ok);
          f.reset(); b.textContent = 'Check Eligibility →'; b.disabled = false;
          setTimeout(function(){ ok.remove(); }, 6000);
        }, 900);
      });
    }
  </script>
</body>
</html>
