<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= businessName %> — <%= tagline %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --forest:      #0e1e0e;
      --forest-mid:  #162616;
      --forest-soft: #1f3520;
      --cream:       #f7f3ec;
      --cream-mid:   #ede8df;
      --cream-dark:  #ddd6c8;
      --gold:        #b8902a;
      --gold-light:  #d4a93c;
      --gold-dim:    rgba(184,144,42,.15);
      --gold-line:   rgba(184,144,42,.3);
      --text-dark:   #0e1e0e;
      --text-mid:    #3a4a3a;
      --text-soft:   #6a7a6a;
      --text-muted:  #9aaa9a;
      --white:       #ffffff;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans:  'DM Sans', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--text-dark);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── FLOATING QUOTE BUTTON ───────────────────────────────── */
    .float-cta {
      position: fixed;
      bottom: 32px;
      right: 32px;
      z-index: 200;
      background: var(--gold);
      color: var(--white);
      padding: 14px 24px;
      border-radius: 100px;
      font-family: var(--sans);
      font-size: .82rem;
      font-weight: 600;
      text-decoration: none;
      letter-spacing: .04em;
      box-shadow: 0 8px 32px rgba(184,144,42,.45);
      display: flex;
      align-items: center;
      gap: 8px;
      transition: transform .2s, box-shadow .2s;
      animation: floatBtn 3s ease-in-out infinite;
    }

    .float-cta:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 40px rgba(184,144,42,.55);
    }

    @keyframes floatBtn {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-4px); }
    }

    .float-cta-dot {
      width: 7px; height: 7px;
      background: var(--white);
      border-radius: 50%;
      opacity: .7;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%,100% { transform: scale(1); opacity: .7; }
      50%      { transform: scale(.6); opacity: .3; }
    }

    /* ── NAV ─────────────────────────────────────────────────── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--forest);
      border-bottom: 1px solid rgba(255,255,255,.06);
      padding: 0 56px;
      transition: box-shadow .3s;
    }

    .nav.scrolled {
      box-shadow: 0 4px 32px rgba(0,0,0,.4);
    }

    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .nav-logo {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      line-height: 1.15;
    }

    .nav-logo-name {
      font-family: var(--serif);
      font-size: 1.35rem;
      font-weight: 600;
      color: var(--cream);
      letter-spacing: .01em;
    }

    .nav-logo-tag {
      font-size: .65rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold-light);
      font-weight: 500;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 0;
      align-items: center;
    }

    .nav-links a {
      font-size: .8rem;
      font-weight: 500;
      color: rgba(247,243,236,.55);
      text-decoration: none;
      padding: 8px 16px;
      letter-spacing: .03em;
      transition: color .2s;
    }

    .nav-links a:hover { color: var(--cream); }

    .nav-cta {
      background: var(--gold);
      color: var(--white) !important;
      padding: 9px 22px !important;
      border-radius: 6px;
      font-weight: 600 !important;
      margin-left: 8px;
      letter-spacing: .04em !important;
      transition: background .2s, box-shadow .2s !important;
    }

    .nav-cta:hover {
      background: var(--gold-light) !important;
      box-shadow: 0 0 20px rgba(184,144,42,.35) !important;
    }

    /* ── HERO — FULL-BLEED SPLIT ─────────────────────────────── */
    .hero {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      min-height: 88vh;
    }

    .hero-left {
      background: var(--forest);
      padding: 72px 64px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }

    /* Subtle radial glow behind hero text */
    .hero-left::before {
      content: '';
      position: absolute;
      top: -100px; left: -100px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(184,144,42,.07), transparent 70%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--gold-dim);
      border: 1px solid var(--gold-line);
      color: var(--gold-light);
      padding: 7px 16px;
      border-radius: 4px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 36px;
      width: fit-content;
    }

    .hero-badge::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--gold-light);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--gold);
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(3rem, 5.5vw, 5.5rem);
      font-weight: 600;
      line-height: 1.06;
      letter-spacing: -.01em;
      color: var(--cream);
      margin-bottom: 28px;
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold-light);
    }

    .hero-deck {
      font-size: 1rem;
      color: rgba(247,243,236,.55);
      font-weight: 300;
      line-height: 1.75;
      max-width: 420px;
      margin-bottom: 40px;
    }

    .hero-trust-bar {
      display: flex;
      gap: 0;
      border: 1px solid rgba(255,255,255,.07);
    }

    .trust-item {
      flex: 1;
      padding: 18px 20px;
      border-right: 1px solid rgba(255,255,255,.07);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .trust-item:last-child { border-right: none; }

    .trust-num {
      font-family: var(--serif);
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--gold-light);
      line-height: 1;
    }

    .trust-label {
      font-size: .68rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: rgba(247,243,236,.4);
      font-weight: 500;
    }

    /* Right panel — cream with quote card */
    .hero-right {
      background: var(--cream);
      padding: 72px 56px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 28px;
      position: relative;
    }

    /* Rotating badge */
    .spin-badge-wrap {
      position: absolute;
      top: 40px;
      right: 40px;
      width: 80px; height: 80px;
    }

    .spin-badge-inner {
      width: 100%; height: 100%;
      position: relative;
    }

    .spin-badge-inner svg {
      animation: rotateBadge 18s linear infinite;
      position: absolute; inset: 0;
    }

    .spin-badge-inner .badge-center {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .badge-center-icon {
      font-size: 1.4rem;
      color: var(--gold);
      filter: drop-shadow(0 0 4px rgba(184,144,42,.4));
    }

    @keyframes rotateBadge {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* Quote request card */
    .quote-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: 12px;
      padding: 32px;
      box-shadow: 0 8px 40px rgba(14,30,14,.08);
    }

    .quote-card-title {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 6px;
    }

    .quote-card-sub {
      font-size: .82rem;
      color: var(--text-soft);
      margin-bottom: 24px;
    }

    .qform { display: flex; flex-direction: column; gap: 12px; }

    .qinput {
      width: 100%;
      padding: 12px 14px;
      background: var(--cream);
      border: 1px solid var(--cream-dark);
      border-radius: 8px;
      font-family: var(--sans);
      font-size: .88rem;
      color: var(--text-dark);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }

    .qinput::placeholder { color: var(--text-muted); }
    .qinput:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-dim); }

    .qselect {
      appearance: none;
      background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239aaa9a' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 12px center;
      background-size: 16px;
      padding-right: 36px;
      cursor: pointer;
    }

    .qbtn {
      background: var(--forest);
      color: var(--cream);
      border: none;
      padding: 13px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: .88rem;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .04em;
      transition: background .2s, transform .15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .qbtn:hover { background: var(--forest-soft); transform: translateY(-1px); }

    /* Micro reassurance */
    .quote-reassurance {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: .72rem;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .quote-reassurance::before {
      content: '🔒';
      font-size: .68rem;
    }

    /* ── MARQUEE TRUST STRIP ─────────────────────────────────── */
    .trust-strip {
      background: var(--forest-mid);
      border-top: 1px solid rgba(255,255,255,.05);
      border-bottom: 1px solid rgba(255,255,255,.05);
      padding: 14px 0;
      overflow: hidden;
      white-space: nowrap;
    }

    .trust-track {
      display: inline-flex;
      animation: marquee 32s linear infinite;
    }

    .trust-tag {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 0 36px;
      border-right: 1px solid rgba(255,255,255,.06);
      font-size: .72rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(247,243,236,.4);
      font-weight: 500;
    }

    .trust-tag-dot { color: var(--gold-light); font-size: .5rem; }

    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ── SECTION SHARED ──────────────────────────────────────── */
    .section {
      padding: 96px 56px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .eyebrow {
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .eyebrow::before {
      content: '';
      width: 28px; height: 1px;
      background: var(--gold);
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -.01em;
      color: var(--text-dark);
      margin-bottom: 14px;
    }

    .section-sub {
      font-size: .95rem;
      color: var(--text-soft);
      font-weight: 300;
      line-height: 1.75;
      max-width: 560px;
    }

    /* ── SERVICES / PROTECTION CATEGORIES ───────────────────── */
    .services-section {
      background: var(--forest);
      padding: 96px 56px;
    }

    .services-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .services-inner .eyebrow { color: var(--gold-light); }
    .services-inner .eyebrow::before { background: var(--gold-light); }
    .services-inner .section-title { color: var(--cream); }
    .services-inner .section-sub { color: rgba(247,243,236,.55); }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.05);
      margin-top: 48px;
    }

    .service-card {
      background: var(--forest);
      padding: 36px 30px;
      position: relative;
      overflow: hidden;
      transition: background .3s;
      cursor: default;
    }

    .service-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--gold);
      transform: scaleX(0);
      transition: transform .4s ease;
      transform-origin: left;
    }

    .service-card:hover { background: var(--forest-mid); }
    .service-card:hover::after { transform: scaleX(1); }

    .service-icon-wrap {
      width: 48px; height: 48px;
      border: 1px solid var(--gold-line);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      margin-bottom: 20px;
      background: var(--gold-dim);
      transition: background .3s;
    }

    .service-card:hover .service-icon-wrap { background: rgba(184,144,42,.25); }

    .service-num {
      position: absolute;
      top: 24px; right: 24px;
      font-family: var(--serif);
      font-size: 2.8rem;
      font-weight: 400;
      color: rgba(255,255,255,.04);
      line-height: 1;
      letter-spacing: -.02em;
    }

    .service-title {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--cream);
      margin-bottom: 10px;
      line-height: 1.2;
    }

    .service-body {
      font-size: .83rem;
      color: rgba(247,243,236,.5);
      line-height: 1.7;
      font-weight: 300;
    }

    .service-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 18px;
      font-size: .75rem;
      font-weight: 600;
      color: var(--gold-light);
      text-decoration: none;
      letter-spacing: .06em;
      text-transform: uppercase;
      opacity: 0;
      transition: opacity .25s;
    }

    .service-card:hover .service-link { opacity: 1; }

    /* ── WHY CHOOSE ME — SPLIT ───────────────────────────────── */
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      margin-top: 48px;
    }

    .why-left {
      background: var(--forest);
      border-radius: 12px 0 0 12px;
      padding: 56px 48px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .why-left .eyebrow { color: var(--gold-light); }
    .why-left .eyebrow::before { background: var(--gold-light); }
    .why-left .section-title { color: var(--cream); font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: 20px; }

    .why-body {
      font-size: .9rem;
      color: rgba(247,243,236,.6);
      line-height: 1.75;
      font-weight: 300;
      margin-bottom: 32px;
    }

    .why-checklist {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .why-checklist li {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-size: .85rem;
      color: rgba(247,243,236,.7);
      line-height: 1.5;
    }

    .why-check {
      width: 20px; height: 20px;
      background: var(--gold-dim);
      border: 1px solid var(--gold-line);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gold-light);
      font-size: .65rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .why-right {
      display: grid;
      grid-template-rows: 1fr 1fr;
      gap: 4px;
    }

    .why-stat-box {
      background: var(--cream-mid);
      border: 1px solid var(--cream-dark);
      padding: 40px 36px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      transition: background .3s;
    }

    .why-stat-box:hover { background: var(--cream); }

    .why-stat-box:first-child { border-radius: 0 12px 0 0; }
    .why-stat-box:last-child  { border-radius: 0 0 12px 0; }

    .why-stat-num {
      font-family: var(--serif);
      font-size: 3.2rem;
      font-weight: 600;
      color: var(--forest);
      line-height: 1;
      letter-spacing: -.02em;
    }

    .why-stat-num span { color: var(--gold); }

    .why-stat-label {
      font-size: .8rem;
      color: var(--text-soft);
      font-weight: 400;
      line-height: 1.5;
      margin-top: 8px;
    }

    .why-stat-dec {
      position: absolute;
      bottom: -20px; right: -10px;
      font-family: var(--serif);
      font-size: 6rem;
      font-weight: 600;
      color: rgba(14,30,14,.04);
      line-height: 1;
      pointer-events: none;
    }

    /* ── TESTIMONIALS ────────────────────────────────────────── */
    .testi-section {
      background: var(--cream-mid);
      padding: 96px 56px;
    }

    .testi-inner { max-width: 1200px; margin: 0 auto; }

    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--cream-dark);
      border: 1px solid var(--cream-dark);
      margin-top: 48px;
    }

    .testi-card {
      background: var(--cream-mid);
      padding: 36px 30px;
      display: flex;
      flex-direction: column;
      gap: 18px;
      transition: background .3s;
    }

    .testi-card:hover { background: var(--cream); }

    .testi-stars { color: var(--gold); font-size: .85rem; letter-spacing: 3px; }

    .testi-quote {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--text-mid);
      line-height: 1.65;
      flex: 1;
    }

    .testi-author {
      display: flex;
      align-items: center;
      gap: 12px;
      padding-top: 16px;
      border-top: 1px solid var(--cream-dark);
    }

    .testi-av {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--forest);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--serif);
      font-size: .85rem;
      font-weight: 600;
      color: var(--gold-light);
      flex-shrink: 0;
    }

    .testi-name { font-size: .82rem; font-weight: 600; color: var(--text-dark); display: block; }
    .testi-role { font-size: .72rem; color: var(--text-muted); display: block; }

    /* ── ABOUT / PERSONAL ────────────────────────────────────── */
    .about-section { padding: 96px 56px; }

    .about-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .about-photo-wrap {
      position: relative;
    }

    .about-photo-placeholder {
      width: 100%;
      aspect-ratio: 4/5;
      background: var(--forest);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    .about-photo-placeholder::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 70%, rgba(184,144,42,.08), transparent 60%);
    }

    .about-photo-initial {
      font-family: var(--serif);
      font-size: 8rem;
      font-weight: 600;
      color: rgba(247,243,236,.06);
      letter-spacing: -.04em;
      user-select: none;
    }

    .about-photo-badge {
      position: absolute;
      bottom: 24px;
      left: 24px;
      right: 24px;
      background: rgba(14,30,14,.85);
      backdrop-filter: blur(8px);
      border: 1px solid var(--gold-line);
      border-radius: 8px;
      padding: 16px 20px;
    }

    .about-photo-badge-name {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 600;
      color: var(--cream);
      display: block;
      margin-bottom: 2px;
    }

    .about-photo-badge-title {
      font-size: .7rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold-light);
      display: block;
    }

    /* Gold corner accent */
    .about-photo-wrap::after {
      content: '';
      position: absolute;
      bottom: -16px; right: -16px;
      width: 80px; height: 80px;
      border-right: 2px solid var(--gold-line);
      border-bottom: 2px solid var(--gold-line);
      border-radius: 0 0 8px 0;
    }

    .about-right { display: flex; flex-direction: column; gap: 20px; }

    .about-body {
      font-size: .95rem;
      color: var(--text-soft);
      line-height: 1.8;
      font-weight: 300;
    }

    .about-credentials {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--cream-dark);
      border-radius: 10px;
      overflow: hidden;
    }

    .cred-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--cream-dark);
      font-size: .83rem;
      color: var(--text-mid);
      transition: background .2s;
    }

    .cred-item:last-child { border-bottom: none; }
    .cred-item:hover { background: var(--cream-mid); }

    .cred-icon {
      width: 28px; height: 28px;
      background: var(--gold-dim);
      border: 1px solid var(--gold-line);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .8rem;
      flex-shrink: 0;
      color: var(--gold);
    }

    /* ── CONTACT ─────────────────────────────────────────────── */
    .contact-section {
      background: var(--forest);
      padding: 96px 56px;
    }

    .contact-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: start;
    }

    .contact-left .eyebrow { color: var(--gold-light); }
    .contact-left .eyebrow::before { background: var(--gold-light); }
    .contact-left .section-title { color: var(--cream); font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: 16px; }

    .contact-body {
      font-size: .9rem;
      color: rgba(247,243,236,.55);
      line-height: 1.75;
      font-weight: 300;
      margin-bottom: 32px;
    }

    .contact-details { display: flex; flex-direction: column; gap: 12px; }

    .contact-detail {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: .85rem;
      color: rgba(247,243,236,.6);
    }

    .contact-detail-icon {
      width: 32px; height: 32px;
      background: var(--gold-dim);
      border: 1px solid var(--gold-line);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .85rem;
      flex-shrink: 0;
    }

    /* Contact form */
    .cform {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 14px;
      padding: 36px;
    }

    .cform-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--cream);
      margin-bottom: 24px;
    }

    .cform-fields { display: flex; flex-direction: column; gap: 14px; }

    .cfield-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .cfield { display: flex; flex-direction: column; gap: 6px; }

    .cfield label {
      font-size: .68rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(247,243,236,.35);
      font-weight: 600;
    }

    .cfield input,
    .cfield textarea,
    .cfield select {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 8px;
      padding: 11px 14px;
      font-family: var(--sans);
      font-size: .88rem;
      color: var(--cream);
      outline: none;
      resize: none;
      transition: border-color .2s, box-shadow .2s;
      width: 100%;
    }

    .cfield input::placeholder,
    .cfield textarea::placeholder { color: rgba(247,243,236,.2); }

    .cfield input:focus,
    .cfield textarea:focus,
    .cfield select:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px var(--gold-dim);
    }

    .cfield select {
      appearance: none;
      background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(247,243,236,.3)' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 12px center;
      background-size: 16px;
      padding-right: 36px;
      cursor: pointer;
    }

    .cfield select option { background: var(--forest-mid); color: var(--cream); }

    .csubmit {
      background: var(--gold);
      color: var(--white);
      border: none;
      padding: 14px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: .88rem;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .04em;
      width: 100%;
      transition: background .2s, transform .15s, box-shadow .2s;
    }

    .csubmit:hover {
      background: var(--gold-light);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(184,144,42,.35);
    }

    /* ── FOOTER ──────────────────────────────────────────────── */
    footer {
      background: var(--forest-mid);
      border-top: 1px solid rgba(255,255,255,.05);
    }

    .footer-top {
      max-width: 1200px;
      margin: 0 auto;
      padding: 56px 56px 40px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 48px;
    }

    .footer-brand-name {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--cream);
      display: block;
      margin-bottom: 10px;
    }

    .footer-tagline {
      font-size: .83rem;
      color: rgba(247,243,236,.4);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 20px;
    }

    .footer-license {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .68rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold-light);
      border: 1px solid var(--gold-line);
      padding: 4px 10px;
      border-radius: 4px;
    }

    .footer-col-title {
      font-size: .68rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: rgba(247,243,236,.3);
      margin-bottom: 16px;
      font-weight: 600;
    }

    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }

    .footer-links a {
      font-size: .83rem;
      color: rgba(247,243,236,.5);
      text-decoration: none;
      transition: color .2s;
    }

    .footer-links a:hover { color: var(--gold-light); }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.05);
      padding: 20px 56px;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy { font-size: .72rem; color: rgba(247,243,236,.25); }
    .footer-disc { font-size: .68rem; color: rgba(247,243,236,.18); max-width: 480px; text-align: right; line-height: 1.5; }

    /* ── SCROLL REVEAL ───────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity .65s ease, transform .65s ease;
    }

    .reveal.visible { opacity: 1; transform: none; }
    .rd1 { transition-delay: .1s; }
    .rd2 { transition-delay: .2s; }
    .rd3 { transition-delay: .3s; }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width: 1024px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-left { padding: 56px 40px; }
      .hero-right { padding: 48px 40px; }
      .spin-badge-wrap { display: none; }
      .why-grid { grid-template-columns: 1fr; }
      .why-left { border-radius: 12px 12px 0 0; }
      .why-right { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .why-stat-box:first-child { border-radius: 0; }
      .why-stat-box:last-child  { border-radius: 0 0 12px 12px; }
      .about-inner { grid-template-columns: 1fr; gap: 48px; }
      .about-photo-wrap { max-width: 380px; }
      .contact-inner { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
      .nav { padding: 0 24px; }
      .nav-links { display: none; }
      .section { padding: 64px 24px; }
      .services-section { padding: 64px 24px; }
      .testi-section { padding: 64px 24px; }
      .about-section { padding: 64px 24px; }
      .contact-section { padding: 64px 24px; }
      .cfield-row { grid-template-columns: 1fr; }
      .footer-top { padding: 40px 24px 32px; grid-template-columns: 1fr; gap: 32px; }
      .footer-bottom { padding: 16px 24px; flex-direction: column; gap: 8px; text-align: center; }
      .footer-disc { text-align: center; }
      .float-cta { bottom: 20px; right: 16px; padding: 12px 18px; }
      .hero-trust-bar { flex-direction: column; gap: 0; }
      .trust-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,.07); }
      .trust-item:last-child { border-bottom: none; }
    }
  </style>
</head>
