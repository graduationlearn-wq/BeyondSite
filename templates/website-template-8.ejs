  <script>
    // SMOOTH SCROLL
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });

    // NAV SCROLL
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // FLOAT CTA — hide when contact visible
    const floatCta = document.getElementById('floatCta');
    const contactSec = document.getElementById('contact');
    if (contactSec && floatCta) {
      new IntersectionObserver(([e]) => {
        floatCta.style.opacity = e.isIntersecting ? '0' : '1';
        floatCta.style.pointerEvents = e.isIntersecting ? 'none' : 'auto';
        floatCta.style.transition = 'opacity .3s';
      }, { threshold: 0.15 }).observe(contactSec);
    }

    // SCROLL REVEAL
    const ro = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); ro.unobserve(e.target); } });
    }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

    // MARQUEE PAUSE
    const tt = document.getElementById('trustTrack');
    if (tt) {
      tt.addEventListener('mouseenter', () => tt.style.animationPlayState = 'paused');
      tt.addEventListener('mouseleave', () => tt.style.animationPlayState = 'running');
    }

    // HERO QUOTE FORM
    const heroForm = document.querySelector('[data-hero-form]');
    if (heroForm) {
      heroForm.addEventListener('submit', e => {
        e.preventDefault();
        const btn = heroForm.querySelector('.qbtn');
        btn.textContent = 'Sending...';
        btn.disabled = true;
        setTimeout(() => {
          btn.textContent = '✓ Request Received!';
          btn.style.background = '#2d6a2d';
          heroForm.reset();
          setTimeout(() => { btn.textContent = 'Request Free Quote'; btn.style.background = ''; btn.disabled = false; }, 4000);
        }, 900);
      });
    }

    // CONTACT FORM
    const cform = document.querySelector('[data-contact]');
    if (cform) {
      cform.addEventListener('submit', e => {
        e.preventDefault();
        const btn = cform.querySelector('.csubmit');
        btn.textContent = 'Sending...';
        btn.disabled = true;
        setTimeout(() => {
          const n = document.createElement('div');
          n.style.cssText = 'background:rgba(184,144,42,.12);border:1px solid rgba(184,144,42,.3);color:#d4a93c;padding:14px 18px;border-radius:8px;font-size:.85rem;margin-bottom:12px;';
          n.textContent = '✓ Message received — I\'ll be in touch within 2 hours.';
          cform.insertAdjacentElement('beforebegin', n);
          cform.reset();
          btn.textContent = 'Send Message →';
          btn.disabled = false;
          setTimeout(() => n.remove(), 5000);
        }, 900);
      });
    }
  </script>
</body>
</html>
