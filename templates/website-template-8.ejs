<%
  const L = locals || {};
  const esc = (s) => (s == null ? '' : String(s));
  const def = (v, d) => (v && String(v).trim() ? v : d);
  const bn     = esc(L.businessName) || 'Your Insurance Advisor';
  const tag    = esc(L.tagline) || 'Protecting what matters most, with advice you can trust.';
  const year   = esc(L.foundedYear) || new Date().getFullYear();
  const accent = L.primaryColor || '#b8902a';
  const logoV  = esc(L.logo);

  const heroTagV           = def(L.heroTag, 'Licensed Insurance Professional');
  const heroEyebrowV       = def(L.heroEyebrow, `Protecting families since ${year}`);
  const heroHeadlineV      = def(L.heroHeadline, `Personalized insurance for every stage of life.`);
  const heroSubV           = def(L.heroSub, `Life, health, motor, home, and travel coverage — carefully tailored to your family and your future. With 24/7 claim support and a dedicated advisor.`);
  const heroCtaPrimaryV    = def(L.heroCtaPrimary, 'Get Free Quote');
  const heroCtaSecondaryV  = def(L.heroCtaSecondary, 'Call Advisor');
  const heroQuoteCardTitleV = def(L.heroQuoteCardTitle, 'Get a personalized quote');
  const heroQuoteCardBodyV  = def(L.heroQuoteCardBody, 'Fill out the quick form — one of our licensed advisors will call you within 24 hours with a plan tailored to your family.');

  const trust = Array.isArray(L.trustItems) && L.trustItems.length ? L.trustItems
    : [{label:'IRDAI Licensed'},{label:'24/7 Claim Support'},{label:'₹480Cr+ Claims Settled'},{label:'50,000+ Families Insured'}];

  const policyList = Array.isArray(L.policies) && L.policies.length ? L.policies : [
    { icon:'🛡', name:'Life Insurance',    body:'Comprehensive life cover with plans that grow with your family.' },
    { icon:'🏠', name:'Home Insurance',    body:'Protect your home, valuables, and everything inside it.' },
    { icon:'🚗', name:'Motor Insurance',   body:'Car and two-wheeler cover with cashless garage access.' },
    { icon:'❤️', name:'Health Insurance',  body:'Hospitalization, critical illness, and family floater plans.' },
    { icon:'✈️', name:'Travel Insurance',  body:'Domestic and international travel with emergency evacuation.' },
    { icon:'💼', name:'Business Insurance',body:'Asset, liability, and employee benefits for your business.' }
  ];

  const whyHeadlineV = def(L.whyHeadline, `Why families choose to work with us`);
  const whyPointsList = Array.isArray(L.whyPoints) && L.whyPoints.length ? L.whyPoints : [
    { text:'Every recommendation compared across 15+ top insurers' },
    { text:'Dedicated advisor who knows your policy inside-out' },
    { text:'Hassle-free claim assistance, from intimation to payout' },
    { text:'Annual policy review to keep you correctly covered' }
  ];
  const statBoxesList = Array.isArray(L.statBoxes) && L.statBoxes.length ? L.statBoxes : [
    { value:'₹480Cr', label:'Claims settled' },
    { value:'96%',    label:'Claim success rate' }
  ];

  const advisorNameV  = def(L.advisorName, bn);
  const advisorPhotoV = esc(L.advisorPhoto);
  const advisorBioV   = def(L.advisorBio, `With over a decade of experience advising families across India, I help clients choose the right coverage — not the most expensive one. Every family I work with gets a plan built around their actual life, reviewed annually, and defended when it matters most.`);
  const credList = Array.isArray(L.credentials) && L.credentials.length ? L.credentials
    : [{text:'IRDAI Licensed Advisor'},{text:'Certified Financial Planner (CFP)'},{text:'15+ years of experience'},{text:'500+ claims personally handled'}];

  const claimStepsList = Array.isArray(L.claimSteps) && L.claimSteps.length ? L.claimSteps : [
    { title:'Intimation',   body:'Call us or fill the claim form. We kick off the process the same day.' },
    { title:'Documentation',body:'We help you prepare every document required by the insurer.' },
    { title:'Follow-up',    body:'We coordinate with the insurer on your behalf until settlement.' },
    { title:'Payout',       body:'Funds are released directly to your bank account.' }
  ];

  const testList = Array.isArray(L.testimonials) ? L.testimonials : [];

  const licenseNumberV = esc(L.licenseNumber) || 'IRDAI License No. XXXXXX';
  const regulatorV     = esc(L.regulator)     || 'IRDAI';

  const primaryEmail = esc(L.email) || 'hello@example.com';
  const primaryPhone = esc(L.phone) || '+91 98765 43210';
  const addressBlock = esc(L.address);
  const hoursText    = esc(L.hours);
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= bn %> | <%= tag %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --forest:#0e1e0e;--forest-d:#0a160a;--forest-m:#16291a;
      --gold:<%= accent %>;--gold-lt:#d4ac4d;
      --cream:#faf6ec;--cream-d:#efe9d6;
      --ink:#0e1e0e;--muted:rgba(14,30,14,.6);--dim:rgba(14,30,14,.4);
      --border:rgba(14,30,14,.12);
      --serif:'Cormorant Garamond',Georgia,serif;
      --sans:'DM Sans',system-ui,sans-serif;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--cream);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:1200px;margin:0 auto;padding:0 32px}
    .eyebrow{display:inline-block;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--gold)}
    h1,h2,h3{font-family:var(--serif);letter-spacing:-.01em;line-height:1.12}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 26px;border-radius:3px;font-weight:600;font-size:.92rem;cursor:pointer;border:0;letter-spacing:.02em;font-family:var(--sans)}
    .btn-gold{background:var(--gold);color:var(--forest)}
    .btn-ghost{background:transparent;color:var(--cream);border:1.5px solid var(--gold)}
    .btn-outline-ink{background:transparent;color:var(--forest);border:1.5px solid var(--forest)}

    /* ── TOP STRIP ─── */
    .topstrip{background:var(--forest-d);color:rgba(255,255,255,.68);font-size:.78rem;padding:9px 32px;display:flex;justify-content:space-between;gap:16px}
    .topstrip span{display:inline-flex;align-items:center;gap:8px}
    .topstrip .dot{width:7px;height:7px;border-radius:50%;background:var(--gold);animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.45;transform:scale(1.4)}}

    /* ── NAV ─── */
    .nav{background:var(--cream);border-bottom:1px solid var(--border);padding:0 32px;height:78px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:500}
    .nav-logo{display:flex;align-items:center;gap:14px}
    .nav-logo .mark{width:44px;height:44px;border-radius:50%;background:var(--forest);display:grid;place-items:center;color:var(--gold);font-family:var(--serif);font-size:1.5rem;font-weight:700}
    .nav-logo img{height:40px}
    .nav-logo .name{font-family:var(--serif);font-size:1.4rem;color:var(--forest);font-weight:700;line-height:1}
    .nav-logo .tag{font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:2px}

    /* ── HERO ─── */
    .hero{background:linear-gradient(180deg,var(--cream),var(--cream-d));padding:80px 0 100px;position:relative;overflow:hidden}
    .hero::before{content:"";position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(closest-side,rgba(184,144,42,.18),transparent);top:-150px;right:-180px;pointer-events:none}
    .hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:70px;align-items:center;position:relative}
    .hero h1{font-size:clamp(2.6rem,5vw,4.4rem);font-weight:700;color:var(--forest);margin:22px 0 24px}
    .hero h1 em{font-style:italic;color:var(--gold)}
    .hero p.sub{color:var(--muted);font-size:1.1rem;max-width:540px;margin-bottom:32px}
    .hero-ctas{display:flex;gap:12px;flex-wrap:wrap}

    .quote-card{background:#fff;border-radius:8px;padding:40px 36px;box-shadow:0 30px 70px rgba(14,30,14,.12);border:1px solid var(--border);position:relative}
    .quote-card::before{content:"";position:absolute;width:70px;height:70px;border:3px solid var(--gold);border-radius:50%;top:-34px;left:50%;transform:translateX(-50%);background:#fff;background-image:radial-gradient(circle,var(--gold) 30%,transparent 35%);animation:spin 30s linear infinite}
    @keyframes spin{to{transform:translateX(-50%) rotate(360deg)}}
    .quote-card h3{font-size:1.7rem;color:var(--forest);margin-bottom:12px;margin-top:14px;text-align:center}
    .quote-card p{color:var(--muted);text-align:center;margin-bottom:22px;font-size:.96rem}
    .quote-card .field{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
    .quote-card label{font-size:.74rem;color:var(--muted);letter-spacing:.12em;text-transform:uppercase}
    .quote-card input,.quote-card select{padding:11px 14px;border:1px solid var(--border);font-family:inherit;font-size:.94rem;background:var(--cream)}
    .quote-card button{background:var(--forest);color:var(--gold);border:0;padding:14px;font-weight:600;letter-spacing:.04em;cursor:pointer;margin-top:8px;font-family:inherit;text-transform:uppercase;font-size:.82rem}

    /* ── TRUST BAR ─── */
    .trustbar{background:var(--forest);color:rgba(255,255,255,.78);padding:22px 0;font-size:.88rem}
    .trustbar-grid{display:flex;flex-wrap:wrap;justify-content:space-around;gap:22px;align-items:center}
    .trustbar-item{display:inline-flex;align-items:center;gap:10px;letter-spacing:.04em}
    .trustbar-item::before{content:"◆";color:var(--gold)}

    /* ── SECTIONS ─── */
    section{padding:92px 0}
    .sec-head{text-align:center;max-width:740px;margin:0 auto 60px}
    .sec-head h2{font-size:clamp(2rem,3.4vw,2.9rem);color:var(--forest);margin-top:12px}
    .sec-head p{color:var(--muted);margin-top:12px}

    /* ── POLICIES ─── */
    .policies-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:22px}
    .pol{background:#fff;border:1px solid var(--border);padding:32px 28px;display:flex;flex-direction:column;gap:10px;border-radius:4px;transition:transform .25s,border-color .25s}
    .pol:hover{transform:translateY(-4px);border-color:var(--gold)}
    .pol-icon{font-size:2rem;color:var(--gold);margin-bottom:4px}
    .pol h3{font-size:1.4rem;color:var(--forest)}
    .pol p{color:var(--muted);font-size:.94rem}

    /* ── WHY ─── */
    .why{background:#fff}
    .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start}
    .why h2{font-size:clamp(2rem,3.2vw,2.8rem);color:var(--forest);margin-bottom:22px}
    .why ul{list-style:none;display:flex;flex-direction:column;gap:16px}
    .why li{padding-left:34px;position:relative;color:var(--forest);font-size:1.02rem}
    .why li::before{content:"✓";position:absolute;left:0;top:-1px;width:22px;height:22px;background:var(--gold);color:var(--forest);border-radius:50%;display:grid;place-items:center;font-size:.78rem;font-weight:700}
    .stats-pair{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .stat-box{background:var(--forest);color:#fff;padding:32px 24px;border-radius:6px;text-align:center}
    .stat-box .v{font-family:var(--serif);font-size:2.8rem;color:var(--gold);font-weight:700;line-height:1}
    .stat-box .l{margin-top:8px;font-size:.82rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.72)}

    /* ── ADVISOR ─── */
    .advisor{background:var(--cream-d)}
    .advisor-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:56px;align-items:center}
    .advisor-photo{width:100%;max-width:380px;aspect-ratio:4/5;background:linear-gradient(135deg,var(--forest),var(--forest-m));border-radius:6px;display:grid;place-items:center;color:var(--gold);font-family:var(--serif);font-size:4rem;overflow:hidden}
    .advisor-photo img{width:100%;height:100%;object-fit:cover}
    .advisor h2{font-size:clamp(2rem,3.2vw,2.8rem);color:var(--forest);margin-bottom:18px}
    .advisor p{color:var(--muted);margin-bottom:20px}
    .cred-list{list-style:none;display:flex;flex-direction:column;gap:10px;margin-top:20px}
    .cred-list li{padding-left:24px;position:relative;font-weight:500;font-size:.95rem;color:var(--forest)}
    .cred-list li::before{content:"◆";color:var(--gold);position:absolute;left:0}

    /* ── CLAIM PROCESS ─── */
    .claim-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:22px;counter-reset:cstep}
    .claim-step{background:#fff;border:1px solid var(--border);border-radius:4px;padding:28px;position:relative}
    .claim-step::before{counter-increment:cstep;content:counter(cstep,decimal-leading-zero);position:absolute;top:-16px;left:22px;width:40px;height:40px;background:var(--gold);color:var(--forest);border-radius:50%;display:grid;place-items:center;font-family:var(--serif);font-weight:700;font-size:1.12rem}
    .claim-step h3{color:var(--forest);margin:14px 0 8px;font-size:1.25rem}
    .claim-step p{color:var(--muted);font-size:.94rem}

    /* ── TESTIMONIALS ─── */
    .tests{background:#fff}
    .tests-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px}
    .t{background:var(--cream);border:1px solid var(--border);padding:28px;border-radius:4px;position:relative}
    .t::before{content:"\201C";font-family:var(--serif);color:var(--gold);font-size:4rem;position:absolute;top:-4px;left:18px;line-height:1}
    .t p{margin:10px 0 20px;color:var(--forest)}
    .t-meta{padding-top:14px;border-top:1px solid var(--border)}
    .t-meta strong{color:var(--forest);font-weight:600}
    .t-meta span{display:block;color:var(--muted);font-size:.86rem}

    /* ── CONTACT / FOOTER ─── */
    .contact{background:var(--forest);color:rgba(255,255,255,.82)}
    .contact .sec-head h2{color:#fff}
    .contact .sec-head p{color:rgba(255,255,255,.6)}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:54px;align-items:start}
    .contact-info p{display:flex;gap:12px;margin-bottom:14px;color:rgba(255,255,255,.72)}
    .contact-info p strong{color:var(--gold)}
    form.advisor-form{background:rgba(255,255,255,.04);padding:28px;border-radius:6px;border:1px solid rgba(255,255,255,.1)}
    form.advisor-form label{display:block;color:rgba(255,255,255,.62);font-size:.78rem;letter-spacing:.06em;margin-bottom:5px}
    form.advisor-form input,form.advisor-form textarea,form.advisor-form select{width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:#fff;padding:11px 14px;font-family:inherit;border-radius:3px;margin-bottom:14px;font-size:.94rem}
    form.advisor-form button{background:var(--gold);color:var(--forest);border:0;padding:13px 28px;font-weight:700;cursor:pointer;letter-spacing:.04em;text-transform:uppercase;font-size:.82rem}

    footer{background:var(--forest-d);color:rgba(255,255,255,.55);padding:32px 0;font-size:.82rem;text-align:center;line-height:1.7}
    footer .license{display:inline-block;margin-top:8px;padding:5px 14px;background:rgba(184,144,42,.14);color:var(--gold);border-radius:2px;letter-spacing:.08em;font-size:.74rem;text-transform:uppercase}

    .floating-cta{position:fixed;bottom:24px;right:24px;z-index:600;background:var(--gold);color:var(--forest);padding:14px 22px;border-radius:50px;font-weight:700;box-shadow:0 12px 30px rgba(184,144,42,.4);display:inline-flex;align-items:center;gap:8px;font-size:.88rem}

    @media (max-width:900px){
      .hero-grid,.why-grid,.advisor-grid,.contact-grid{grid-template-columns:1fr;gap:40px}
      section{padding:60px 0}
      .topstrip,.nav{padding-left:18px;padding-right:18px}
      .wrap{padding:0 18px}
    }
  </style>
</head>
<body>

<div class="topstrip">
  <span><span class="dot"></span>Office hours: <%= hoursText || 'Mon–Sat · 9am–7pm' %></span>
  <span>📞 <%= primaryPhone %> · <%= primaryEmail %></span>
</div>

<nav class="nav">
  <div class="nav-logo">
    <% if (logoV) { %><img src="<%= logoV %>" alt="<%= bn %>">
    <% } else { %><span class="mark"><%= bn.charAt(0) %></span><% } %>
    <div>
      <div class="name"><%= bn %></div>
      <div class="tag"><%= heroTagV %></div>
    </div>
  </div>
  <a href="#contact" class="btn btn-gold"><%= heroCtaPrimaryV %> →</a>
</nav>

<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow"><%= heroEyebrowV %></span>
      <h1><%- heroHeadlineV %></h1>
      <p class="sub"><%= heroSubV %></p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-gold"><%= heroCtaPrimaryV %></a>
        <% if (primaryPhone) { %><a href="tel:<%= primaryPhone %>" class="btn btn-outline-ink">📞 <%= heroCtaSecondaryV %></a><% } %>
      </div>
    </div>
    <aside class="quote-card">
      <h3><%= heroQuoteCardTitleV %></h3>
      <p><%= heroQuoteCardBodyV %></p>
      <div class="field"><label>Full name</label><input type="text" placeholder="Your name"></div>
      <div class="field"><label>Phone</label><input type="tel" placeholder="+91 …"></div>
      <div class="field"><label>Email</label><input type="email" placeholder="you@example.com"></div>
      <div class="field">
        <label>Policy of interest</label>
        <select>
          <% policyList.forEach(p => { %><option><%= p.name %></option><% }) %>
        </select>
      </div>
      <button type="button" onclick="alert('Thanks! An advisor will reach out shortly.')"><%= heroCtaPrimaryV %></button>
    </aside>
  </div>
</section>

<% if (trust.length) { %>
<div class="trustbar">
  <div class="wrap trustbar-grid">
    <% trust.forEach(t => { %><span class="trustbar-item"><%= t.label %></span><% }) %>
  </div>
</div>
<% } %>

<% if (policyList.length) { %>
<section id="policies">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Policies offered</span>
      <h2>Coverage for every milestone</h2>
      <p>Compare plans across leading insurers and pick the one that actually fits your family.</p>
    </div>
    <div class="policies-grid">
      <% policyList.forEach(p => { %>
        <article class="pol">
          <% if (p.icon) { %><div class="pol-icon"><%= p.icon %></div><% } %>
          <h3><%= p.name %></h3>
          <p><%= p.body %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="why">
  <div class="wrap why-grid">
    <div>
      <span class="eyebrow">Why choose us</span>
      <h2><%= whyHeadlineV %></h2>
      <ul>
        <% whyPointsList.forEach(p => { %><li><%= p.text %></li><% }) %>
      </ul>
    </div>
    <div class="stats-pair">
      <% statBoxesList.forEach(s => { %>
      <div class="stat-box">
        <div class="v"><%= s.value %></div>
        <div class="l"><%= s.label %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="advisor" id="advisor">
  <div class="wrap advisor-grid">
    <div class="advisor-photo">
      <% if (advisorPhotoV) { %><img src="<%= advisorPhotoV %>" alt="<%= advisorNameV %>">
      <% } else { %><%= advisorNameV.charAt(0) %><% } %>
    </div>
    <div>
      <span class="eyebrow">About <%= advisorNameV %></span>
      <h2>Your trusted family advisor</h2>
      <p><%= advisorBioV %></p>
      <ul class="cred-list">
        <% credList.forEach(c => { %><li><%= c.text %></li><% }) %>
      </ul>
    </div>
  </div>
</section>

<% if (claimStepsList.length) { %>
<section id="claim">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Claim process</span>
      <h2>A simple, supported claim journey</h2>
      <p>We don't just sell the policy — we stand with you when it's time to claim.</p>
    </div>
    <div class="claim-grid">
      <% claimStepsList.forEach(s => { %>
        <div class="claim-step">
          <h3><%= s.title %></h3>
          <p><%= s.body %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<% if (testList.length) { %>
<section class="tests">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Testimonials</span>
      <h2>Families we've helped protect</h2>
    </div>
    <div class="tests-grid">
      <% testList.forEach(r => { %>
        <div class="t">
          <p><%= r.quote %></p>
          <div class="t-meta">
            <strong><%= r.name %></strong>
            <% if (r.role) { %><span><%= r.role %></span><% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="contact" id="contact">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Get in touch</span>
      <h2>Let's protect what matters, together.</h2>
      <p>Share a few details — we'll be in touch within 24 hours with a personalized plan.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info">
        <p><strong>Call</strong> <%= primaryPhone %></p>
        <p><strong>Email</strong> <%= primaryEmail %></p>
        <% if (addressBlock) { %><p><strong>Office</strong> <%= addressBlock %></p><% } %>
        <% if (hoursText) { %><p><strong>Hours</strong> <%= hoursText %></p><% } %>
      </div>
      <form class="advisor-form" onsubmit="event.preventDefault(); this.reset(); alert('Thanks — we will be in touch within 24 hours.')">
        <label>Name</label><input type="text" required>
        <label>Phone</label><input type="tel" required>
        <label>Email</label><input type="email">
        <label>Policy of interest</label>
        <select>
          <% policyList.forEach(p => { %><option><%= p.name %></option><% }) %>
        </select>
        <label>How can we help?</label><textarea rows="3"></textarea>
        <button type="submit">Request Callback</button>
      </form>
    </div>
  </div>
</section>

<footer>
