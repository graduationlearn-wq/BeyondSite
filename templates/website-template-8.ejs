        <% products.forEach(function(p){ %>
          <li><a href="#services" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none"><%= p %></a></li>
        <% }); %>
      </ul>
    </div>
    <div>
      <p style="font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(247,243,236,.3);margin-bottom:14px;font-weight:600">Legal & Compliance</p>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px">
        <% if(typeof footerLinks !== 'undefined' && footerLinks && footerLinks.length) { %>
          <% footerLinks.forEach(function(lk){ %>
            <li><a href="<%= lk.url || '#' %>" target="_blank" rel="noopener" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none"><%= lk.label %></a></li>
          <% }); %>
        <% } else { %>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">About Us</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">ISNP</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">Grievance Redressal</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">Privacy Policy</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">Terms & Conditions</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">Disclaimer</a></li>
          <li><a href="#" style="font-size:.82rem;color:rgba(247,243,236,.5);text-decoration:none">IRDAI License</a></li>
        <% } %>
      </ul>
    </div>
  </div>
  <div style="border-top:1px solid rgba(255,255,255,.06);padding:18px 48px;max-width:1100px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
    <span class="license">
      <%= regulatorV %>
      <% if(typeof footerIrdaiNo !== 'undefined' && footerIrdaiNo) { %>· <%= footerIrdaiNo %><% } else { %>· <%= licenseNumberV %><% } %>
      <% if(typeof footerCin !== 'undefined' && footerCin) { %>· CIN: <%= footerCin %><% } %>
    </span>
    <span style="font-size:.72rem;color:rgba(247,243,236,.25)">© <%= year %> <%= bn %>. All rights reserved.</span>
  </div>
</footer>

<a href="#contact" class="floating-cta">💬 <%= heroCtaPrimaryV %></a>

