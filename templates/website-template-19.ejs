<script>
  // Reveal animations
  var ro=new IntersectionObserver(function(es){
    es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target);}});
  },{threshold:.06,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(function(el){ro.observe(el);});

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.querySelector(a.getAttribute('href'));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
    });
  });

  // ── EMI Calculator ──
  function fmtRupee(n){
    if(!n && n!==0) return '₹0';
    n=Math.round(n);
    var s=n.toString();
    if(s.length<=3) return '₹'+s;
    var last3=s.slice(-3), rest=s.slice(0,-3);
    return '₹'+rest.replace(/\B(?=(\d{2})+(?!\d))/g,',')+','+last3;
  }
  function calcEmi(p,t,r){
    var mr=(r/100)/12;
    if(!mr || !t) return p/t;
    var n=p*mr*Math.pow(1+mr,t);
    var d=Math.pow(1+mr,t)-1;
    return d?Math.round(n/d):0;
  }
  function updateCalc(){
    var p=parseFloat(document.getElementById('calcAmount').value);
    var t=parseFloat(document.getElementById('calcTenure').value);
    var r=parseFloat(document.getElementById('calcRate').value);
    var emi=calcEmi(p,t,r);
    var total=emi*t;
    var interest=total-p;
    document.getElementById('calcAmountVal').textContent=fmtRupee(p);
    document.getElementById('calcTenureVal').textContent=t+' months';
    document.getElementById('calcRateVal').textContent=r.toFixed(2)+'% p.a.';
    document.getElementById('calcEmi').innerHTML=fmtRupee(emi)+'<small>/ month</small>';
    document.getElementById('calcInterest').textContent=fmtRupee(interest);
    document.getElementById('calcTotal').textContent=fmtRupee(total);
  }
  ['calcAmount','calcTenure','calcRate'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.addEventListener('input',updateCalc);
  });

  // ── Eligibility live check ──
  function updateElig(){
    var income=parseInt(document.getElementById('eligIncome').value);
    var loan=parseInt(document.getElementById('eligLoan').value);
    var score=parseInt(document.getElementById('eligScore').value);
    document.getElementById('eligIncomeVal').textContent=fmtRupee(income);
    document.getElementById('eligLoanVal').textContent=fmtRupee(loan);
    document.getElementById('eligScoreVal').textContent=score;
    // Heuristic
    var ratio=loan/(income*60); // loan vs 5yr income
    var resultTitle='Likely eligible', resultBody='Based on your inputs, most of our partner lenders should consider your application. Apply to see firm offers.';
    var resultEl=document.getElementById('eligResult');
    if(score<650){
      resultTitle='Limited options';
      resultBody='A CIBIL score below 650 means most prime lenders will decline. We can route you to lenders who accept lower scores — at a higher rate.';
      resultEl.style.borderLeftColor='#fb923c';
      document.querySelector('.elig-result-title').style.color='#fb923c';
    } else if(ratio>1){
      resultTitle='Loan too large';
      resultBody='Your requested loan exceeds the EMI burden lenders typically allow. Consider a smaller amount or a longer tenure to improve your odds.';
      resultEl.style.borderLeftColor='#fb923c';
      document.querySelector('.elig-result-title').style.color='#fb923c';
    } else {
      resultEl.style.borderLeftColor='#84cc16';
      document.querySelector('.elig-result-title').style.color='#84cc16';
    }
    document.querySelector('.elig-result-title').textContent=resultTitle;
    document.getElementById('eligResultBody').textContent=resultBody;
  }
  ['eligIncome','eligLoan','eligScore'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.addEventListener('input',updateElig);
  });

  // ── Document accordion ──
  document.querySelectorAll('.doc-group-head').forEach(function(h){
    h.addEventListener('click',function(){
      var g=h.parentElement;
      var willOpen=!g.classList.contains('open');
      // accordion: close others
      document.querySelectorAll('.doc-group').forEach(function(x){
        x.classList.remove('open');
        var btn=x.querySelector('.doc-group-head');
        if(btn) btn.setAttribute('aria-expanded','false');
      });
      if(willOpen){
        g.classList.add('open');
        h.setAttribute('aria-expanded','true');
      }
    });
  });

  // ── Contact form fake submit ──
  var f=document.querySelector('[data-contact]');
  if(f){f.addEventListener('submit',function(e){
    e.preventDefault();
    var b=f.querySelector('.form-submit');
    b.textContent='Sending…';b.disabled=true;
    setTimeout(function(){
      var ok=document.createElement('div');
      ok.style.cssText='background:rgba(132,204,22,.14);border:1px solid rgba(132,204,22,.4);color:#4d7c0f;padding:15px 18px;border-radius:12px;font-size:.93rem;margin-bottom:14px;font-weight:600;font-family:Inter,sans-serif';
      ok.textContent='✓ Request received. We will pre-qualify you across our partner lenders and reply within a few hours.';
      f.insertAdjacentElement('beforebegin',ok);
      f.reset();b.textContent='Get my offers →';b.disabled=false;
      setTimeout(function(){ok.remove();},8000);
    },900);
  });}
</script>
</body>
</html>
