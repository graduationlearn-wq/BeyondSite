      --display:     'Sora', system-ui, sans-serif;
      --sans:        'Inter', system-ui, -apple-system, sans-serif;
      --mono:        'JetBrains Mono', ui-monospace, monospace;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--paper);color:var(--ink);line-height:1.7;-webkit-font-smoothing:antialiased;padding-bottom:env(safe-area-inset-bottom)}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none}
    em{font-style:normal;color:var(--lime-deep);position:relative;display:inline-block}
    em::after{content:'';position:absolute;left:0;right:0;bottom:.06em;height:.32em;background:var(--lime-tint);border-radius:100px;z-index:-1}
    .container{max-width:1240px;margin:0 auto;padding:0 32px}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── TOPBAR ─────────────────────────────────────────────── */
    .topbar{background:var(--indigo-deep);color:rgba(255,255,255,.8);font-size:.74rem;padding:9px 0}
    .topbar-inner{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;max-width:1240px;margin:0 auto;padding:0 32px}
    .topbar-info{display:flex;gap:18px;flex-wrap:wrap;align-items:center}
    .topbar-info b{font-weight:700;color:#fff}
    .topbar-badge{display:inline-flex;align-items:center;gap:8px;background:var(--lime);color:var(--indigo-deep);padding:5px 12px;border-radius:100px;font-weight:700;font-size:.74rem}
    .topbar-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--indigo-deep);box-shadow:0 0 0 3px var(--lime)}

    /* ── NAV ────────────────────────────────────────────────── */
    .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.95);backdrop-filter:blur(14px);border-bottom:1px solid var(--ink-line)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .brand{display:flex;align-items:center;gap:12px;font-family:var(--display);font-size:1.32rem;font-weight:800;color:var(--ink);letter-spacing:-.02em;white-space:nowrap}
    .brand-mark{width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,var(--indigo),var(--indigo-soft));color:var(--lime);display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:800;font-size:1.25rem;box-shadow:0 8px 22px var(--indigo-glow);letter-spacing:-.04em}
    .nav-links{display:flex;gap:26px;align-items:center;list-style:none}
    .nav-links a{color:var(--ink-soft);font-size:.92rem;font-weight:500;transition:color .2s}
    .nav-links a:hover{color:var(--indigo)}
    .nav-cta{background:var(--lime);color:var(--indigo-deep);padding:10px 22px;border-radius:100px;font-weight:700;box-shadow:0 8px 22px var(--lime-glow);white-space:nowrap;font-size:.92rem}
    .nav-cta:hover{background:var(--lime-deep);color:#fff}

    /* ── BUTTONS ────────────────────────────────────────────── */
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:14px;font-size:.95rem;font-weight:700;transition:transform .15s,box-shadow .25s,background .25s;min-height:48px;line-height:1.2}
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{background:var(--lime);color:var(--indigo-deep);box-shadow:0 12px 28px var(--lime-glow)}
    .btn-primary:hover{background:var(--lime-deep);color:#fff;box-shadow:0 16px 38px var(--lime-glow)}
    .btn-ink{background:var(--indigo);color:#fff;box-shadow:0 12px 28px var(--indigo-glow)}
    .btn-ink:hover{background:var(--indigo-soft)}
    .btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--ink-line-md)}
    .btn-ghost:hover{background:var(--cream);border-color:var(--indigo);color:var(--indigo)}
    .btn-wa{background:#25d366;color:#fff;box-shadow:0 12px 28px rgba(37,211,102,.4)}
    .btn-wa:hover{background:#1eaa54}

    /* ── HERO ───────────────────────────────────────────────── */
    .hero{padding:48px 0 80px;position:relative;overflow:hidden;background:linear-gradient(180deg,#ffffff 0%,#fafafa 100%)}
    .hero::before{content:'';position:absolute;top:-220px;right:-220px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,var(--lime-tint) 0%,transparent 65%);pointer-events:none}
    .hero::after{content:'';position:absolute;bottom:-160px;left:-160px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,var(--indigo-tint) 0%,transparent 65%);pointer-events:none}
    .hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;position:relative}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:.78rem;font-weight:600;letter-spacing:.04em;color:var(--indigo);background:var(--indigo-tint);padding:9px 18px;border-radius:100px;margin-bottom:22px}
    .hero-eyebrow::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--lime);box-shadow:0 0 0 4px var(--lime-tint)}
    .hero-title{font-family:var(--display);font-weight:800;font-size:clamp(2.4rem,5vw,4.4rem);line-height:1.04;letter-spacing:-.03em;color:var(--ink);margin-bottom:20px}
    .hero-sub{font-size:1.04rem;color:var(--ink-soft);max-width:520px;margin-bottom:26px;line-height:1.75}
    .hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px}
    .hero-nofee{display:inline-flex;align-items:center;gap:12px;background:var(--lime-tint);border:1.5px solid var(--lime);border-radius:14px;padding:12px 16px;font-size:.88rem;color:var(--lime-deep);font-weight:600;line-height:1.4}
    .hero-nofee b{font-family:var(--display);font-weight:800;color:var(--indigo)}
    .hero-nofee-ic{width:34px;height:34px;border-radius:50%;background:var(--lime);color:var(--indigo-deep);display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:1rem;font-weight:800;flex-shrink:0}

    /* ── EMI CALCULATOR ─────────────────────────────────────── */
    .calc-card{background:var(--indigo);color:#fff;border-radius:24px;padding:32px;box-shadow:0 32px 64px -32px var(--indigo-glow), 0 16px 32px -16px var(--indigo-glow);position:relative;overflow:hidden}
    .calc-card::before{content:'';position:absolute;top:-80px;right:-80px;width:240px;height:240px;border-radius:50%;background:radial-gradient(circle,var(--lime-tint) 0%,transparent 70%);pointer-events:none}
    .calc-card::after{content:'EMI CALCULATOR';position:absolute;top:14px;right:18px;font-family:var(--mono);font-size:.65rem;font-weight:700;letter-spacing:.18em;color:rgba(132,204,22,.65)}
    .calc-result{margin-bottom:24px;position:relative}
    .calc-result-label{font-family:var(--mono);font-size:.7rem;font-weight:600;color:rgba(255,255,255,.55);letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px}
    .calc-result-emi{font-family:var(--display);font-size:clamp(2.5rem,4.5vw,3.4rem);font-weight:800;color:#fff;line-height:1;letter-spacing:-.025em;margin-bottom:6px;display:flex;align-items:baseline;gap:10px}
    .calc-result-emi small{font-family:var(--sans);font-size:.95rem;font-weight:500;color:rgba(255,255,255,.7);letter-spacing:0}
    .calc-result-summary{display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:.84rem;color:rgba(255,255,255,.7);margin-top:14px;padding-top:14px;border-top:1px dashed rgba(255,255,255,.18)}
    .calc-result-summary b{display:block;color:var(--lime);font-family:var(--mono);font-weight:700;font-size:.95rem;margin-top:2px}
    .calc-sliders{display:flex;flex-direction:column;gap:18px;position:relative}
    .calc-row label{display:flex;justify-content:space-between;align-items:center;font-size:.84rem;color:rgba(255,255,255,.8);margin-bottom:8px;font-weight:500}
    .calc-row label b{font-family:var(--mono);color:#fff;font-weight:700;font-size:.95rem;background:rgba(132,204,22,.18);padding:3px 9px;border-radius:6px;letter-spacing:-.005em}
    .calc-slider{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:100px;background:rgba(255,255,255,.16);outline:none;margin:8px 0 0;cursor:pointer}
    .calc-slider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:24px;height:24px;border-radius:50%;background:var(--lime);box-shadow:0 4px 14px var(--lime-glow);cursor:pointer;border:3px solid #fff}
    .calc-slider::-moz-range-thumb{width:24px;height:24px;border-radius:50%;background:var(--lime);box-shadow:0 4px 14px var(--lime-glow);cursor:pointer;border:3px solid #fff}
    .calc-slider:focus::-webkit-slider-thumb{outline:2px solid var(--cream);outline-offset:2px}
    .calc-bounds{display:flex;justify-content:space-between;font-family:var(--mono);font-size:.7rem;color:rgba(255,255,255,.45);margin-top:5px}
    .calc-foot{margin-top:22px;padding-top:18px;border-top:1px dashed rgba(255,255,255,.18);font-size:.78rem;color:rgba(255,255,255,.6);font-style:italic;line-height:1.55}

    /* Lender ribbon (floating below calc on desktop) */
    .lender-ribbon{display:flex;gap:10px;margin-top:22px;overflow-x:auto;padding-bottom:6px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}
    .lender-ribbon::-webkit-scrollbar{display:none}
    .lender-ribbon{scrollbar-width:none}
    .lender-chip{flex-shrink:0;background:var(--paper);border:1px solid var(--ink-line);border-radius:100px;padding:7px 14px;font-family:var(--mono);font-size:.78rem;font-weight:600;color:var(--ink);display:flex;align-items:center;gap:8px;scroll-snap-align:start}
    .lender-chip b{color:var(--lime-deep);font-weight:700}

    /* ── TRUST STRIP ────────────────────────────────────────── */
    .trust-strip{background:var(--cream);padding:28px 0;border-top:1px solid var(--cream-deep);border-bottom:1px solid var(--cream-deep)}
    .trust-strip-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
    .trust-stat-v{font-family:var(--display);font-size:clamp(1.5rem,2.4vw,2.1rem);font-weight:800;color:var(--indigo);letter-spacing:-.02em;line-height:1}
    .trust-stat-l{font-size:.8rem;color:var(--ink-mute);font-weight:500;margin-top:6px}

    /* ── SECTION ────────────────────────────────────────────── */
    .section-pad{padding:88px 0}
    .section-head{text-align:left;max-width:760px;margin-bottom:48px}
    .section-head.center{margin-left:auto;margin-right:auto;text-align:center}
    .section-eyebrow{display:inline-block;font-family:var(--mono);font-size:.76rem;font-weight:700;color:var(--lime-deep);background:var(--lime-tint);padding:6px 12px;border-radius:6px;margin-bottom:14px;text-transform:uppercase;letter-spacing:.08em}
    .section-title{font-family:var(--display);font-size:clamp(2rem,3.5vw,3rem);font-weight:800;line-height:1.13;letter-spacing:-.025em;color:var(--ink);margin-bottom:16px}
    .section-body{font-size:1.02rem;color:var(--ink-soft);line-height:1.78;max-width:660px}

    /* ── LOAN TYPES ─────────────────────────────────────────── */
    .loans{background:var(--paper)}
    .loans-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px}
    .loan-card{background:var(--paper);border:1.5px solid var(--ink-line);border-radius:20px;padding:28px;display:flex;flex-direction:column;transition:transform .25s,border-color .25s,box-shadow .25s;position:relative;overflow:hidden;min-height:240px}
    .loan-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--indigo),var(--lime));border-radius:20px 20px 0 0;opacity:0;transition:opacity .3s}
    .loan-card:hover{transform:translateY(-4px);border-color:var(--indigo);box-shadow:0 22px 44px -22px var(--indigo-glow)}
    .loan-card:hover::before{opacity:1}
    .loan-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:14px}
    .loan-icon{width:54px;height:54px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0}
    .loan-name{font-family:var(--display);font-size:1.18rem;font-weight:700;color:var(--ink);letter-spacing:-.015em;line-height:1.3;margin-bottom:4px}
    .loan-rate{font-family:var(--mono);font-size:.84rem;font-weight:700;color:var(--lime-deep);letter-spacing:-.005em}
    .loan-rate small{color:var(--ink-mute);font-weight:500;letter-spacing:0}
    .loan-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;margin-bottom:14px;flex:1}
    .loan-meta{display:flex;gap:10px;flex-wrap:wrap;padding-top:14px;border-top:1px dashed var(--ink-line-md);font-size:.78rem;color:var(--ink-soft)}
    .loan-meta-row{display:flex;flex-direction:column;gap:2px;flex:1;min-width:0}
    .loan-meta-row b{color:var(--ink);font-family:var(--mono);font-size:.82rem;font-weight:700}
    .loan-meta-row span{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-mute);font-weight:500}

    /* ── LENDERS ────────────────────────────────────────────── */
    .lenders{background:var(--bg)}
    .lenders-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
    .lender-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:14px;padding:20px 18px;display:flex;align-items:center;gap:14px;transition:transform .25s,border-color .25s,box-shadow .25s}
    .lender-card:hover{transform:translateY(-2px);border-color:var(--indigo);box-shadow:0 14px 28px -16px var(--indigo-glow)}
    .lender-mono{width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,var(--indigo),var(--indigo-soft));color:var(--lime);display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:1.3rem;font-weight:800;letter-spacing:-.02em;flex-shrink:0}
    .lender-name{font-family:var(--display);font-size:.98rem;font-weight:700;color:var(--ink);letter-spacing:-.005em;margin-bottom:3px}
    .lender-meta{display:flex;align-items:center;gap:8px;font-size:.72rem;color:var(--ink-mute)}
    .lender-type{font-family:var(--mono);background:var(--indigo-tint);color:var(--indigo);font-weight:700;padding:2px 8px;border-radius:4px;font-size:.66rem;letter-spacing:.04em}
    .lender-rate{font-family:var(--mono);font-size:.78rem;color:var(--lime-deep);font-weight:700;margin-top:4px;display:block}

    /* ── COMPARISON TABLE ───────────────────────────────────── */
    .comp{background:var(--paper)}
    .comp-card{background:var(--paper);border:1px solid var(--ink-line-md);border-radius:20px;overflow:hidden;box-shadow:0 18px 44px -24px rgba(15,23,42,.18)}
    .comp-head{background:var(--indigo);color:#fff;padding:22px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px}
    .comp-head-title{font-family:var(--display);font-size:1.05rem;font-weight:700;letter-spacing:-.005em}
    .comp-head-note{font-family:var(--mono);font-size:.72rem;color:rgba(255,255,255,.6);letter-spacing:.04em;text-transform:uppercase}
    .comp-table{width:100%;border-collapse:collapse;display:table}
    .comp-table thead{background:var(--bg)}
    .comp-table th,.comp-table td{padding:16px 28px;text-align:left;border-bottom:1px solid var(--ink-line);font-size:.92rem}
    .comp-table th{font-family:var(--mono);font-weight:700;color:var(--ink-mute);font-size:.7rem;letter-spacing:.1em;text-transform:uppercase}
    .comp-table tr:last-child td{border-bottom:none}
    .comp-table tr:hover td{background:rgba(132,204,22,.04)}
    .comp-loan{font-family:var(--display);font-weight:700;color:var(--ink);letter-spacing:-.005em}
    .comp-rate{font-family:var(--mono);font-weight:700;color:var(--lime-deep);font-size:.95rem;display:flex;flex-direction:column;gap:2px}
    .comp-rate small{font-family:var(--sans);font-size:.7rem;color:var(--ink-mute);font-weight:500}
    .comp-median{font-family:var(--mono);color:var(--ink-soft);font-weight:600;font-size:.88rem}
    .comp-tat{font-family:var(--mono);font-size:.78rem;color:var(--ink);background:var(--cream);padding:4px 10px;border-radius:5px;font-weight:600;display:inline-block;letter-spacing:-.005em}
    .comp-amount{font-family:var(--mono);font-size:.86rem;color:var(--ink-soft)}
    .comp-foot{padding:16px 28px;background:var(--bg);font-size:.78rem;color:var(--ink-mute);font-style:italic;border-top:1px solid var(--ink-line);line-height:1.55}

    /* Mobile cards (hidden on desktop) */
    .comp-cards{display:none}
    .comp-mobile-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:16px;padding:20px;flex-shrink:0;width:280px;scroll-snap-align:start}
    .comp-mobile-card .cmc-loan{font-family:var(--display);font-size:1.05rem;font-weight:700;color:var(--ink);margin-bottom:14px;letter-spacing:-.005em}
    .comp-mobile-card .cmc-row{display:grid;grid-template-columns:auto 1fr;gap:6px 12px;font-size:.84rem;margin-bottom:14px}
    .comp-mobile-card .cmc-key{font-family:var(--mono);font-size:.7rem;color:var(--ink-mute);font-weight:600;text-transform:uppercase;letter-spacing:.06em;padding-top:2px}
    .comp-mobile-card .cmc-val{color:var(--ink);font-weight:600}
    .comp-mobile-card .cmc-val.rate{font-family:var(--mono);color:var(--lime-deep);font-weight:700}
    .comp-mobile-card .cmc-val.tat{font-family:var(--mono);background:var(--cream);padding:2px 8px;border-radius:5px;display:inline-block;font-size:.76rem;font-weight:600;width:fit-content}

    /* ── PROCESS ────────────────────────────────────────────── */
    .process{background:var(--bg)}
    .process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;position:relative}
    .process-grid::before{content:'';position:absolute;top:48px;left:8%;right:8%;height:2px;background:repeating-linear-gradient(90deg,var(--indigo) 0 6px,transparent 6px 14px);opacity:.35;z-index:0}
    .process-step{position:relative;z-index:1;text-align:center;padding:0 8px}
    .process-icon{width:100px;height:100px;border-radius:50%;background:var(--paper);border:2px solid var(--indigo);color:var(--indigo);font-size:2rem;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;position:relative;box-shadow:0 14px 28px -14px var(--indigo-glow)}
    .process-num{position:absolute;top:-8px;right:-8px;width:32px;height:32px;border-radius:50%;background:var(--lime);color:var(--indigo-deep);font-family:var(--display);font-weight:800;font-size:.92rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px var(--lime-glow)}
    .process-title{font-family:var(--display);font-size:1.18rem;font-weight:700;color:var(--ink);margin-bottom:8px;letter-spacing:-.015em}
    .process-body{font-size:.9rem;color:var(--ink-soft);line-height:1.7;max-width:240px;margin:0 auto 12px}
    .process-duration{display:inline-block;font-family:var(--mono);font-size:.74rem;font-weight:700;color:var(--lime-deep);background:var(--lime-tint);padding:4px 12px;border-radius:100px;letter-spacing:.04em}

    /* ── ELIGIBILITY ────────────────────────────────────────── */
    .elig{background:var(--paper)}
    .elig-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
    .elig-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .elig-card{background:var(--bg);border:1px solid var(--ink-line);border-radius:14px;padding:22px}
    .elig-card-icon{width:42px;height:42px;border-radius:12px;background:var(--lime-tint);color:var(--lime-deep);display:flex;align-items:center;justify-content:center;font-size:1.25rem;margin-bottom:12px}
    .elig-card-title{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);margin-bottom:5px;letter-spacing:-.005em}
    .elig-card-body{font-size:.84rem;color:var(--ink-soft);line-height:1.6}

    /* Eligibility quick-check form */
    .elig-form{background:linear-gradient(160deg,var(--indigo),var(--indigo-soft));color:#fff;border-radius:24px;padding:32px;box-shadow:0 24px 50px -24px var(--indigo-glow);position:relative;overflow:hidden}
    .elig-form::before{content:'CHECK IF YOU QUALIFY';position:absolute;top:14px;right:18px;font-family:var(--mono);font-size:.65rem;font-weight:700;letter-spacing:.18em;color:rgba(132,204,22,.7)}
    .elig-form-title{font-family:var(--display);font-size:1.25rem;font-weight:700;margin-bottom:22px;letter-spacing:-.015em;color:#fff}
    .elig-form-row{margin-bottom:18px}
    .elig-form-row label{display:flex;justify-content:space-between;align-items:center;font-size:.86rem;color:rgba(255,255,255,.85);margin-bottom:8px;font-weight:500}
    .elig-form-row label b{font-family:var(--mono);color:#fff;font-weight:700;background:rgba(132,204,22,.18);padding:3px 9px;border-radius:6px;font-size:.85rem}
    .elig-result{margin-top:22px;padding:18px;background:rgba(132,204,22,.14);border-left:3px solid var(--lime);border-radius:0 12px 12px 0}
    .elig-result-title{font-family:var(--display);font-weight:700;color:var(--lime);font-size:.86rem;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
    .elig-result-body{color:rgba(255,255,255,.92);font-size:.92rem;line-height:1.6}

    /* ── DOCUMENTS (accordion) ─────────────────────────────── */
    .docs{background:var(--bg)}
    .docs-acc{display:grid;gap:14px}
    .doc-group{background:var(--paper);border:1px solid var(--ink-line);border-radius:18px;overflow:hidden;transition:border-color .25s,box-shadow .25s}
    .doc-group.open{border-color:var(--indigo);box-shadow:0 16px 32px -20px var(--indigo-glow)}
    .doc-group-head{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px 26px;cursor:pointer;user-select:none;background:none;width:100%;text-align:left;border:none;color:var(--ink);font-family:inherit}
    .doc-group-head-l{display:flex;align-items:center;gap:14px}
    .doc-group-icon{width:42px;height:42px;border-radius:12px;background:var(--cream);color:var(--indigo);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
    .doc-group-title{font-family:var(--display);font-size:1.08rem;font-weight:700;letter-spacing:-.01em}
    .doc-group-chev{width:32px;height:32px;border-radius:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;color:var(--ink-soft);transition:transform .3s,background .25s;font-size:1rem;font-weight:600;flex-shrink:0}
    .doc-group.open .doc-group-chev{transform:rotate(180deg);background:var(--lime);color:var(--indigo-deep)}
    .doc-group-body{max-height:0;overflow:hidden;transition:max-height .35s ease;padding:0 26px}
    .doc-group.open .doc-group-body{max-height:600px;padding-bottom:24px}
    .doc-items{list-style:none;display:flex;flex-direction:column;gap:10px;padding-top:6px}
    .doc-items li{display:flex;align-items:flex-start;gap:10px;font-size:.93rem;color:var(--ink-soft);line-height:1.55}
    .doc-items li::before{content:'';width:18px;height:18px;border-radius:5px;background:var(--lime);color:var(--indigo-deep);display:flex;align-items:center;justify-content:center;font-size:.74rem;font-weight:800;flex-shrink:0;margin-top:3px}
    .doc-items li::before{content:'✓';font-family:var(--display)}

    /* ── WHY ────────────────────────────────────────────────── */
    .why{background:var(--paper)}
    .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:20px}
    .why-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:18px;padding:28px;display:flex;flex-direction:column;gap:12px;transition:transform .25s,box-shadow .25s,border-color .25s}
    .why-card:hover{transform:translateY(-3px);border-color:var(--lime);box-shadow:0 16px 32px -20px var(--lime-glow)}
    .why-icon{width:48px;height:48px;border-radius:12px;background:var(--lime);color:var(--indigo-deep);display:flex;align-items:center;justify-content:center;font-size:1.35rem;font-weight:700;box-shadow:0 8px 18px var(--lime-glow)}
    .why-title{font-family:var(--display);font-size:1.1rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .why-body{font-size:.9rem;color:var(--ink-soft);line-height:1.7}

    /* ── TESTIMONIALS ──────────────────────────────────────── */
    .testi{background:var(--bg)}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:22px}
    .testi-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:20px;padding:30px;display:flex;flex-direction:column;transition:transform .25s,box-shadow .25s;position:relative}
    .testi-card::before{content:'\201C';position:absolute;top:14px;right:24px;font-family:var(--display);font-size:5rem;font-weight:800;color:var(--lime-tint);line-height:1}
    .testi-card:hover{transform:translateY(-3px);box-shadow:0 18px 36px -22px rgba(15,23,42,.14)}
    .testi-product{font-family:var(--mono);font-size:.72rem;font-weight:700;color:var(--indigo);background:var(--indigo-tint);padding:5px 10px;border-radius:5px;letter-spacing:.04em;display:inline-block;margin-bottom:14px;text-transform:uppercase}
    .testi-quote{font-size:.98rem;color:var(--ink);line-height:1.7;margin-bottom:22px;flex:1;position:relative;z-index:1}
    .testi-author{display:flex;align-items:center;gap:12px;border-top:1px dashed var(--ink-line-md);padding-top:18px}
    .testi-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--indigo),var(--indigo-soft));color:var(--lime);display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:800;font-size:.92rem;flex-shrink:0}
    .testi-name{display:block;font-weight:700;color:var(--ink);font-size:.94rem}
    .testi-role{display:block;font-size:.82rem;color:var(--ink-mute);margin-top:2px}

    /* ── DISCLOSURES ───────────────────────────────────────── */
    .disc{background:var(--cream);border-top:1px solid var(--cream-deep)}
    .disc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px}
    .disc-card{background:var(--paper);border:1px solid rgba(15,23,42,.1);border-radius:16px;padding:22px;display:flex;gap:14px;align-items:flex-start}
    .disc-icon{width:38px;height:38px;border-radius:50%;background:var(--lime);color:var(--indigo-deep);display:flex;align-items:center;justify-content:center;font-size:1.05rem;font-weight:800;flex-shrink:0}
    .disc-title{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);margin-bottom:5px;letter-spacing:-.005em}
    .disc-body{font-size:.86rem;color:var(--ink-soft);line-height:1.6}

    /* ── GRIEVANCE ─────────────────────────────────────────── */
    .grievance{background:var(--bg)}
    .gv-card{background:var(--paper);border:1px solid var(--ink-line-md);border-radius:24px;padding:48px;box-shadow:0 18px 48px -24px rgba(15,23,42,.1)}
    .gv-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:48px;align-items:start}
    .gv-officer{background:linear-gradient(160deg,var(--indigo),var(--indigo-deep));color:#fff;border-radius:18px;padding:32px;position:sticky;top:100px}
    .gv-officer-eyebrow{font-family:var(--mono);font-size:.74rem;font-weight:600;color:var(--lime);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em}
    .gv-officer-name{font-family:var(--display);font-size:1.5rem;font-weight:700;margin-bottom:4px;letter-spacing:-.015em}
    .gv-officer-role{color:rgba(255,255,255,.75);font-size:.92rem;margin-bottom:24px}
    .gv-info{display:grid;gap:14px;padding-top:20px;border-top:1px dashed rgba(255,255,255,.18)}
    .gv-info-row{display:grid;grid-template-columns:74px 1fr;gap:12px;font-size:.86rem}
    .gv-info-key{font-family:var(--mono);color:rgba(255,255,255,.55);font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:.7rem;padding-top:2px}
    .gv-info-val{color:#fff;line-height:1.55;word-break:break-word}
    .gv-escalation{display:flex;flex-direction:column;gap:14px}
    .gv-step{background:var(--paper);border:1px solid var(--ink-line);border-left:4px solid var(--lime);border-radius:14px;padding:20px 22px}
    .gv-step-head{display:flex;align-items:baseline;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}
    .gv-level{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--indigo);letter-spacing:-.005em}
    .gv-tat{font-family:var(--mono);font-size:.72rem;font-weight:700;color:var(--lime-deep);background:var(--lime-tint);padding:3px 9px;border-radius:5px;letter-spacing:.04em}
    .gv-step-body{font-size:.91rem;color:var(--ink-soft);line-height:1.7;margin-bottom:8px}
    .gv-step-contact{font-size:.84rem;font-weight:500;font-family:var(--mono);background:var(--indigo-tint);padding:6px 10px;border-radius:6px;display:inline-block;color:var(--indigo)}

    /* ── CTA BAND ──────────────────────────────────────────── */
    .cta-band{background:linear-gradient(135deg,var(--indigo) 0%,var(--indigo-deep) 100%);color:#fff;padding:88px 0;position:relative;overflow:hidden}
    .cta-band::before{content:'';position:absolute;right:-220px;top:-200px;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,var(--lime-tint) 0%,transparent 70%)}
    .cta-band::after{content:'';position:absolute;left:-180px;bottom:-160px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(254,243,199,.16) 0%,transparent 70%)}
    .cta-inner{display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:center;position:relative}
    .cta-title{font-family:var(--display);font-size:clamp(2rem,3.3vw,2.8rem);font-weight:800;line-height:1.15;margin-bottom:16px;letter-spacing:-.025em;color:#fff}
    .cta-sub{color:rgba(255,255,255,.85);font-size:1.02rem;line-height:1.7}
    .cta-actions{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .cta-note{font-size:.78rem;color:rgba(255,255,255,.6)}
    .cta-disclaim{font-size:.74rem;color:rgba(255,255,255,.58);margin-top:24px;font-style:italic;line-height:1.7;border-top:1px dashed rgba(255,255,255,.18);padding-top:22px}

    /* ── CONTACT ───────────────────────────────────────────── */
    .contact{background:var(--bg);border-top:1px solid var(--ink-line)}
    .contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:start}
    .contact-info{margin-top:28px;padding-top:22px;border-top:1px dashed var(--ink-line-md);display:grid;gap:12px;font-size:.95rem;color:var(--ink-soft)}
    .contact-info b{color:var(--ink);font-weight:700}
    .form-card{background:var(--paper);border:1px solid var(--ink-line);border-radius:20px;padding:36px;box-shadow:0 18px 44px -22px rgba(15,23,42,.1)}
    .fg{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
    .fg label{font-size:.84rem;font-weight:600;color:var(--ink)}
    .fg input,.fg select,.fg textarea{padding:14px 16px;border:1.5px solid var(--ink-line-md);border-radius:12px;background:var(--paper);font-family:inherit;font-size:.95rem;color:var(--ink);outline:none;transition:border-color .2s;min-height:48px}
    .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--indigo)}
    .fg select option{background:#fff;color:var(--ink)}
    .fg-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .form-submit{width:100%;background:var(--lime);color:var(--indigo-deep);padding:16px;border-radius:14px;font-size:.98rem;font-weight:800;transition:background .2s,transform .15s;box-shadow:0 12px 28px var(--lime-glow);min-height:54px;font-family:var(--display);letter-spacing:-.005em}
    .form-submit:hover{background:var(--lime-deep);color:#fff;transform:translateY(-1px)}
    .form-disclaim{font-size:.78rem;color:var(--ink-mute);margin-top:12px;line-height:1.6}

    /* ── STICKY MOBILE CTA BAR ─────────────────────────────── */
    .mobile-cta{display:none}

    /* ── FOOTER ────────────────────────────────────────────── */
    .footer{background:var(--indigo-deep);color:rgba(255,255,255,.65);padding:64px 0 0}
    .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:44px;margin-bottom:44px}
    .f-brand{font-family:var(--display);color:#fff;font-size:1.45rem;font-weight:800;margin-bottom:8px;letter-spacing:-.025em}
    .f-tag{font-size:.86rem;color:rgba(255,255,255,.5);max-width:300px;line-height:1.7;margin-bottom:14px}
    .f-reg{font-family:var(--mono);font-size:.76rem;font-weight:600;color:var(--lime);margin-bottom:6px;letter-spacing:.02em}
    .f-cert-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
    .f-cert{font-family:var(--mono);font-size:.7rem;font-weight:600;color:#fff;background:rgba(132,204,22,.14);border:1px solid rgba(132,204,22,.3);padding:6px 11px;border-radius:5px}
    .f-col-title{font-family:var(--display);font-size:.95rem;font-weight:700;color:#fff;margin-bottom:16px;letter-spacing:-.005em}
    .f-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .f-links a{color:rgba(255,255,255,.55);font-size:.86rem;transition:color .2s}
    .f-links a:hover{color:var(--lime)}
    .footer-disclaim{padding:24px 0;border-top:1px solid rgba(255,255,255,.08);font-size:.76rem;color:rgba(255,255,255,.5);line-height:1.85;font-style:italic}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding:20px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;font-size:.78rem;color:rgba(255,255,255,.42)}

    /* ── RESPONSIVE — tablet ────────────────────────────────── */
    @media(max-width:980px){
      .hero-grid,.elig-grid,.gv-grid,.cta-inner,.contact-grid{grid-template-columns:1fr;gap:42px}
      .gv-officer{position:static}
      .process-grid{grid-template-columns:repeat(2,1fr)}
      .process-grid::before{display:none}
      .trust-strip-grid{grid-template-columns:repeat(2,1fr);gap:20px}
      .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
      .cta-actions{text-align:left;align-items:flex-start}
      .elig-cards{grid-template-columns:1fr 1fr}
    }

    /* ── RESPONSIVE — mobile (the heart of this template) ──── */
    @media(max-width:640px){
      .container{padding:0 18px}
      body{padding-bottom:84px}  /* room for sticky CTA */

      /* Nav */
      .nav-inner{padding:12px 0}
      .nav-links li:not(:last-child){display:none}
      .brand{font-size:1rem;gap:9px}
      .brand-mark{width:32px;height:32px;font-size:1rem}
      .nav-cta{padding:8px 14px;font-size:.78rem}
      .topbar{font-size:.66rem;padding:6px 0}
      .topbar-inner{flex-direction:column;gap:5px;align-items:flex-start;padding:0 18px}
      .topbar-info{gap:6px 12px;font-size:.66rem}

      /* Hero */
      .hero{padding:36px 0 56px}
      .hero-title{font-size:2.1rem;line-height:1.07}
      .hero-sub{font-size:.95rem;line-height:1.65;margin-bottom:22px}
      .hero-actions{display:flex;flex-direction:column;gap:10px;width:100%}
      .hero-actions .btn{width:100%;justify-content:center}
      .hero-nofee{font-size:.82rem;padding:10px 12px}
      .hero-nofee-ic{width:30px;height:30px;font-size:.9rem}
      .hero-eyebrow{font-size:.7rem;padding:7px 13px}

      /* Calc card — full width, simplified */
      .calc-card{padding:24px 22px;border-radius:20px}
      .calc-result-emi{font-size:2.4rem;flex-wrap:wrap}
      .calc-result-summary{font-size:.78rem;gap:4px}

      /* Trust strip */
      .trust-strip{padding:22px 0}
      .trust-strip-grid{grid-template-columns:repeat(2,1fr);gap:16px}
      .trust-stat-v{font-size:1.45rem}
      .trust-stat-l{font-size:.74rem;margin-top:4px}

      /* Sections */
      .section-pad{padding:60px 0}
      .section-head{margin-bottom:32px}
      .section-title{font-size:1.75rem}
      .section-body{font-size:.94rem;line-height:1.7}
      .section-eyebrow{font-size:.66rem}

      /* Loan cards — single column, compact */
      .loans-grid{grid-template-columns:1fr;gap:14px}
      .loan-card{padding:22px 20px;min-height:0}
      .loan-icon{width:48px;height:48px;font-size:1.35rem;border-radius:12px}
      .loan-name{font-size:1.06rem}
      .loan-body{font-size:.86rem;margin-bottom:12px}

      /* Lender grid — 2 cols on mobile */
      .lenders-grid{grid-template-columns:1fr 1fr;gap:10px}
      .lender-card{padding:14px 12px;gap:10px}
      .lender-mono{width:38px;height:38px;font-size:1.1rem}
      .lender-name{font-size:.85rem;line-height:1.25}
      .lender-meta{font-size:.66rem;gap:6px}
      .lender-type{font-size:.6rem;padding:1px 6px}

      /* Comparison: hide table, show swipeable cards */
      .comp-table{display:none}
      .comp-foot{display:none}
      .comp-head-note{display:none}
      .comp-cards{display:flex;gap:12px;overflow-x:auto;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;padding:20px 18px 22px;background:var(--bg)}
      .comp-cards::-webkit-scrollbar{display:none}
      .comp-cards{scrollbar-width:none}
      .comp-head{padding:18px 22px;font-size:.95rem}

      /* Process — single column */
      .process-grid{grid-template-columns:1fr;gap:32px}
      .process-icon{width:80px;height:80px;font-size:1.65rem;margin-bottom:16px}
      .process-num{width:28px;height:28px;font-size:.8rem;top:-6px;right:-6px}

      /* Eligibility — single column, cards full width */
      .elig-cards{grid-template-columns:1fr;gap:10px}
      .elig-card{padding:18px}
      .elig-form{padding:24px 20px}
      .elig-form-title{font-size:1.1rem;margin-bottom:18px}

      /* Documents */
      .doc-group-head{padding:18px 20px}
      .doc-group-icon{width:38px;height:38px;font-size:1.08rem}
      .doc-group-title{font-size:1rem}
      .doc-group-body{padding:0 20px}
      .doc-group.open .doc-group-body{padding-bottom:20px}
      .doc-items li{font-size:.88rem}

      /* Why */
      .why-grid{grid-template-columns:1fr;gap:12px}
      .why-card{padding:22px 20px;flex-direction:row;align-items:flex-start;gap:14px}
      .why-icon{margin-bottom:0;width:42px;height:42px;font-size:1.15rem;flex-shrink:0}
      .why-title{font-size:1rem}
      .why-body{font-size:.86rem}

      /* Testi */
      .testi-grid{grid-template-columns:1fr;gap:14px}
      .testi-card{padding:24px 20px}
      .testi-quote{font-size:.92rem}

      /* Disclosures */
      .disc-grid{grid-template-columns:1fr;gap:12px}
      .disc-card{padding:18px}

      /* Grievance */
      .gv-card{padding:24px 18px;border-radius:18px}
      .gv-officer{padding:24px 22px;border-radius:14px}
      .gv-step{padding:16px 18px}

      /* CTA + contact */
      .cta-band{padding:60px 0}
      .cta-title{font-size:1.65rem}
      .cta-sub{font-size:.92rem}
      .form-card{padding:24px 20px}
      .fg-row{grid-template-columns:1fr}

      /* Footer */
      .footer-grid{grid-template-columns:1fr}
      .footer-bottom{flex-direction:column;align-items:flex-start;gap:10px}

      /* STICKY MOBILE CTA — the killer mobile feature */
      .mobile-cta{display:flex;position:fixed;bottom:0;left:0;right:0;background:var(--paper);border-top:1px solid var(--ink-line);padding:10px 16px calc(10px + env(safe-area-inset-bottom));gap:8px;z-index:99;box-shadow:0 -8px 24px -8px rgba(15,23,42,.16);align-items:stretch}
      .mobile-cta .btn{flex:1;padding:13px 14px;font-size:.88rem;min-height:48px;border-radius:12px;gap:6px}
      .mobile-cta-wa{flex:0 0 48px;border-radius:12px;background:#25d366;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:0 6px 14px rgba(37,211,102,.4)}
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-info">
      <span>CIN: <b><%= esc(dsaCinV) %></b></span>
      <span>GSTIN: <b><%= esc(dsaGstV) %></b></span>
    </div>
    <div class="topbar-badge"><%= esc(noFeeBadgeV) %></div>
  </div>
</div>

<nav class="nav">
  <div class="container nav-inner">
    <a href="#" class="brand">
      <span class="brand-mark"><%= bn.charAt(0).toUpperCase() %></span>
      <span><%= bn %></span>
    </a>
    <ul class="nav-links">
      <li><a href="#loans">Loans</a></li>
      <li><a href="#lenders">Lenders</a></li>
      <li><a href="#comp">Rates</a></li>
      <li><a href="#elig">Eligibility</a></li>
      <li><a href="#contact" class="nav-cta"><%= esc(heroCtaPrimaryV) %></a></li>
    </ul>
  </div>
</nav>

<section class="hero">
  <div class="container hero-grid">
    <div class="reveal">
      <div class="hero-eyebrow"><%= esc(heroEyebrowV) %></div>
      <h1 class="hero-title"><%= esc(heroHeadlineLeadV) %> <em><%= esc(heroHeadlineEmphV) %></em></h1>
      <p class="hero-sub"><%= esc(heroSubV) %></p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary"><%= esc(heroCtaPrimaryV) %> →</a>
        <a href="#calc" class="btn btn-ghost"><%= esc(heroCtaSecondaryV) %></a>
      </div>
      <div class="hero-nofee">
        <span class="hero-nofee-ic">₹0</span>
        <span><b>You pay us nothing.</b> Lender pays our commission only on disbursal.</span>
      </div>
    </div>

    <div class="reveal" id="calc">
      <div class="calc-card">
        <div class="calc-result">
          <div class="calc-result-label">Your monthly EMI</div>
          <div class="calc-result-emi" id="calcEmi"><%= fmtRupee(initialEmiV) %><small>/ month</small></div>
          <div class="calc-result-summary">
            <div>Total interest <b id="calcInterest"><%= fmtRupee(initialInterestV) %></b></div>
            <div>Total payable <b id="calcTotal"><%= fmtRupee(initialTotalV) %></b></div>
          </div>
        </div>
        <div class="calc-sliders">
          <div class="calc-row">
            <label>Loan amount <b id="calcAmountVal"><%= fmtRupee(calcDefaultAmountV) %></b></label>
            <input type="range" min="50000" max="10000000" step="10000" value="<%= calcDefaultAmountV %>" class="calc-slider" id="calcAmount">
            <div class="calc-bounds"><span>₹50K</span><span>₹1Cr</span></div>
          </div>
          <div class="calc-row">
            <label>Tenure <b id="calcTenureVal"><%= calcDefaultTenureV %> months</b></label>
