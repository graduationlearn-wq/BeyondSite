  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1, 2);
    return (a + b).toUpperCase();
  }

  function loanColor(c) {
    const map = {
      indigo: { bg: '#eef2ff', text: '#3730a3', border: '#c7d2fe' },
      sky:    { bg: '#e0f2fe', text: '#075985', border: '#bae6fd' },
      lime:   { bg: '#ecfccb', text: '#365314', border: '#bef264' },
      amber:  { bg: '#fef3c7', text: '#92400e', border: '#fde68a' },
      teal:   { bg: '#ccfbf1', text: '#115e59', border: '#99f6e4' },
      violet: { bg: '#f3e8ff', text: '#6b21a8', border: '#e9d5ff' },
      rose:   { bg: '#ffe4e6', text: '#9f1239', border: '#fecdd3' },
      peach:  { bg: '#fed7aa', text: '#9a3412', border: '#fdba74' }
    };
    return map[c] || map.indigo;
  }

  // Format Indian-style number
  function fmtRupee(n) {
    if (!n && n !== 0) return '';
    const s = Math.round(n).toString();
    if (s.length <= 3) return '₹' + s;
    const last3 = s.slice(-3);
    const rest = s.slice(0, -3);
    return '₹' + rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + ',' + last3;
  }

  // Compute initial EMI (server-side, becomes the default value before JS runs)
  function initialEmi(p, t, r) {
    if (!p || !t || !r) return 0;
    const monthlyRate = (r / 100) / 12;
    const numerator = p * monthlyRate * Math.pow(1 + monthlyRate, t);
    const denominator = Math.pow(1 + monthlyRate, t) - 1;
    return denominator ? Math.round(numerator / denominator) : 0;
  }
  const initialEmiV = initialEmi(calcDefaultAmountV, calcDefaultTenureV, calcDefaultRateV);
  const initialTotalV = initialEmiV * calcDefaultTenureV;
  const initialInterestV = initialTotalV - calcDefaultAmountV;
