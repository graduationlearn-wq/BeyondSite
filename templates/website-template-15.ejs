  // Process
  const processLabelV    = def(L.processLabel,    'Get started in minutes');
  const processHeadlineV = def(L.processHeadline, 'Open your Demat — fully digital, paperless.');
  const processStepsList = (Array.isArray(L.processSteps) && L.processSteps.length)
    ? L.processSteps
    : [
        { icon: '📝', title: 'Sign up',          body: 'Enter your mobile number and email. Get an OTP-verified account in under a minute.',                duration: '1 minute' },
        { icon: '🪪', title: 'Aadhaar eKYC',     body: 'Verify identity with Aadhaar OTP. PAN is auto-pulled from the income-tax database.',                  duration: '2 minutes' },
        { icon: '✍',  title: 'eSign your forms', body: 'Aadhaar-based eSign on the account opening forms. No printing, no couriers, no branch visit.',         duration: '1 minute' },
        { icon: '🚀', title: 'Start investing',  body: 'Your demat and trading accounts are activated within 24 hours — usually much sooner.',                  duration: 'Same day' }
      ];

  // Calculators
  const calculatorsLabelV    = def(L.calculatorsLabel,    'Plan before you invest');
  const calculatorsHeadlineV = def(L.calculatorsHeadline, 'Calculators for every kind of decision.');
  const calculatorsBodyV     = def(L.calculatorsBody,     'From a first ₹500 SIP to a leveraged intraday trade — figure out the math before the money moves.');
  const calculatorsList = (Array.isArray(L.calculators) && L.calculators.length)
    ? L.calculators
    : [
        { icon: '💹', name: 'SIP Calculator',         body: 'Estimate corpus from a recurring SIP across years and expected returns.' },
        { icon: '💵', name: 'Lumpsum Calculator',     body: 'Future value of a one-time investment compounded annually.' },
        { icon: '🧾', name: 'Brokerage Calculator',   body: 'Total charges on a trade — brokerage, STT, exchange, GST, SEBI fee.' },
        { icon: '⚖',  name: 'Margin Calculator',     body: 'Pre-trade margin requirement for equity, F&O, and commodity positions.' },
        { icon: '🏦', name: 'FD Calculator',          body: 'Maturity value of a fixed deposit across tenures and interest rates.' },
        { icon: '🚗', name: 'EMI Calculator',         body: 'Monthly EMI for car, home, or personal loans with full amortisation.' }
      ];

  // Pricing / Brokerage
  const pricingLabelV    = def(L.pricingLabel,    'Brokerage & Charges');
  const pricingHeadlineV = def(L.pricingHeadline, 'Transparent pricing. No surprises.');
  const pricingBodyV     = def(L.pricingBody,     'Every paisa, listed. SEBI requires brokers to publish their charge schedule — we go a step further and show the math on every order.');
  const pricingRowsList = (Array.isArray(L.pricingRows) && L.pricingRows.length)
    ? L.pricingRows
    : [
        { segment: 'Account opening',         rate: '₹0',                       note: 'Lifetime free demat account' },
        { segment: 'Equity Delivery',         rate: '₹0',                       note: 'Zero brokerage on long-term equity' },
        { segment: 'Equity Intraday',         rate: '0.05% or ₹20 per order',   note: 'Whichever is lower' },
        { segment: 'F&O — Futures',           rate: '₹20 per order',             note: 'Flat fee on Nifty, Bank Nifty, stock futures' },
        { segment: 'F&O — Options',           rate: '₹20 per order',             note: 'Flat fee regardless of lot size' },
        { segment: 'Currency / Commodity',    rate: '₹20 per order',             note: 'MCX & NSE currency derivatives' },
        { segment: 'Mutual Funds (Direct)',    rate: '₹0',                       note: '100% commission-free, no DP charges on MF units' },
        { segment: 'DP charges',              rate: '₹13.5 + GST per scrip',     note: 'On debit of stocks from demat account' }
      ];

  // Trust Signals (Regulator badges)
  const trustLabelV    = def(L.trustLabel,    'Regulated. Transparent. Secure.');
  const trustHeadlineV = def(L.trustHeadline, 'A SEBI-registered broker with full exchange memberships.');
  const partnerLogosList = (Array.isArray(L.partnerLogos) && L.partnerLogos.length)
    ? L.partnerLogos
    : [
        { name: 'SEBI Registered' }, { name: 'NSE Member' }, { name: 'BSE Member' },
        { name: 'MCX Member' },      { name: 'CDSL DP' },    { name: 'NSDL DP' },
        { name: 'AMFI Registered' }, { name: 'ISO 27001 Certified' }
      ];

  // Testimonials
  const testimonialsList = (Array.isArray(L.testimonials) && L.testimonials.length)
    ? L.testimonials
    : [
        { quote: 'Switched from a legacy broker after watching one too many order delays during market hours. Stallion fills orders instantly — and the charges are a fraction of what I used to pay.', name: 'Aman Khurana',  role: 'Bengaluru', productUsed: 'Intraday trader · 4 years' },
        { quote: 'I started with a ₹500 SIP because the app made it that easy. Three years later I run a 12-fund portfolio with goal-mapped buckets. Zero commission on direct plans changed everything.',  name: 'Sneha Iyer',    role: 'Pune',      productUsed: 'SIP investor · MF portfolio' },
        { quote: 'The F&O terminal is what kept me. Option chain, payoff diagrams, basket orders — everything in one window. And the brokerage is flat ₹20 per order regardless of lot size.',                name: 'Rakesh Bansal', role: 'Delhi NCR', productUsed: 'F&O active trader' }
      ];

  // Grievance
  const grievanceLabelV    = def(L.grievanceLabel,    'Investor Care · Grievance Redressal');
  const grievanceHeadlineV = def(L.grievanceHeadline, 'Every complaint reaches a real person. Within hours.');
  const grievanceBodyV     = def(L.grievanceBody,     'As a SEBI-registered stock broker and depository participant, ' + bn + ' operates a 5-tier grievance mechanism. All complaints are acknowledged within 24 hours and resolved within 30 days as mandated by SEBI.');
  const groNameV    = def(L.groName,    'Ms. Priya Bhandari');
  const groRoleV    = def(L.groRole,    'Principal Compliance Officer');
  const groEmailV   = def(L.groEmail,   'compliance@stallioncapital.in');
  const groPhoneV   = def(L.groPhone,   '+91 80 4000 XXXX');
  const groAddressV = def(L.groAddress, bn + '\nIndiranagar, Bengaluru — 560038\nKarnataka');
  const groTimingsV = def(L.groTimings, 'Mon–Fri · 9:00 AM – 6:00 PM IST');
  const escalationLevelsList = (Array.isArray(L.escalationLevels) && L.escalationLevels.length)
    ? L.escalationLevels
    : [
        { level: 'Level 1 · Customer Care',      body: 'Raise a ticket via chat, email, or phone. First-response under 4 hours; most cases closed in 24.',         contact: 'support@stallioncapital.in · 1800-000-0000', tat: 'Within 24 hours' },
        { level: 'Level 2 · Compliance Officer',  body: 'Unresolved in 3 days? Escalate to the Principal Compliance Officer with your ticket reference.',            contact: groEmailV,                                     tat: 'Within 7 days' },
        { level: 'Level 3 · Exchange (NSE/BSE)',  body: 'Lodge directly with the exchange via the investor complaint portal of NSE, BSE, or MCX.',                     contact: 'investorhelpline.nseindia.com',               tat: 'Within 15 days' },
        { level: 'Level 4 · SEBI SCORES',         body: 'If unresolved after 30 days, register your complaint on SEBI\'s official investor grievance portal.',         contact: 'scores.sebi.gov.in · 1800-266-7575',          tat: 'Per SEBI norms' },
        { level: 'Level 5 · SMART ODR',           body: 'Online Dispute Resolution for unresolved investor grievances under SEBI\'s SMART ODR mechanism.',             contact: 'smartodr.in',                                 tat: 'Per SMART ODR norms' }
      ];

  // Investor Education
  const eduLabelV    = def(L.eduLabel,    'Investor Charter & Downloads');
  const eduHeadlineV = def(L.eduHeadline, 'Regulatory documents — published, downloadable, current.');
  const eduBodyV     = def(L.eduBody,     'Every disclosure SEBI requires a broker to publish — gathered in one place, plain-language summaries included.');
  const riskDocsList = (Array.isArray(L.riskDocs) && L.riskDocs.length)
    ? L.riskDocs
    : [
        { icon: '📜', title: 'Investor Charter',                  body: 'Your rights and responsibilities as a securities-market investor.' },
        { icon: '⚠',  title: 'Risk Disclosure Document (RDD)',   body: 'Mandatory pre-investment risk disclosure prescribed by SEBI.' },
        { icon: '📋', title: 'Rights & Obligations',              body: 'Rights and obligations of broker, sub-broker, depository participant, and client.' },
        { icon: '📄', title: 'MITC (Most Important Terms)',       body: 'Plain-language summary of the most important terms and conditions.' },
        { icon: '🧾', title: 'Policies & Procedures',             body: 'Internal policies on brokerage, margin, settlement, and dispute resolution.' },
        { icon: '🆔', title: 'KYC Forms',                         body: 'Account opening, modification, and nomination forms — printable PDF.' }
      ];

  // CTA
  const ctaHeadlineV = def(L.ctaHeadline, 'Open your Demat in 5 minutes. Free, for life.');
  const ctaBodyV     = def(L.ctaBody,     'Aadhaar eKYC, eSign, and instant activation. No account opening charges, no annual maintenance for the first year.');
  const ctaButtonV   = def(L.ctaButton,   'Open Free Account');
  const ctaNoteV     = def(L.ctaNote,     'No account opening charges · SEBI Registered · ' + brokerSebiRegV);

  // Contact
  const emailV   = esc(L.email)   || 'hello@stallioncapital.in';
  const phoneV   = esc(L.phone)   || '+91 80 4000 XXXX';
  const addressV = esc(L.address) || 'Indiranagar, Bengaluru 560038';
  const hoursV   = esc(L.hours)   || 'Mon–Fri · 9:00 AM – 6:00 PM IST';

  function initialsOf(name) {
    if (!name) return '·';
    const parts = String(name).trim().split(/\s+/);
    const a = (parts[0] || '')[0] || '';
    const b = (parts[1] || '')[0] || (parts[0] || '').slice(1, 2);
    return (a + b).toUpperCase();
  }
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bn %> — <%= tagln %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --purple:       <%= accent %>;
      --purple-soft:  #6f33ee;
      --purple-dark:  #3a00aa;
      --purple-tint:  rgba(85,0,235,.08);
      --purple-glow:  rgba(85,0,235,.18);
      --green:        #00b386;
      --green-tint:   rgba(0,179,134,.1);
      --red:          #eb5b3c;
      --red-tint:     rgba(235,91,60,.1);
      --gold:         #f5a623;
      --ink:          #0e0e23;
      --ink-soft:     rgba(14,14,35,.7);
      --ink-mute:     rgba(14,14,35,.45);
      --ink-line:     rgba(14,14,35,.08);
      --ink-line-md:  rgba(14,14,35,.14);
      --bg:           #ffffff;
      --bg-soft:      #f7f5ff;
      --bg-card:      #ffffff;
      --bg-violet:    #faf8ff;
      --display:      'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
      --sans:         'Inter', system-ui, -apple-system, sans-serif;
    }
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--bg);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    button{font-family:inherit;cursor:pointer;border:none}
    em{font-style:normal;color:var(--purple)}
    .container{max-width:1240px;margin:0 auto;padding:0 32px}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .55s ease,transform .55s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ── TOPBAR ─────────────────────────────────────────────────── */
    .topbar{background:var(--ink);color:rgba(255,255,255,.78);font-size:.74rem;padding:9px 0}
    .topbar-inner{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;max-width:1240px;margin:0 auto;padding:0 32px}
    .topbar-info{display:flex;gap:18px;flex-wrap:wrap;align-items:center}
    .topbar-info b{font-weight:600;color:#fff}
    .topbar-links{display:flex;gap:14px;flex-wrap:wrap}
    .topbar-links a{color:rgba(255,255,255,.62);transition:color .2s}
    .topbar-links a:hover{color:#fff;text-decoration:underline}

    /* ── NAV ────────────────────────────────────────────────────── */
    .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.94);backdrop-filter:blur(14px);border-bottom:1px solid var(--ink-line)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .brand{display:flex;align-items:center;gap:12px;font-family:var(--display);font-size:1.25rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .brand-mark{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--purple),var(--purple-soft));color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:800;font-size:1.05rem;box-shadow:0 6px 20px var(--purple-glow)}
    .nav-links{display:flex;gap:28px;align-items:center;list-style:none}
    .nav-links a{color:var(--ink-soft);font-size:.92rem;font-weight:500;transition:color .2s}
    .nav-links a:hover{color:var(--purple)}
    .nav-cta{background:var(--purple);color:#fff;padding:10px 22px;border-radius:8px;font-weight:600;box-shadow:0 8px 22px var(--purple-glow)}
    .nav-cta:hover{background:var(--purple-soft)}

    /* ── BUTTONS ────────────────────────────────────────────────── */
    .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:10px;font-size:.95rem;font-weight:600;transition:transform .15s,box-shadow .2s,background .2s}
    .btn:hover{transform:translateY(-2px)}
    .btn-primary{background:var(--purple);color:#fff;box-shadow:0 12px 28px var(--purple-glow)}
    .btn-primary:hover{background:var(--purple-soft);box-shadow:0 16px 38px var(--purple-glow)}
    .btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--ink-line-md)}
    .btn-ghost:hover{background:var(--bg-soft);border-color:var(--purple);color:var(--purple)}

    /* ── HERO ───────────────────────────────────────────────────── */
    .hero{padding:64px 0 120px;position:relative;overflow:hidden;background:linear-gradient(180deg,#ffffff 0%,#faf8ff 100%)}
    .hero::before{content:'';position:absolute;top:-180px;right:-160px;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,var(--purple-tint) 0%,transparent 70%);pointer-events:none}
    .hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:64px;align-items:center;position:relative}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:.78rem;font-weight:600;letter-spacing:.04em;color:var(--purple);background:var(--purple-tint);padding:8px 16px;border-radius:100px;margin-bottom:24px}
    .hero-eyebrow::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green)}
    .hero-title{font-family:var(--display);font-weight:800;font-size:clamp(2.6rem,5.5vw,4.6rem);line-height:1.05;letter-spacing:-.025em;color:var(--ink);margin-bottom:22px}
    .hero-title em{display:inline-block}
    .hero-sub{font-size:1.05rem;color:var(--ink-soft);max-width:520px;margin-bottom:34px;line-height:1.7}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:30px}
    .hero-mini-stats{display:flex;gap:28px;flex-wrap:wrap;padding-top:24px;border-top:1px solid var(--ink-line)}
    .hero-mini-stat{display:flex;flex-direction:column;gap:2px}
    .hero-mini-stat-v{font-family:var(--display);font-size:1.3rem;font-weight:800;color:var(--ink);letter-spacing:-.01em}
    .hero-mini-stat-l{font-size:.78rem;color:var(--ink-mute);font-weight:500}

    /* Hero panel: phone mockup + chart */
    .hero-panel{position:relative;display:flex;justify-content:center;align-items:center}
    .phone-frame{position:relative;width:300px;height:560px;background:linear-gradient(180deg,#1a1a2e,#0f0f1a);border-radius:38px;padding:14px;box-shadow:0 40px 80px -30px rgba(85,0,235,.45),0 18px 36px -16px rgba(14,14,35,.4);border:1px solid rgba(255,255,255,.08)}
    .phone-screen{width:100%;height:100%;border-radius:26px;background:#fff;overflow:hidden;position:relative;display:flex;flex-direction:column}
    .phone-notch{position:absolute;top:18px;left:50%;transform:translateX(-50%);width:96px;height:22px;background:#1a1a2e;border-radius:0 0 12px 12px;z-index:5}
    .phone-app-bar{padding:42px 18px 14px;display:flex;justify-content:space-between;align-items:center;background:#fff;border-bottom:1px solid var(--ink-line)}
    .phone-greet{font-size:.7rem;color:var(--ink-mute)}
    .phone-greet b{display:block;font-size:.95rem;font-weight:700;color:var(--ink);margin-top:1px}
    .phone-bell{width:30px;height:30px;border-radius:50%;background:var(--bg-soft);display:flex;align-items:center;justify-content:center;font-size:.85rem}
    .phone-stock{margin:14px 14px 0;padding:14px;border-radius:14px;background:linear-gradient(135deg,var(--purple) 0%,var(--purple-soft) 100%);color:#fff;position:relative;overflow:hidden}
    .phone-stock-name{font-size:.72rem;opacity:.85;font-weight:500}
    .phone-stock-price{font-family:var(--display);font-size:1.55rem;font-weight:800;margin:3px 0 1px;letter-spacing:-.01em}
    .phone-stock-change{font-size:.72rem;display:inline-flex;align-items:center;gap:4px;background:rgba(255,255,255,.16);padding:2px 7px;border-radius:100px;font-weight:600}
    .phone-stock-change::before{content:'▲';font-size:.55rem}
    .phone-spark{position:absolute;right:14px;top:14px;width:88px;height:38px}
    .phone-tabs{display:flex;justify-content:space-around;padding:12px 14px;background:#fff;border-bottom:1px solid var(--ink-line);font-size:.62rem;color:var(--ink-mute);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
    .phone-tab.active{color:var(--purple)}
    .phone-list{flex:1;padding:8px 14px;display:flex;flex-direction:column;gap:8px;overflow:hidden}
    .phone-row{display:flex;align-items:center;justify-content:space-between;padding:9px 11px;border-radius:10px;background:var(--bg-soft);font-size:.74rem}
    .phone-row-name{font-weight:600;color:var(--ink)}
    .phone-row-sub{display:block;font-size:.62rem;color:var(--ink-mute);font-weight:500;margin-top:1px}
    .phone-row-price{text-align:right;font-weight:700;color:var(--ink)}
    .phone-row-chg{display:block;font-size:.62rem;font-weight:600;margin-top:1px}
    .phone-row-chg.up{color:var(--green)}
    .phone-row-chg.down{color:var(--red)}
    .phone-cta{margin:0 14px 14px;padding:13px;background:var(--purple);color:#fff;text-align:center;border-radius:12px;font-size:.82rem;font-weight:700;letter-spacing:.02em}

    /* Floating chart card behind phone */
    .float-card{position:absolute;background:#fff;border-radius:14px;padding:14px 16px;box-shadow:0 18px 50px -20px rgba(14,14,35,.18);border:1px solid var(--ink-line);display:flex;align-items:center;gap:10px}
    .float-card-1{top:18%;left:-8%;}
    .float-card-2{bottom:14%;right:-6%;}
    .float-card-ico{width:36px;height:36px;border-radius:9px;background:var(--green-tint);color:var(--green);display:flex;align-items:center;justify-content:center;font-size:1.05rem}
    .float-card-2 .float-card-ico{background:var(--purple-tint);color:var(--purple)}
    .float-card-text{font-size:.74rem;color:var(--ink-mute);font-weight:500}
    .float-card-text b{display:block;font-size:.92rem;color:var(--ink);font-weight:700;font-family:var(--display)}

    /* ── HERO TRUST STRIP ───────────────────────────────────────── */
    .trust-strip{background:var(--ink);padding:32px 0}
    .trust-strip-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
    .trust-stat-v{font-family:var(--display);font-size:clamp(1.6rem,2.6vw,2.2rem);font-weight:800;color:#fff;letter-spacing:-.01em;line-height:1}
    .trust-stat-l{font-size:.82rem;color:rgba(255,255,255,.6);font-weight:500;margin-top:6px}

    /* ── SECTION ────────────────────────────────────────────────── */
    .section-pad{padding:96px 0}
    .section-head{text-align:left;max-width:780px;margin-bottom:54px}
    .section-head.center{margin-left:auto;margin-right:auto;text-align:center}
    .section-eyebrow{font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--purple);margin-bottom:14px}
    .section-title{font-family:var(--display);font-size:clamp(2rem,3.5vw,3rem);font-weight:800;line-height:1.12;letter-spacing:-.02em;color:var(--ink);margin-bottom:14px}
    .section-body{font-size:1rem;color:var(--ink-soft);line-height:1.75;max-width:680px}

    /* ── PRODUCTS ───────────────────────────────────────────────── */
    .products{background:var(--bg)}
    .products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px}
    .product-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:16px;padding:26px 24px;transition:transform .25s,border-color .25s,box-shadow .25s;position:relative;overflow:hidden}
    .product-card:hover{transform:translateY(-4px);border-color:var(--purple);box-shadow:0 18px 40px -22px var(--purple-glow)}
    .product-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--purple),var(--purple-soft));opacity:0;transition:opacity .25s}
    .product-card:hover::before{opacity:1}
    .product-icon{width:48px;height:48px;border-radius:11px;background:var(--purple-tint);color:var(--purple);display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:18px}
    .product-name{font-family:var(--display);font-size:1.25rem;font-weight:700;color:var(--ink);margin-bottom:5px;letter-spacing:-.01em}
    .product-tagline{font-size:.82rem;color:var(--purple);font-weight:600;margin-bottom:10px}
    .product-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65}

    /* ── WHY CHOOSE ─────────────────────────────────────────────── */
    .why{background:var(--bg-violet);border-top:1px solid var(--ink-line);border-bottom:1px solid var(--ink-line)}
    .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:22px}
    .why-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:14px;padding:28px;display:flex;flex-direction:column;gap:12px;transition:transform .25s,box-shadow .25s}
    .why-card:hover{transform:translateY(-3px);box-shadow:0 14px 36px -18px rgba(14,14,35,.12)}
    .why-icon{width:46px;height:46px;border-radius:11px;background:linear-gradient(135deg,var(--purple),var(--purple-soft));color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.35rem;box-shadow:0 8px 22px var(--purple-glow)}
    .why-title{font-family:var(--display);font-size:1.1rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .why-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65}

    /* ── PROCESS ────────────────────────────────────────────────── */
    .process{background:var(--bg)}
    .process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;position:relative}
    .process-grid::before{content:'';position:absolute;top:46px;left:8%;right:8%;height:2px;background:repeating-linear-gradient(90deg,var(--purple) 0 6px,transparent 6px 14px);opacity:.35;z-index:0}
    .process-step{position:relative;z-index:1;text-align:center;padding:0 6px}
    .process-icon{width:96px;height:96px;border-radius:50%;background:var(--bg);border:2px solid var(--purple);color:var(--purple);font-size:2rem;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;position:relative;box-shadow:0 14px 28px -14px var(--purple-glow)}
    .process-num{position:absolute;top:-8px;right:-8px;width:30px;height:30px;border-radius:50%;background:var(--purple);color:#fff;font-family:var(--display);font-weight:800;font-size:.9rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px var(--purple-glow)}
    .process-title{font-family:var(--display);font-size:1.15rem;font-weight:700;color:var(--ink);margin-bottom:8px;letter-spacing:-.01em}
    .process-body{font-size:.88rem;color:var(--ink-soft);line-height:1.65;max-width:230px;margin:0 auto 12px}
    .process-duration{display:inline-block;font-size:.74rem;font-weight:700;letter-spacing:.04em;color:var(--green);background:var(--green-tint);padding:5px 12px;border-radius:100px;text-transform:uppercase}

    /* ── CALCULATORS ───────────────────────────────────────────── */
    .calc{background:var(--bg-violet);border-top:1px solid var(--ink-line);border-bottom:1px solid var(--ink-line)}
    .calc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px}
    .calc-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:12px;padding:22px;transition:transform .25s,border-color .25s,box-shadow .25s;display:flex;flex-direction:column;gap:8px}
    .calc-card:hover{transform:translateY(-3px);border-color:var(--purple);box-shadow:0 14px 30px -16px var(--purple-glow)}
    .calc-icon{width:40px;height:40px;border-radius:9px;background:var(--purple-tint);color:var(--purple);display:flex;align-items:center;justify-content:center;font-size:1.25rem;margin-bottom:4px}
    .calc-name{font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);letter-spacing:-.01em}
    .calc-body{font-size:.82rem;color:var(--ink-soft);line-height:1.55}

    /* ── PRICING ───────────────────────────────────────────────── */
    .pricing{background:var(--bg)}
    .pricing-card{background:var(--bg-card);border:1px solid var(--ink-line-md);border-radius:18px;overflow:hidden;box-shadow:0 18px 44px -22px rgba(14,14,35,.1)}
    .pricing-head{background:linear-gradient(135deg,var(--purple),var(--purple-soft));color:#fff;padding:24px 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
    .pricing-head-title{font-family:var(--display);font-size:1.1rem;font-weight:700;letter-spacing:-.01em}
    .pricing-head-note{font-size:.82rem;opacity:.8}
    .pricing-table{width:100%;border-collapse:collapse}
    .pricing-table th,.pricing-table td{padding:18px 32px;text-align:left;border-bottom:1px solid var(--ink-line);font-size:.92rem}
    .pricing-table th{background:var(--bg-soft);font-weight:700;color:var(--ink-mute);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase}
    .pricing-table tr:last-child td{border-bottom:none}
    .pricing-segment{font-weight:600;color:var(--ink)}
    .pricing-rate{font-family:var(--display);font-weight:700;color:var(--purple)}
    .pricing-note{font-size:.82rem;color:var(--ink-mute)}
    .pricing-foot{padding:18px 32px;background:var(--bg-soft);font-size:.78rem;color:var(--ink-mute);font-style:italic;border-top:1px solid var(--ink-line);line-height:1.55}

    /* ── TRUST / REGULATOR BADGES ──────────────────────────────── */
    .trust{background:var(--bg-violet);border-top:1px solid var(--ink-line)}
    .trust-grid{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:36px}
    .trust-pill{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:100px;padding:10px 20px;font-size:.9rem;font-weight:600;color:var(--ink);display:inline-flex;align-items:center;gap:8px;transition:transform .2s,border-color .2s}
    .trust-pill:hover{transform:translateY(-2px);border-color:var(--purple);color:var(--purple)}
    .trust-pill::before{content:'✓';color:var(--green);font-weight:800}

    /* ── TESTIMONIALS ──────────────────────────────────────────── */
    .testi{background:var(--bg)}
    .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px}
    .testi-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:16px;padding:30px;display:flex;flex-direction:column;transition:transform .25s,box-shadow .25s}
    .testi-card:hover{transform:translateY(-3px);box-shadow:0 16px 38px -22px rgba(14,14,35,.12)}
    .testi-product{font-size:.74rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--purple);margin-bottom:16px}
    .testi-quote{font-size:1rem;color:var(--ink);line-height:1.65;margin-bottom:22px;flex:1}
    .testi-author{display:flex;align-items:center;gap:12px;border-top:1px solid var(--ink-line);padding-top:18px}
    .testi-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--purple-soft));color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:700;font-size:.95rem;flex-shrink:0}
    .testi-name{display:block;font-weight:700;color:var(--ink);font-size:.94rem}
    .testi-role{display:block;font-size:.82rem;color:var(--ink-mute);margin-top:2px}

    /* ── GRIEVANCE ─────────────────────────────────────────────── */
    .grievance{background:var(--bg-violet);border-top:1px solid var(--ink-line)}
    .gv-card{background:var(--bg-card);border:1px solid var(--ink-line-md);border-radius:20px;padding:48px;box-shadow:0 18px 48px -24px rgba(14,14,35,.12)}
    .gv-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:48px;align-items:start}
    .gv-officer{background:linear-gradient(160deg,var(--purple),var(--purple-dark));color:#fff;border-radius:16px;padding:32px;position:sticky;top:100px}
    .gv-officer-eyebrow{font-size:.74rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:14px}
    .gv-officer-name{font-family:var(--display);font-size:1.5rem;font-weight:800;margin-bottom:4px;letter-spacing:-.01em}
    .gv-officer-role{color:rgba(255,255,255,.75);font-size:.92rem;margin-bottom:24px}
    .gv-info{display:grid;gap:14px;padding-top:20px;border-top:1px solid rgba(255,255,255,.18)}
    .gv-info-row{display:grid;grid-template-columns:74px 1fr;gap:12px;font-size:.86rem}
    .gv-info-key{color:rgba(255,255,255,.55);font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:.7rem;padding-top:2px}
    .gv-info-val{color:#fff;line-height:1.55;word-break:break-word}
    .gv-escalation{display:flex;flex-direction:column;gap:12px}
    .gv-step{background:var(--bg-soft);border:1px solid var(--ink-line);border-left:4px solid var(--purple);border-radius:10px;padding:18px 20px}
    .gv-step-head{display:flex;align-items:baseline;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}
    .gv-level{font-family:var(--display);font-size:.98rem;font-weight:700;color:var(--purple);letter-spacing:-.01em}
    .gv-tat{font-size:.72rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--green);background:var(--green-tint);padding:4px 10px;border-radius:100px}
    .gv-step-body{font-size:.87rem;color:var(--ink-soft);line-height:1.65;margin-bottom:8px}
    .gv-step-contact{font-size:.82rem;font-weight:500;font-family:ui-monospace,monospace;background:var(--purple-tint);padding:6px 10px;border-radius:5px;display:inline-block;color:var(--purple)}

    /* ── INVESTOR EDUCATION ────────────────────────────────────── */
    .edu{background:var(--bg)}
    .edu-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .edu-card{background:var(--bg-card);border:1px solid var(--ink-line);border-radius:12px;padding:22px;display:flex;gap:14px;align-items:flex-start;transition:transform .25s,border-color .25s,box-shadow .25s}
    .edu-card:hover{transform:translateY(-2px);border-color:var(--purple);box-shadow:0 14px 30px -18px var(--purple-glow)}
    .edu-icon{width:38px;height:38px;border-radius:9px;background:var(--purple-tint);color:var(--purple);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    .edu-title{font-family:var(--display);font-size:.98rem;font-weight:700;color:var(--ink);margin-bottom:4px;letter-spacing:-.01em}
    .edu-body{font-size:.82rem;color:var(--ink-soft);line-height:1.55}

    /* ── CTA BAND ──────────────────────────────────────────────── */
    .cta-band{background:linear-gradient(135deg,var(--purple) 0%,var(--purple-dark) 100%);color:#fff;padding:88px 0;position:relative;overflow:hidden}
    .cta-band::before{content:'';position:absolute;right:-200px;top:-180px;width:540px;height:540px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.12) 0%,transparent 70%);pointer-events:none}
    .cta-band::after{content:'';position:absolute;left:-160px;bottom:-160px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(245,166,35,.16) 0%,transparent 70%);pointer-events:none}
    .cta-inner{display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:center;position:relative}
    .cta-title{font-family:var(--display);font-size:clamp(1.9rem,3vw,2.6rem);font-weight:800;line-height:1.2;margin-bottom:14px;letter-spacing:-.02em;color:#fff}
    .cta-sub{color:rgba(255,255,255,.85);font-size:1rem;line-height:1.7}
    .cta-actions{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .cta-actions .btn-primary{background:#fff;color:var(--purple);box-shadow:0 14px 32px rgba(0,0,0,.25)}
    .cta-actions .btn-primary:hover{background:#f5f5ff}
    .cta-note{font-size:.78rem;color:rgba(255,255,255,.6)}
    .cta-disclaim{font-size:.74rem;color:rgba(255,255,255,.55);margin-top:24px;font-style:italic;line-height:1.65;border-top:1px solid rgba(255,255,255,.16);padding-top:20px}

    /* ── CONTACT ───────────────────────────────────────────────── */
    .contact{background:var(--bg);border-top:1px solid var(--ink-line)}
    .contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:64px;align-items:start}
    .contact-info{margin-top:28px;padding-top:22px;border-top:1px dashed var(--ink-line-md);display:grid;gap:10px;font-size:.92rem;color:var(--ink-soft)}
    .contact-info b{color:var(--ink);font-weight:600}
    .form-card{background:var(--bg-soft);border:1px solid var(--ink-line);border-radius:16px;padding:36px;box-shadow:0 14px 36px -22px rgba(14,14,35,.1)}
    .fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
    .fg label{font-size:.82rem;font-weight:600;color:var(--ink)}
    .fg input,.fg select,.fg textarea{padding:12px 14px;border:1.5px solid var(--ink-line-md);border-radius:9px;background:#fff;font-family:inherit;font-size:.95rem;color:var(--ink);outline:none;transition:border-color .2s}
    .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--purple)}
    .fg select option{background:#fff;color:var(--ink)}
    .fg-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .form-submit{width:100%;background:var(--purple);color:#fff;padding:14px;border-radius:10px;font-size:.95rem;font-weight:700;transition:background .2s,transform .15s;box-shadow:0 10px 26px var(--purple-glow)}
    .form-submit:hover{background:var(--purple-soft);transform:translateY(-1px)}
    .form-disclaim{font-size:.74rem;color:var(--ink-mute);margin-top:12px;line-height:1.55}

    /* ── FOOTER ────────────────────────────────────────────────── */
    .footer{background:var(--ink);color:rgba(255,255,255,.62);padding:64px 0 0}
    .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:44px;margin-bottom:44px}
    .f-brand{font-family:var(--display);color:#fff;font-size:1.35rem;font-weight:800;margin-bottom:8px;letter-spacing:-.01em}
    .f-tag{font-size:.86rem;color:rgba(255,255,255,.5);max-width:300px;line-height:1.65;margin-bottom:14px}
    .f-reg{font-size:.77rem;font-weight:600;color:var(--gold);margin-bottom:10px;letter-spacing:.02em}
    .f-cert-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}
    .f-cert{font-size:.7rem;font-weight:600;color:#fff;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);padding:5px 10px;border-radius:5px}
    .f-col-title{font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#fff;margin-bottom:16px}
    .f-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .f-links a{color:rgba(255,255,255,.55);font-size:.87rem;transition:color .2s}
    .f-links a:hover{color:#fff}
    .footer-attention{padding:24px 0;border-top:1px solid rgba(255,255,255,.08);font-size:.74rem;color:rgba(255,255,255,.5);line-height:1.7}
    .footer-attention b{color:#fff;display:block;margin-bottom:8px;font-size:.78rem;letter-spacing:.06em;text-transform:uppercase}
    .footer-attention p{margin-bottom:6px}
    .footer-disclaim{padding:20px 0;border-top:1px solid rgba(255,255,255,.08);font-size:.72rem;color:rgba(255,255,255,.4);line-height:1.75;font-style:italic}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding:20px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;font-size:.78rem;color:rgba(255,255,255,.42)}

    /* ── RESPONSIVE ────────────────────────────────────────────── */
    @media(max-width:980px){
      .hero-grid,.gv-grid,.cta-inner,.contact-grid{grid-template-columns:1fr;gap:48px}
      .gv-officer{position:static}
      .process-grid{grid-template-columns:repeat(2,1fr)}
      .process-grid::before{display:none}
      .trust-strip-grid{grid-template-columns:repeat(2,1fr);gap:20px}
      .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
      .cta-actions{text-align:left;align-items:flex-start}
      .phone-frame{width:260px;height:500px}
      .float-card-1{left:-2%}
      .float-card-2{right:-2%}
      .pricing-table th,.pricing-table td{padding:14px 20px;font-size:.85rem}
    }
    @media(max-width:640px){
      .container{padding:0 20px}
      .nav-links li:not(:last-child){display:none}
      .topbar{font-size:.68rem;padding:7px 0}
      .topbar-inner{flex-direction:column;gap:6px;align-items:flex-start}
      .topbar-info{gap:6px 12px}
      .topbar-links{display:none}
      .section-pad{padding:64px 0}
      .process-grid{grid-template-columns:1fr}
      .trust-strip-grid{grid-template-columns:1fr;gap:24px}
      .footer-grid{grid-template-columns:1fr}
      .fg-row{grid-template-columns:1fr}
      .gv-card{padding:28px 20px}
      .phone-frame{width:240px;height:460px}
      .float-card{display:none}
      .pricing-table th,.pricing-table td{padding:12px 16px;font-size:.8rem}
      .pricing-note{display:none}
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-info">
