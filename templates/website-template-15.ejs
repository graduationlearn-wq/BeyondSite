  const heroHeadlineEmphV = def(L.heroHeadlineEmph, 'everything.');
  const heroSubV          = def(L.heroSub,          'Stocks, F&O, IPOs, Mutual Funds, ETFs, Bonds — one app, zero account-opening charges. SEBI-registered since ' + founded + '.');
  const heroCtaPrimaryV   = def(L.heroCtaPrimary,   'Open Free Demat');
  const heroCtaSecondaryV = def(L.heroCtaSecondary, 'Explore Stocks');
  const heroActiveUsersV  = def(L.heroActiveUsers,  '5 Lakh+ active investors');
  const heroAumValueV     = def(L.heroAumValue,     '₹38,000 Cr+ Assets');
  const trustStatsList = (Array.isArray(L.trustStats) && L.trustStats.length)
    ? L.trustStats
    : [
        { value: '5L+',     label: 'Active investors' },
        { value: '₹38KCr',  label: 'Assets under custody' },
        { value: '0',       label: 'Account opening charges' },
        { value: '24/7',    label: 'Customer support' }
      ];

  // Products
  const productsLabelV    = def(L.productsLabel,    'Build your portfolio');
  const productsHeadlineV = def(L.productsHeadline, 'One account. Every asset class.');
  const productsBodyV     = def(L.productsBody,     'Whether you are buying your first share or running a derivatives book — every product is in the same login, with one consolidated P&L.');
  const productsList = (Array.isArray(L.products) && L.products.length && (typeof L.products[0] === 'object'))
    ? L.products
    : [
        { icon: '📈', name: 'Stocks',         tagline: 'NSE & BSE listed equities',          body: 'Invest in companies across market caps. Track real-time P&L, set price alerts, place orders in milliseconds.' },
        { icon: '📊', name: 'F&O',            tagline: 'Futures & Options terminal',         body: 'Trade Nifty, Bank Nifty, and stock derivatives with advanced charts, option chains, and basket orders.' },
        { icon: '🪙', name: 'Mutual Funds',   tagline: 'Direct plans · zero commission',     body: 'Invest via SIP or lumpsum across all AMCs. We earn nothing on direct plans — your returns stay yours.' },
        { icon: '🚀', name: 'IPO',            tagline: 'Apply with one click',               body: 'Track upcoming and ongoing IPOs. UPI mandate in seconds — no cheques, no paperwork.' },
        { icon: '🛡', name: 'ETFs',           tagline: 'Index, Gold, Silver, International', body: 'Diversified exposure at low cost. Hold ETFs alongside stocks in the same demat account.' },
        { icon: '💼', name: 'Bonds',          tagline: 'Fixed-income earning regular yield', body: 'Government and corporate bonds with transparent yields. Settle in your demat account — no separate custody.' },
        { icon: '💰', name: 'MTF',            tagline: 'Buy now, pay later',                 body: 'Margin Trading Facility — up to 4× leverage on eligible stocks. Pledge holdings for instant margin.' },
        { icon: '🛢', name: 'Commodities',    tagline: 'Crude, Gold, Silver — MCX',          body: 'Trade real-world assets on the MCX with the same terminal you use for equities.' }
      ];

  // Why Choose
  const whyChooseLabelV    = def(L.whyChooseLabel,    'Why investors trust us');
