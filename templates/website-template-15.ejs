  // Regulatory
  const brokerSebiRegV    = def(L.brokerSebiReg,    'INZ000301838');
  const nseBseMemberCodeV = def(L.nseBseMemberCode, 'NSE-11724 · BSE-1234');
  const cdslDpIdV         = def(L.cdslDpId,         'CDSL: IN-DP-417-2019');
  const mcxMemberCodeV    = def(L.mcxMemberCode,    'MCX-56789');
  const brokerCinV        = def(L.brokerCin,        'U65100KA2016PTC092879');
  const amfiArnV          = def(L.amfiArn,          'ARN-111686');

  // Mandatory disclaimers — SEBI / Exchange / AMFI — must not be removed
  const RISK_DISC       = 'Investment in securities market is subject to market risks. Read all the related documents carefully before investing.';
